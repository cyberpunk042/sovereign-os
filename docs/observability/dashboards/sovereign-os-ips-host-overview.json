    {"title": "M060 mirror-domains", "url": "/d/sovereign-os-m060-mirror-domains", "type": "link", "icon": "external link"},
    {"title": "MS022 SSE quota", "url": "/d/sovereign-os-ms022-sse-quota", "type": "link", "icon": "external link"},
    {"title": "four-watchdog (IPS spine)", "url": "/d/sovereign-os-four-watchdog", "type": "link", "icon": "external link"},
    {"title": "modules-catalog", "url": "/d/sovereign-os-selfdef-modules", "type": "link", "icon": "external link"},
    {"title": "daemon-process", "url": "/d/sovereign-os-selfdef-daemon-process", "type": "link", "icon": "external link"},
    {"title": "AppArmor", "url": "/d/sovereign-os-selfdef-apparmor", "type": "link", "icon": "external link"},
