{
  "_comment": "sovereign-os selfdef SDD-068 token-revocations dashboard. Visualizes selfdef_token_revocations_* gauges (selfdef commit 24ebd58, merged at 251b10f6 via #205; SDD-068 spec at d2c3f74 / #202 a21dc931). Completes the IPS-quartet observability set with blockset (#39) + quarantine (#40) + revocations (#41) + token-revocations (#42 this dashboard).",
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [
    {"title": "operator runbook", "url": "/d/sovereign-os-selfdef-token-revocations#runbook", "type": "link", "icon": "doc"},
    {"title": "SDD-068 spec", "url": "https://github.com/cyberpunk042/selfdef/blob/main/docs/sdd/068-api-token-revocation-action-surface.md", "type": "link", "icon": "external link"},
    {"title": "producer source", "url": "https://github.com/cyberpunk042/selfdef/blob/main/packaging/scripts/selfdef-token-revocations-textfile.sh", "type": "link", "icon": "external link"},
