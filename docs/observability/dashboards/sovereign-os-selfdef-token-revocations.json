  ],
  "panels": [
    {
      "type": "stat",
      "title": "token-revocations state-dir present",
      "description": "Red at 0 = selfdefd didn't bootstrap; SDD-068 enforcement OFFLINE.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "selfdef_token_revocations_state_dir_present", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "min": 0, "max": 1, "mappings": [{"type": "value", "options": {"0": {"text": "OFFLINE"}, "1": {"text": "OK"}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}}},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
    },
    {
      "type": "stat",
      "title": "active token revocations",
      "description": "Currently-active token revocation handles. Yellow at 10 matches SelfdefTokenRevocationsActiveHigh.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "selfdef_token_revocations_active_count", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 10}, {"color": "red", "value": 50}]}}},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0}
    },
    {
      "type": "stat",
      "title": "pending restore decisions",
      "description": "Operator decision queue depth. Yellow at 5 matches SelfdefTokenRevocationsPendingRestoreBacklog.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "selfdef_token_revocations_pending_restores", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 5}, {"color": "red", "value": 20}]}}},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0}
    },
    {
      "type": "stat",
      "title": "observer sentinel",
      "description": "selfdef_token_revocations_textfile_emit_failed.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "selfdef_token_revocations_textfile_emit_failed", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "min": 0, "max": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}]}}},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "token-revocations state — active vs pending-restores",
      "description": "Active total vs pending-restore subset. Gap shows operator-decided handles still TTL-ticking.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "selfdef_token_revocations_active_count", "legendFormat": "active", "refId": "A"},
        {"expr": "selfdef_token_revocations_pending_restores", "legendFormat": "pending", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "none"}},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 4}
    },
    {
      "type": "timeseries",
      "title": "state-dir presence over time",
      "description": "Should be 1 sustained — any drop is selfdefd state-dir outage.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "selfdef_token_revocations_state_dir_present", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "min": 0, "max": 1}},
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 12}
    }
  ],
  "refresh": "30s",
