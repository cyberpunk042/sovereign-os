    },
    {
      "type": "stat",
      "title": "observer emit-failed",
      "description": "Honest-offline sentinel.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "selfdef_auth_events_textfile_emit_failed", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "min": 0, "max": 1, "mappings": [{"type": "value", "options": {"0": {"text": "OK"}, "1": {"text": "FAILED"}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}]}}},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "auth events over time (failures vs successes)",
      "description": "Failed vs successful auth events side-by-side. A failures-spike with flat successes = brute-force attempt.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "selfdef_auth_events_login_failures", "refId": "A", "legendFormat": "failures"},
        {"expr": "selfdef_auth_events_login_successes", "refId": "B", "legendFormat": "successes"}
