  "panels": [
    {
      "type": "stat",
      "title": "login failures (5m)",
      "description": "Auth failures in the rolling window. Red at 20 matches SelfdefAuthEventsBruteForceDetected.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "selfdef_auth_events_login_failures", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 5}, {"color": "red", "value": 20}]}}},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
    },
    {
      "type": "stat",
      "title": "ssh invalid users (5m)",
      "description": "Invalid-user attempts. Red at 5 matches SelfdefAuthEventsSshInvalidUserAttempts (credential recon).",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "selfdef_auth_events_ssh_invalid_users", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}}},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0}
    },
    {
      "type": "stat",
      "title": "sudo invocations (5m)",
      "description": "sudo uses. Red at 10 matches SelfdefAuthEventsSudoSpike.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "selfdef_auth_events_sudo_invocations", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 3}, {"color": "red", "value": 10}]}}},
