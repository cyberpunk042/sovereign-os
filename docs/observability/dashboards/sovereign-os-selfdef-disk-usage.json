  "panels": [
    {
      "type": "stat",
      "title": "/var used %",
      "description": "Filesystem usage percent. Yellow at 75 = approaching; red at 90 = critical (IPS spine has <10% headroom).",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "selfdef_disk_usage_var_used_percent", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 75}, {"color": "red", "value": 90}]}}},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
    },
    {
      "type": "stat",
      "title": "/var free",
      "description": "Bytes free on /var. Drops to 0 = filesystem full.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "selfdef_disk_usage_var_free_bytes", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "bytes", "thresholds": {"mode": "absolute", "steps": [{"color": "red"}, {"color": "yellow", "value": 1073741824}, {"color": "green", "value": 10737418240}]}}},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0}
    },
    {
      "type": "stat",
      "title": "/var/log/selfdef",
      "description": "selfdef logs subtree size. Yellow at 5 GiB matches SelfdefLogHigh alert.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "selfdef_disk_usage_log_bytes", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "bytes", "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 5368709120}, {"color": "red", "value": 10737418240}]}}},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0}
    },
    {
      "type": "stat",
      "title": "observer emit-failed",
      "description": "Honest-offline sentinel.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "selfdef_disk_usage_textfile_emit_failed", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "min": 0, "max": 1, "mappings": [{"type": "value", "options": {"0": {"text": "OK"}, "1": {"text": "FAILED"}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}]}}},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "per-directory size over time",
      "description": "All 4 measured paths over time. A sudden growth in any line = candidate disk-fill surface.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "selfdef_disk_usage_lib_bytes", "refId": "A", "legendFormat": "/var/lib/selfdef"},
        {"expr": "selfdef_disk_usage_log_bytes", "refId": "B", "legendFormat": "/var/log/selfdef"},
        {"expr": "selfdef_disk_usage_var_log_bytes", "refId": "C", "legendFormat": "/var/log (all)"},
        {"expr": "selfdef_disk_usage_textfile_collector_bytes", "refId": "D", "legendFormat": "textfile_collector"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 20}}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4}
    },
    {
      "type": "timeseries",
      "title": "/var used % over time (with 75/90 thresholds)",
      "description": "Usage trajectory toward the alert thresholds. The line crossing 75 = warning; crossing 90 = critical.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "selfdef_disk_usage_var_used_percent", "refId": "A", "legendFormat": "{{instance}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 30}, "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 75}, {"color": "red", "value": 90}]}}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4}
    },
    {
      "type": "timeseries",
      "title": "/var free bytes over time",
      "description": "Absolute free bytes on /var filesystem.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "selfdef_disk_usage_var_free_bytes", "refId": "A", "legendFormat": "{{instance}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 20}}},
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 12}
    },
    {
      "type": "timeseries",
      "title": "observer-freshness — emit-failed sentinel",
      "description": "Red bands = wedged-wrapper windows.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "selfdef_disk_usage_textfile_emit_failed", "refId": "A", "legendFormat": "{{instance}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "none", "min": 0, "max": 1, "custom": {"drawStyle": "line", "lineInterpolation": "stepAfter", "lineWidth": 2, "fillOpacity": 50}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}]}}},
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 12}
    }
  ],
