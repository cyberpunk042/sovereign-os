  "panels": [
    {
      "type": "stat",
      "title": "retention enabled",
      "description": "1 when hot_retention_days>0 (retention on); 0 = operator opted out (events kept forever).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "selfdef_store_retention_enabled",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "hot-store size",
      "description": "Live event count in the hot SQLite store; retention keeps this bounded.",
