  "panels": [
    {
      "type": "stat",
      "title": "apparmor-profile-pivots state-dir present",
      "description": "Red at 0 = SDD-077 enforcement OFFLINE.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "selfdef_apparmor_profile_pivots_state_dir_present", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "min": 0, "max": 1, "mappings": [{"type": "value", "options": {"0": {"text": "OFFLINE"}, "1": {"text": "OK"}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}}},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0}
    },
    {
      "type": "stat",
      "title": "active profile-pivots (handles)",
      "description": "Yellow at 10. MAC policy narrowing — processes pivoted into stricter profiles.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "selfdef_apparmor_profile_pivots_active_count", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 10}, {"color": "red", "value": 50}]}}},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0}
    },
    {
      "type": "stat",
      "title": "Denied + NoTarget (config-health)",
      "description": "Sum of Denied (current profile forbids change_profile) + NoTarget (target profile not loaded). High value = rule misconfiguration or missing profiles.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "(selfdef_apparmor_profile_pivots_denied_count or vector(0)) + (selfdef_apparmor_profile_pivots_no_target_count or vector(0))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 3}, {"color": "red", "value": 10}]}}},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0}
    },
    {
      "type": "stat",
      "title": "observer sentinel",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "selfdef_apparmor_profile_pivots_textfile_emit_failed", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none", "min": 0, "max": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}]}}},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0}
    },
    {
      "type": "barchart",
      "title": "pivots breakdown by target profile",
      "description": "Per-target-profile count across active handles — mass-containment-event detection.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "selfdef_apparmor_profile_pivots_by_target_profile", "legendFormat": "{{profile}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4}
    },
    {
      "type": "timeseries",
      "title": "state over time — active vs denied vs no-target vs stale vs pending",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "selfdef_apparmor_profile_pivots_active_count", "legendFormat": "active", "refId": "A"},
        {"expr": "selfdef_apparmor_profile_pivots_denied_count", "legendFormat": "Denied (current profile forbids)", "refId": "B"},
        {"expr": "selfdef_apparmor_profile_pivots_no_target_count", "legendFormat": "NoTarget (profile not loaded)", "refId": "C"},
        {"expr": "selfdef_apparmor_profile_pivots_stale_count", "legendFormat": "Stale (pid died)", "refId": "D"},
        {"expr": "selfdef_apparmor_profile_pivots_pending_restores", "legendFormat": "pending restores", "refId": "E"}
      ],
      "fieldConfig": {"defaults": {"unit": "none"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4}
    },
    {
      "type": "barchart",
      "title": "pivots breakdown by scope (profile vs hat)",
      "description": "Profile = full aa_change_profile(); Hat = aa_change_hat() within current profile.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "selfdef_apparmor_profile_pivots_by_scope", "legendFormat": "{{scope}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "none"}},
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 12}
    },
    {
      "type": "timeseries",
      "title": "per-target-profile counts over time",
