# sovereign-os fine-tune lifecycle profiles — R290 / E5.M6.
#
# Operator-named (§1b mandate row, verbatim): "End-to-end fine-tune
# lifecycle (operator triggers training → eval → register)".
#
# Each [[profiles]] block declares one operator-named fine-tune
# workflow: download → fine-tune → eval → register → run. The
# `sovereign-osctl lifecycle plan <profile>` verb walks the stages,
# probes each (read-only) for completion, and emits the next pending
# command.
#
# Adopts R283 / SDD-030 operator-overlay-doctrine: copy this to
# /etc/sovereign-os/lifecycle-profiles.toml (or set
# SOVEREIGN_OS_OVERLAY_LIFECYCLE_PROFILES=<path>). Lists REPLACE
# entirely (§3 of doctrine) so this file is the full surface when
# present.

[[profiles]]
name        = "qwen2-7b-sft-helpdesk"
base        = "Qwen/Qwen2-7B-Instruct"
method      = "sft-trl"              # cross-ref scripts/models/fine_tune.py
dataset     = "operator-helpdesk-v1"
adapter_id  = "qwen2-helpdesk-v1"
eval_task   = "operator-helpdesk-eval"
notes       = "Reference SFT lifecycle on Zen5 + RTX PRO 6000."

[[profiles]]
name        = "llama3-1b-ternary-bench"
base        = "meta-llama/Llama-3.2-1B"
method      = "lora-unsloth"
dataset     = "operator-bench-v1"
adapter_id  = "llama3-1b-ternary-bench"
eval_task   = "lm-eval-harness-mmlu-mini"
notes       = "Small-model ternary-fast-path workload baseline."
