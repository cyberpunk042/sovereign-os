# config/sudoers.d/sovereign-os-cockpit — DRAFT, OPERATOR-REVIEW-PENDING
# ============================================================================
# The "sudoer strategy" (mechanism A) that lets cockpit panel daemons EXECUTE
# sovereign-os-owned control verbs non-interactively, realizing R10274 (the
# signed-mutation-proxy path) instead of only copying the command. The manual
# `sovereign-osctl …` command stays the documented fallback.
#
# INSTALL TARGET: /etc/sudoers.d/sovereign-os-cockpit  (mode 0440, root:root)
# Validate before install:  visudo -cf config/sudoers.d/sovereign-os-cockpit
#
# ⚠ REVIEW BEFORE WIRING ANY DAEMON — three load-bearing decisions are yours:
#   1. The runas user. This grants a DEDICATED, unprivileged service account
#      `sovereign-cockpit` NOPASSWD for a FIXED verb allowlist — never a human
#      login, never ALL. The `*-api` systemd units must then run
#      `User=sovereign-cockpit` and DROP `NoNewPrivileges=true` (it currently
#      blocks sudo). That hardening trade-off is the security-critical change
#      and must be your explicit call.
#   2. The allowlist scope. ONLY the 9 sovereign-os-OWNED controls are listed.
#      selfdef + perimeter are DELIBERATELY ABSENT — they are selfdef-owned and
#      stay a signed proxy to the selfdef producer (R10212). Never add them here.
#   3. Two-gate defence. sudoers `*` is fnmatch (does NOT cross `/`) and pins
#      only the fixed verb PREFIX. The PRIMARY gate is `_action_exec.py`, which
#      validates every placeholder value against the control's `options`
#      allowlist / a strict no-metacharacter regex BEFORE invoking sudo. This
#      file is the second gate — a defence-in-depth binary+verb allowlist.
# ============================================================================

# ── The 9 sovereign-os-OWNED control verbs (config/control-systems.yaml) ──
# One entry per control's `change_cli`; the trailing `*` is the validated
# placeholder slot. selfdef + perimeter are NOT here (R10212 boundary).
Cmnd_Alias SOVEREIGN_COCKPIT_ACTIONS = \
    /usr/local/bin/sovereign-osctl profiles switch *, \
    /usr/local/bin/sovereign-osctl trinity profile switch *, \
    /usr/local/bin/sovereign-osctl profiles flex set *, \
    /usr/local/bin/sovereign-osctl cpu-mode set *, \
    /usr/local/bin/sovereign-osctl gpu-mode set *, \
    /usr/local/bin/sovereign-osctl dashboards enable *, \
    /usr/local/bin/sovereign-osctl dashboards disable *, \
    /usr/local/bin/sovereign-osctl auth-tier set *, \
    /usr/local/bin/sovereign-osctl inference start *, \
    /usr/local/bin/sovereign-osctl inference stop *, \
    /usr/local/bin/sovereign-osctl inference restart *, \
    /usr/local/bin/sovereign-osctl workload-knobs set *

# The dedicated cockpit service account — NOPASSWD, allowlist only.
sovereign-cockpit ALL=(root) NOPASSWD: SOVEREIGN_COCKPIT_ACTIONS

# Daemon runs without a controlling TTY — sudo must not require one.
Defaults:sovereign-cockpit !requiretty
