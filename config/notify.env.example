# config/notify.env.example — operator notification SECRETS env file.
#
# WHERE THIS GOES (the question answered 2026-07-19): this is NOT a repo
# .env. Copy it to /etc/sovereign-os/notify.env on the box:
#
#   sudo install -m 0600 -o root -g root config/notify.env.example \
#        /etc/sovereign-os/notify.env
#   sudoedit /etc/sovereign-os/notify.env     # fill the real values
#
# It follows the existing /etc/sovereign-os/*.env convention
# (active-profile.env · ups.env · inference-router.env) and is loaded by
# systemd via `EnvironmentFile=-/etc/sovereign-os/notify.env` on
# sovereign-notify-dispatch.service. For interactive CLI use
# (`sovereign-osctl notifykit test`), source it into the shell:
#   set -a; . /etc/sovereign-os/notify.env; set +a
#
# The TOML configs (notify.toml / notifykit.toml) carry only these
# VARIABLE NAMES ("env:RESEND_API_KEY") — values live HERE ONLY
# (operator-supplied URLs / tokens NEVER live in-repo — docs/src/operator-env-files.md; the "SDD-009" cite R228 carried is a stale number: SDD-009 is the TDD harness).
# 0600 root-owned; never commit a filled copy.

# ── ntfy push ────────────────────────────────────────────────────────
SOVEREIGN_OS_NOTIFY_NTFY_BASE_URL=https://ntfy.sh
SOVEREIGN_OS_NOTIFY_NTFY_TOPIC=
# Optional bearer token for a self-hosted/authed ntfy:
SOVEREIGN_OS_NOTIFY_NTFY_TOKEN=

# ── generic webhook ─────────────────────────────────────────────────
SOVEREIGN_OS_NOTIFY_WEBHOOK_URL=

# ── Resend email ────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SOVEREIGN_OS_OPERATOR_EMAIL=

# ── Twilio SMS (E.164 numbers, +15551234567) ────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SOVEREIGN_OS_OPERATOR_SMS=
