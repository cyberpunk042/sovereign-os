# sovereign-os operator-deps declarative install hook — R284 / E7.M6.
#
# Operator-named (§1b verbatim): "Allow to interoperate with an MCP
# via tools calls and/or MCP. (e.g. I might install node, claude
# and whatever deps and use it on it.)"
#
# Adopts SDD-030 (operator-overlay-doctrine R283): copy to
# /etc/sovereign-os/operator-deps.toml; or point
# SOVEREIGN_OS_OVERLAY_OPERATOR_DEPS=<path> for dev runs.
#
# Triple-gate per the SOVEREIGN_OS_CONFIRM_DESTROY=YES convention:
#   - DRY-RUN by default
#   - --apply requires --confirm OR env
#   - curl-shell entries ALWAYS additionally require
#     --confirm-curl-shell (these pipe untrusted code to bash;
#     defense-in-depth)

# NOTE — the RUST toolchain is intentionally NOT here. sovereign-os's intelligence
# layer (crates/ — the Cortex Runtime) needs rust 1.89 / edition 2024, but Debian
# stable ships 1.85, so it is installed via rustup (pinned in rust-toolchain.toml)
# as a first-class build-host tool by scripts/install/rust-toolchain.sh — invoked
# from bootstrap-host.sh (step 3) + provision.sh. apt would only give 1.85.

# ─── Debian / Ubuntu system packages ───
[apt]
install = [
    "jq",           # JSON parsing in shell scripts
    "ripgrep",      # fast grep
    "fd-find",      # fast find
    "dnsutils",     # `dig` for dns-advisor + perf-baseline
    "lm-sensors",   # thermal-watch
    "nut-server",   # NUT upsd + core drivers (usbhid-ups / apcsmart) — APC Smart-UPS (R252/R253)
    "nut-client",   # NUT upsc / upsmon / upsdrvctl — power-status reads UPS state via upsc
    "nut-modbus",   # apc_modbus driver (Modbus TCP :502 / serial) — SMT2200C SmartConnect; Debian splits it out
    "wasmtime",     # R281 Wasm-AOT pipeline (if packaged)
    "zfsutils-linux",  # zpool + zfs userland — required by zfs-tiered profiles (preflight-storage)
    "nodejs",       # Node runtime — required by the [npm] claude-code global (dev workstation)
    "npm",          # npm — installs @anthropic-ai/claude-code
    "python3-yaml",       # PyYAML — ~32 operator daemons + provision.sh import yaml (image/chroot paths lack it otherwise)
    "python3-jsonschema", # catalog/profile schema validation (schema conformance + perimeter check-overlap)
    "prometheus-node-exporter",  # scrapes /var/lib/node_exporter/textfile_collector (else every Layer-B .prom metric is written into the void)
]

# ─── Python pip packages ───
[pip]
install = [
    "huggingface_hub",   # R242 model toolchain — huggingface-cli download for the SDD-702 model pull
    "transformers",      # HF reference runtime (E1.M14 workload-fit)
    "vllm",              # Oracle-tier RLM serving
    "trl",               # SFT/DPO training pipeline
    "lm-eval",           # R232 eval harness
    "mteb",              # embedding eval
    "tomli",             # TOML for Python 3.10 backports
    "warp-lang",         # R558/SDD-070 — NVIDIA Warp particle-sim (science-tools `particles`); wheel bundles CUDA 12, CPU-capable
]

# ─── Node / npm global packages ───
[npm]
global = [
    "@anthropic-ai/claude-code",   # operator's primary AI assistant
]

# ─── Curl-pipe-shell installs (operator-trusted only) ───
[curl_shell]
# Each entry: name + url + verify (sha256 | gpg | skip).
# `verify` is operator-readable metadata for now; future round adds
# the actual checksum/signature check before piping to bash.
installs = [
    # tailscale's official install script — operator-trusted but
    # ALWAYS requires --confirm-curl-shell to actually run.
    # { name = "tailscale", url = "https://tailscale.com/install.sh", verify = "skip" },
    # ollama's official install script
    # { name = "ollama", url = "https://ollama.ai/install.sh", verify = "skip" },
]
