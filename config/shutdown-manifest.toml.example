# sovereign-os graceful-shutdown manifest — R262 / SDD-029 R262 + SDD-026 Z-18.
#
# Operator-named (verbatim): "graceful on all levels, orderly" (2026-05-17) and
# "soft exit / graceful shutdown for all services and modules like a good system
# that want to reboot properly and not disrupt the user" (2026-07-08).
#
# The ordered soft-exit the host runs when:
#   - the R253 power-shutdown-guard fires (UPS battery/runtime critical + armed), OR
#   - the operator runs `sovereign-osctl power-shutdown apply --confirm`.
#
# Each step:
#   name         operator-readable label (logged + JSON-surfaced)
#   kind         systemctl-stop / shell / sleep
#   target       systemd unit (kind=systemctl-stop)
#   cmd          shell command, runs as root (kind=shell)
#   seconds      duration (kind=sleep)
#   timeout_s    abort the step after N seconds (default 30)
#   fail_action  continue (log + next) / abort (halt the sequence)
#
# RC: apply rc=0 all ok/dry-run · rc=1 ≥1 step failed · rc=2 invalid/unconfirmed.
#
# SHAPE OF THE SEQUENCE (edit freely — this is the whole policy in one file):
#   announce → grace window → DRAIN inference (finish in-flight) → stop router →
#   UNLOAD models (free VRAM) → stop operator services → sync → final warn → poweroff
#
# To REBOOT instead of power off: change the last step's cmd to `systemctl reboot`.
# To make it MORE aggressive: shrink the grace + drain timeouts. To make it gentler:
# raise them (mind [meta].total_budget_seconds vs. your UPS runtime headroom).

[meta]
description           = "Sovereign-OS graceful soft-exit (warn · drain · unload · stop · poweroff)"
total_budget_seconds  = 300

# 1. Announce across EVERY medium (notify/phone · wall · console · desktop).
[[steps]]
name         = "announce-imminent"
kind         = "shell"
cmd          = "/opt/sovereign-os/scripts/power/graceful-warn.sh imminent 'UPS battery critical — starting graceful shutdown; save your work now'"
timeout_s    = 20
fail_action  = "continue"

# 2. Grace window so an interactive operator can react before anything stops.
#    (The minutes-ahead heads-up already went out at the 'attention' verdict.)
[[steps]]
name         = "grace-window"
kind         = "sleep"
seconds      = 45
timeout_s    = 60
fail_action  = "continue"

# 3. DRAIN the inference router: 503 new requests + wait for in-flight LLM
#    messages to FINISH (bounded). No-op if inference isn't running.
[[steps]]
name         = "drain-inference-inflight"
kind         = "shell"
cmd          = "/opt/sovereign-os/scripts/power/drain-inference.sh 60"
timeout_s    = 75
fail_action  = "continue"

# 4. Stop the router itself (no more proxying).
[[steps]]
name         = "stop-router"
kind         = "systemctl-stop"
target       = "sovereign-router.service"
timeout_s    = 20
fail_action  = "continue"

# 5. UNLOAD models / stop inference backends — frees GPU VRAM cleanly.
#    (logic-engine has ExecStop=`podman stop`; the others get a clean SIGTERM.)
[[steps]]
name         = "unload-oracle-core"
kind         = "systemctl-stop"
target       = "sovereign-oracle-core.service"
timeout_s    = 45
fail_action  = "continue"

[[steps]]
name         = "unload-logic-engine"
kind         = "systemctl-stop"
target       = "sovereign-logic-engine.service"
timeout_s    = 45
fail_action  = "continue"

[[steps]]
name         = "unload-pulse"
kind         = "systemctl-stop"
target       = "sovereign-pulse.service"
timeout_s    = 20
fail_action  = "continue"

[[steps]]
name         = "stop-nvidia-mps"
kind         = "shell"
cmd          = "systemctl stop sovereign-nvidia-mps.service 2>/dev/null || true"
timeout_s    = 15
fail_action  = "continue"

# 6. Stop operator-facing services (dashboards/panels) + sampling timers.
[[steps]]
name         = "stop-dashboards"
kind         = "systemctl-stop"
target       = "sovereign-dashboards.service"
timeout_s    = 15
fail_action  = "continue"

[[steps]]
name         = "stop-watchers"
kind         = "shell"
cmd          = "systemctl stop sovereign-gpu-watch.timer sovereign-thermal-watch.timer 2>/dev/null || true"
timeout_s    = 15
fail_action  = "continue"

# 7. Flush filesystem buffers + JSONL logs to disk.
[[steps]]
name         = "flush-fs-buffers"
kind         = "shell"
cmd          = "sync"
timeout_s    = 30
fail_action  = "continue"

# 8. Let in-flight Layer B metric emission settle.
[[steps]]
name         = "settle-metrics"
kind         = "sleep"
seconds      = 5
timeout_s    = 10
fail_action  = "continue"

# 9. Final warning across all mediums: powering off now.
[[steps]]
name         = "announce-final"
kind         = "shell"
cmd          = "/opt/sovereign-os/scripts/power/graceful-warn.sh final 'powering off now — goodbye'"
timeout_s    = 15
fail_action  = "continue"

# 10. Terminal step. Substitute `systemctl reboot` for a planned restart.
[[steps]]
name         = "poweroff"
kind         = "shell"
cmd          = "systemctl poweroff"
timeout_s    = 60
fail_action  = "abort"
