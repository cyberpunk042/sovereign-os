  bashrc)
    # R447 (E11.M6): operator-discoverable bashrc integration —
    # autocompletes + aliases + helper menu. Operator §1g verbatim:
    # "the bashrc we can offer to configure it too and we can add
    # our autocompletes and aliases and manual / helps and menus".
    # Idempotent + reversible (sentinel-bounded block).
    "${__REPO_ROOT}/scripts/operator/bashrc-install.sh" "$@"
    ;;
  ms022-doctor)
    # MS022 SSE subscriber-quota chain triage — probes the 4 consumer-
    # side surfaces (proxy daemon, master-dashboard banner, systemd unit)
    # against the selfdef-side producer state (selfdef commit 77b4499
    # 6 gauges). Read-only (R10212 + R10115). Stdlib-only Python; no deps.
    # Exit codes: 0=GREEN / 1=YELLOW / 2=RED. Flags: --strict requires
    # state=ok everywhere; --json for machine-readable triage.
    # See scripts/diagnostics/ms022-doctor.py --help for the full
    # flag surface.
    "${__REPO_ROOT}/scripts/diagnostics/ms022-doctor.py" "$@"
    ;;
  m060-doctor)
    # M060 cross-repo mirror chain smoke check — pings each /api/d-NN/snapshot
    # endpoint through the sovereign-os master-dashboard proxy AND probes the
    # selfdef-side doctor textfile observers (selfdef-cli-mirror-doctor.timer
    # + selfdef-m060-doctor.timer, selfdef commits e9ab056 + ce58154) via
    # node_exporter's /metrics so one operator command verifies the full
    # producer→consumer→observer chain end-to-end. Read-only (web-is-read-
    # only doctrine MS043 R10212 + R10115). Stdlib-only Python; no deps.
    # See scripts/diagnostics/m060-smoke.py --help for flags
    # (--base-url, --node-exporter-url, --strict, --skip-doctor-observers,
    #  --json).
    "${__REPO_ROOT}/scripts/diagnostics/m060-smoke.py" "$@"
    ;;
  observability-status|obs-status)
    # NEW: cross-vertical observability triage. Probes ALL 6
    # verticals shipped to date (M060 chain-health, MS022 SSE quota,
    # four-watchdog IPS spine, selfdef-modules-catalog, selfdef-
    # daemon-process, selfdef-apparmor) in one shot via the 3 proxy
    # daemons + node_exporter scrape. Operator-runnable single-
    # command status across the entire observability surface
    # without subscribing to per-vertical alert channels.
    # R10212 read-only — never mutates anything.
    # Exit codes: 0=all green, 1=any WARN/FAIL, 2=any proxy unreach.
    # See scripts/diagnostics/observability-status.py --help.
    "${__REPO_ROOT}/scripts/diagnostics/observability-status.py" "$@"
    ;;
  version|--version|-V) cmd_version "$@" ;;
  help|--help|-h|"") cmd_help ;;
  *)
    log_error "unknown command: ${cmd}"
    cmd_help
    exit 2
    ;;
esac
