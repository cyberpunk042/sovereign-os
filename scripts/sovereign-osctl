#!/usr/bin/env bash
# scripts/sovereign-osctl — lifecycle management CLI for sovereign-os.
#
# Q-019 implementation. The operator-facing single-entry-point for
# managing an installed sovereign-os system.
#
# Verbatim operator framing (sacrosanct):
#   "even once installed and configured it will be possible to manage
#    the OS like we need to even if we need to add such an additional
#    tool and even service possibly or even multiple adapted if need be"
#
# Designed to be installed at /usr/local/bin/sovereign-osctl on the
# running system. In-repo it dispatches to scripts/hooks/* via the
# common lib.

set -euo pipefail

__SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Detect installation context: in-repo vs installed-system. Search
# order (first hit wins):
#   1. SOVEREIGN_OS_LIB env override (operator-specified)
#   2. In-repo (sibling of this script's dir)
#   3. /usr/local/lib/sovereign-os/ (make install default PREFIX)
#   4. /usr/lib/sovereign-os/ (legacy)
#   5. /opt/sovereign-os/ (alt convention used by systemd units)
declare -a _lib_candidates=(
  "${SOVEREIGN_OS_LIB:-}"
  "${__SCRIPT_DIR}/build"
  "/usr/local/lib/sovereign-os"
  "/usr/lib/sovereign-os"
  "/opt/sovereign-os"
)

for _cand in "${_lib_candidates[@]}"; do
  [ -z "${_cand}" ] && continue
  if [ -f "${_cand}/lib/common.sh" ]; then
    if [ "${_cand}" = "${__SCRIPT_DIR}/build" ]; then
      __REPO_ROOT="${__SCRIPT_DIR}/.."
    else
      __REPO_ROOT="${_cand}"
    fi
    # shellcheck source=/dev/null
    . "${_cand}/lib/common.sh"
    break
  fi
done

if [ -z "${__REPO_ROOT:-}" ]; then
  echo "error: sovereign-osctl can't locate its lib. Tried:" >&2
  for _cand in "${_lib_candidates[@]}"; do
    [ -n "${_cand}" ] && echo "  ${_cand}/lib/common.sh" >&2
  done
  echo "  Set SOVEREIGN_OS_LIB=<dir> to override." >&2
  exit 1
fi
unset _lib_candidates _cand

: "${SOVEREIGN_OS_PROFILE:=$(cat /etc/sovereign-os/active-profile 2>/dev/null || echo sain-01)}"

# ------------------------------ help -----------------------------------------

cmd_help() {
  cat <<'EOF'
sovereign-osctl — sovereign-os lifecycle management

USAGE:
  sovereign-osctl <command> [<subcommand>] [<args>]

COMMANDS:

  status [--json]              System state overview (--json for fleet aggregation)
  assistant [<sub>]            First-login assistant: full | status | reset | list
  doctor                       Sanity checks across the system

  profiles list                List declared profiles
  profiles show <id>           Print profile YAML (raw, no mixin resolution)
  profiles show-effective <id> Print profile with mixins + parent resolved
  profiles compare <a> <b>     Unified diff of two profiles' EFFECTIVE (resolved) state
  profiles fork <base> <new>   Scaffold a new profile from <base> with id <new> (validates immediately)
  profiles active              Show active profile id
  profiles switch <id>         Swap active profile (flags items requiring rebuild)
  profiles validate            Schema-validate all profiles (raw + resolved)

  whitelabel show              Show active whitelabel branding
  whitelabel apply <id>        Re-render whitelabel surfaces on the running system
  whitelabel list              List declared whitelabels
  whitelabel diff <id>         Unified diff: active whitelabel → <id>

  perimeter status             Tetragon perimeter status
  perimeter verify             Run perimeter integrity audit
  perimeter reload             Reload Tetragon TracingPolicies

  models list                  List resident models (tank/models)
  models pull <hf-id>          Pull model from HuggingFace into tank/models
  models verify                Verify resident-model integrity
  models size                  Disk-usage breakdown of tank/models
  models remove <name>         Delete a resident model (confirms)

  audit friction               Runtime friction-audit (lspci/lscpu/IOMMU)
  audit perimeter              Perimeter integrity (Tetragon policy)
  audit storage                ZFS pool + dataset health
  audit provenance [--deep] [<path>]    Inspect build-provenance.json + cross-check sha256sums.txt (+ recompute SHA256 on disk with --deep)
  audit drift [--json]         Compare deployed hardening drop-ins vs config/server + config/workstation sources
  audit customization [--json] Did my profile/whitelabel/hostname customization actually land?

  maintenance list             List on-demand maintenance subverbs
  maintenance scrub            Trigger ZFS scrub now
  maintenance arc-status       Show ZFS ARC stats
  maintenance log-rotate       Rotate ~/.sovereign-os/log/*.jsonl now
  maintenance snapshot         Take tank/context ZFS snapshot now
  maintenance security-check   Scan for pending security updates now
  maintenance models-sync      Verify resident model catalog now
  maintenance perimeter-check  Verify Tetragon perimeter policy now
  maintenance alerts-check     Derive alerts + emit meta-counters now

  hooks list [<profile>]       List hooks declared in a profile (default: active)
  hooks add <stage> <script-path> [--id <id>] [--mandatory] [--profile <id>]
                               Append a hook to the profile YAML (validates path + executable)
  hooks remove <id> [--profile <id>]
                               Remove a hook by id from the profile YAML

  decommission start           Begin decommission flow (interactive; confirms)
  decommission --plan          Preview ALL 3 decommission phases (paths, sizes, commands); writes nothing

  install image <img> --to <dev>  Safely dd a built image to a target device
                                  (gates: not-mounted-root + fingerprint + SOVEREIGN_OS_CONFIRM_DESTROY=YES)
  install image --plan <img> --to <dev>  Show fingerprint + plan, do nothing

  init [--non-interactive]     Interactive setup wizard — walk through 5 decisions
                               (profile · substrate · secure-boot · encryption · whitelabel)
                               and write .sovereign-os/init-state.yaml

  secure-boot gen-keys --out <dir>  Generate PK/KEK/db key triple (SDD-015 'signed' posture).
                                    REFUSES to write under the repo root. Operator-owned.
  secure-boot status                Inspect current PK/KEK/db enrollment + MOK state

  env list [--filter <regex>]  List every SOVEREIGN_OS_* env var with its default
                               + the file that consumes it. --filter narrows.
  env show <NAME>              Detail one env var (default · all consumers · currently-set value)

  inference status             Per-tier backend status (Pulse / Logic / Oracle / Router)
  inference health             HTTP-probe every tier's /healthz (with TCP fallback)
  inference start <tier>       Start a tier (pulse | logic | oracle | router | all)
  inference stop <tier>        Stop a tier
  inference restart <tier>     Restart a tier
  inference route <prompt>     Show which tier the router would pick for a sample request
  inference logs <tier>        Tail systemd journal for the tier

  metrics list                 List all sovereign_os_*.prom files in the textfile collector dir
  metrics show <basename>      Pretty-print a single .prom file (resolves trailing .prom)
  metrics tail [N]             Tail the N most-recently-updated .prom files (default: 5)
  metrics health               Sanity-check the textfile collector dir (presence, age, format)

  alerts [--json]              Derive operator alerts from .prom files (no Alertmanager needed)

  journal list                 List Layer A JSONL log files (size + first/last event)
  journal show <file>          Pretty-print one JSONL log file as a table
  journal tail [N]             Tail the N most recent log files (default: 3)
  journal errors               Show every error/warn entry across all log files

  history list                 Per-run summary derived from JSONL files (profile · steps · result · duration)
  history show <run-id>        Drill into one run (step-by-step pass/fail)

  version [--json]             sovereign-osctl + sovereign-os version info (--json for fleet tooling)
  help                         This help

ENV VARS (override defaults):
  SOVEREIGN_OS_PROFILE         active profile (default: read from /etc/sovereign-os/active-profile)
  SOVEREIGN_OS_LOG_LEVEL       debug|info|warn|error
  SOVEREIGN_OS_NONINTERACTIVE  set to skip all prompts (CI mode)

EXAMPLES:
  sudo sovereign-osctl status
  sudo sovereign-osctl assistant
  sudo sovereign-osctl whitelabel apply default
  sudo sovereign-osctl models pull microsoft/bitnet-b1.58-2B-4T
  sudo sovereign-osctl audit friction
EOF
}

# ------------------------------ status ---------------------------------------

cmd_status() {
  # --json mode: machine-readable status for fleet aggregation
  if [ "${1:-}" = "--json" ]; then
    local profile="${SOVEREIGN_OS_PROFILE:-unknown}"
    local active_whitelabel="default"
    [ -r /etc/sovereign-os/active-whitelabel ] && \
      active_whitelabel="$(cat /etc/sovereign-os/active-whitelabel)"
    local zfs_state="absent"
    if command -v zpool >/dev/null 2>&1 && zpool list tank >/dev/null 2>&1; then
      if zpool status tank | grep -q "state: ONLINE"; then zfs_state="online"; else zfs_state="degraded"; fi
    fi
    local tetragon_state="not-installed"
    if command -v tetragon >/dev/null 2>&1; then
      systemctl is-active --quiet tetragon && tetragon_state="active" || tetragon_state="inactive"
    fi
    local kernel; kernel="$(uname -r)"
    local os_pretty="unknown"
    [ -r /etc/os-release ] && os_pretty="$(grep PRETTY_NAME /etc/os-release | cut -d= -f2- | tr -d '"')"
    local first_boot_done="false"
    [ -r /var/lib/sovereign-os/first-boot-complete ] && first_boot_done="true"
    cat <<EOF
{
  "profile": "${profile}",
  "active_whitelabel": "${active_whitelabel}",
  "kernel_release": "${kernel}",
  "os_pretty_name": "${os_pretty}",
  "zfs_pool_state": "${zfs_state}",
  "tetragon_state": "${tetragon_state}",
  "first_boot_complete": ${first_boot_done},
  "timestamp": $(date +%s)
}
EOF
    return 0
  fi

  echo "sovereign-os status"
  echo "==================="
  echo
  echo "Profile:    ${SOVEREIGN_OS_PROFILE}"
  if [ -r /etc/os-release ]; then
    echo "OS release: $(grep PRETTY_NAME /etc/os-release | cut -d= -f2-)"
  fi
  echo "Kernel:     $(uname -r)"
  echo "Uptime:     $(uptime -p 2>/dev/null || uptime)"
  echo

  # ZFS pool
  if command -v zpool >/dev/null 2>&1; then
    echo "[ZFS pool 'tank']"
    if zpool list tank >/dev/null 2>&1; then
      zpool list tank
      echo
      zfs list -r tank -o name,used,available,refer,mountpoint 2>/dev/null
    else
      echo "  pool 'tank' not present"
    fi
    echo
  fi

  # Tetragon
  if command -v tetragon >/dev/null 2>&1; then
    echo "[Tetragon]"
    if systemctl is-active --quiet tetragon; then
      echo "  status: active"
    else
      echo "  status: INACTIVE"
    fi
    echo
  fi

  # GPUs (host-visible)
  if command -v nvidia-smi >/dev/null 2>&1; then
    echo "[NVIDIA GPUs (host-visible)]"
    nvidia-smi --query-gpu=name,memory.total,driver_version --format=csv,noheader 2>/dev/null | sed 's/^/  /' || echo "  nvidia-smi present but no GPUs visible (VFIO bound?)"
    echo
  fi

  # Network
  echo "[Network]"
  ip -brief addr show | grep -v '^lo' | sed 's/^/  /'
  echo

  # Whitelabel
  echo "[Whitelabel]"
  if [ -r /etc/sovereign-os/active-whitelabel ]; then
    echo "  active: $(cat /etc/sovereign-os/active-whitelabel)"
  else
    echo "  active: default (no /etc/sovereign-os/active-whitelabel)"
  fi
}

# ------------------------------ doctor ---------------------------------------

cmd_doctor() {
  echo "sovereign-osctl doctor"
  echo "======================"
  echo

  # Load profile so profile_field can read SOVEREIGN_OS_PROFILE_FILE
  # (its python3 subshell reads it via os.environ).
  load_profile "${SOVEREIGN_OS_PROFILE}" 2>/dev/null || true

  # Profile-aware: which checks apply?
  local layout secure_boot
  layout="$(profile_field hardware.storage.layout 2>/dev/null || echo unknown)"
  secure_boot="$(profile_field kernel.cmdline.secure_boot 2>/dev/null || echo unknown)"
  echo "  profile=${SOVEREIGN_OS_PROFILE:-unknown} layout=${layout} secure_boot=${secure_boot}"
  echo

  local issues=0 warnings=0

  # ---- Required tools (profile-conditioned) ----
  echo "[tooling]"
  local required_tools=(systemctl)
  case "${layout}" in
    zfs-tiered) required_tools+=(zpool zfs) ;;
    ext4)       required_tools+=(mkfs.ext4) ;;
  esac
  # Profile-conditioned tools
  if profile_field hardware.gpu 2>/dev/null | grep -q nvidia; then
    required_tools+=(nvidia-smi)
  fi
  if [ "${SOVEREIGN_OS_PROFILE:-}" = "sain-01" ]; then
    required_tools+=(tetragon podman)
  fi
  for tool in "${required_tools[@]}"; do
    if command -v "${tool}" >/dev/null 2>&1; then
      echo "  ✓ ${tool} installed"
    else
      echo "  ✗ ${tool} NOT installed (required by profile=${SOVEREIGN_OS_PROFILE:-unknown})"
      issues=$((issues + 1))
    fi
  done

  # ---- Systemd units ----
  echo
  echo "[systemd]"
  local required_svcs=(systemd-networkd)
  [ "${SOVEREIGN_OS_PROFILE:-}" = "sain-01" ] && required_svcs+=(tetragon)
  for svc in "${required_svcs[@]}"; do
    if systemctl is-active --quiet "${svc}" 2>/dev/null; then
      echo "  ✓ ${svc} active"
    else
      echo "  ✗ ${svc} not active"
      issues=$((issues + 1))
    fi
  done

  # ---- ZFS pool (only for zfs-tiered profiles) ----
  if [ "${layout}" = "zfs-tiered" ]; then
    echo
    echo "[zfs]"
    if zpool list tank >/dev/null 2>&1; then
      if zpool status tank | grep -q "state: ONLINE"; then
        echo "  ✓ tank pool ONLINE"
      else
        echo "  ✗ tank pool DEGRADED or UNAVAILABLE"
        issues=$((issues + 1))
      fi
    else
      echo "  ✗ tank pool not present"
      issues=$((issues + 1))
    fi
  fi

  # ---- TPM2 (when secure_boot != none) ----
  if [ "${secure_boot}" != "none" ] && [ "${secure_boot}" != "unknown" ]; then
    echo
    echo "[tpm2]"
    if [ -e /dev/tpm0 ] || [ -e /dev/tpmrm0 ]; then
      echo "  ✓ TPM device node present"
    else
      echo "  ✗ TPM device node missing (required by secure_boot=${secure_boot})"
      issues=$((issues + 1))
    fi
    if [ -d /sys/firmware/efi ]; then
      echo "  ✓ UEFI booted (efi vars dir present)"
    else
      echo "  ✗ no /sys/firmware/efi — BIOS/legacy boot? secure_boot=${secure_boot} expects UEFI"
      issues=$((issues + 1))
    fi
  fi

  # ---- Layer B metrics observability ----
  echo
  echo "[observability]"
  local mdir="${SOVEREIGN_OS_METRICS_DIR:-/var/lib/node_exporter/textfile_collector}"
  if [ -d "${mdir}" ]; then
    local n; n="$(find "${mdir}" -name 'sovereign-os-*.prom' -type f 2>/dev/null | wc -l)"
    if [ "${n}" -gt 0 ]; then
      echo "  ✓ ${n} sovereign-os metrics file(s) at ${mdir}"
    else
      echo "  ! no sovereign-os-*.prom files yet (recurrent hooks haven't run?)"
      warnings=$((warnings + 1))
    fi
  else
    echo "  ! metrics dir ${mdir} not present (node_exporter not installed?)"
    warnings=$((warnings + 1))
  fi

  # ---- inference reachability ----
  echo
  echo "[inference]"
  local any_inf=0
  for port in 8080 8081 8082 8083; do
    if (echo >/dev/tcp/127.0.0.1/"${port}") 2>/dev/null; then
      echo "  ✓ port ${port} listening"
      any_inf=1
    fi
  done
  if [ "${any_inf}" -eq 0 ]; then
    echo "  ! no inference tiers listening on 8080/8081/8082/8083"
    warnings=$((warnings + 1))
  fi

  # ---- build-state freshness ----
  echo
  echo "[build-state]"
  local state_file="${SOVEREIGN_OS_STATE_DIR:-${HOME}/.sovereign-os/build-state}/state.yaml"
  if [ -f "${state_file}" ]; then
    local age=$(( $(date +%s) - $(stat -c %Y "${state_file}" 2>/dev/null || echo 0) ))
    echo "  ✓ state.yaml present (last modified ${age}s ago)"
  else
    echo "  ! no build state at ${state_file} (image never built?)"
    warnings=$((warnings + 1))
  fi

  echo
  if [ "${issues}" -eq 0 ] && [ "${warnings}" -eq 0 ]; then
    echo "doctor: PASS (no issues, no warnings)"
  elif [ "${issues}" -eq 0 ]; then
    echo "doctor: PASS with ${warnings} warning(s) (informational; not blocking)"
  else
    echo "doctor: FAIL — ${issues} issue(s) + ${warnings} warning(s)"
    return 1
  fi
}

# ------------------------------ assistant ------------------------------------

cmd_assistant() {
  local sub="${1:-full}"
  shift || true
  case "${sub}" in
    full)
      # Re-run the entire first-login-assistant flow
      SOVEREIGN_OS_ASSISTANT_FORCE=1 "${__REPO_ROOT}/scripts/hooks/post-install/first-login-assistant.sh"
      ;;
    status)
      # Read the persisted assistant state if present
      local state_file="${SOVEREIGN_OS_ASSISTANT_STATE_DIR:-/var/lib/sovereign-os/assistant}/state.yaml"
      if [ -r "${state_file}" ]; then
        echo "Assistant state at ${state_file}:"
        echo
        cat "${state_file}"
      else
        echo "Assistant has not been run yet (no state at ${state_file})"
      fi
      ;;
    reset)
      local state_file="${SOVEREIGN_OS_ASSISTANT_STATE_DIR:-/var/lib/sovereign-os/assistant}/state.yaml"
      if [ "${SOVEREIGN_OS_ASSUME_YES:-}" != "1" ]; then
        if ! confirm "Reset assistant state at ${state_file}?" default-no; then
          log_info "reset cancelled"
          return 0
        fi
      fi
      rm -f "${state_file}"
      log_info "assistant state cleared; next run will execute full flow"
      ;;
    list)
      cat <<EOF
Assistant subverbs:
  full        Re-run the complete first-login assistant flow (default)
  status      Show persisted state.yaml (when did it run? what choices?)
  reset       Clear state.yaml (next run executes full flow)
  list        This list.

Env vars (consumed by the underlying first-login-assistant.sh):
  SOVEREIGN_OS_NONINTERACTIVE    skip prompts (use defaults)
  SOVEREIGN_OS_ASSISTANT_FORCE   ignore completed:true sentinel
EOF
      ;;
    *)
      log_error "unknown assistant subcommand: ${sub}"
      log_error "  available: full / status / reset / list"
      exit 2
      ;;
  esac
}

# ------------------------------ profiles -------------------------------------

cmd_profiles() {
  local sub="${1:-list}"
  shift || true
  case "${sub}" in
    list)
      echo "Declared profiles:"
      find "${__REPO_ROOT}/profiles" -maxdepth 1 -name '*.yaml' -type f 2>/dev/null | sort | while read -r p; do
        local id name status
        id="$(basename "$p" .yaml)"
        # Must export — profile_field invokes python3 which only sees the
        # *exported* environment, not bash shell vars.
        export SOVEREIGN_OS_PROFILE_FILE="$p"
        name="$(profile_field identity.name 2>/dev/null || true)"
        status="$(profile_field identity.status 2>/dev/null || true)"
        printf "  %-20s %-50s [%s]\n" "${id}" "${name}" "${status}"
      done
      ;;
    show)
      local id="${1:-${SOVEREIGN_OS_PROFILE}}"
      local f="${__REPO_ROOT}/profiles/${id}.yaml"
      require_file "$f"
      cat "$f"
      ;;
    show-effective)
      local id="${1:-${SOVEREIGN_OS_PROFILE}}"
      (cd "${__REPO_ROOT}" && python3 -m tools.profile_merger "${id}")
      ;;
    fork)
      # R140 (F-04 MED closure): scaffold a new profile from an existing one.
      # Copies base.yaml → new.yaml, updates identity.id, sets parent for
      # inheritance traceability, validates immediately, registers in INDEX.
      local base="${1:-}" new="${2:-}"
      if [ -z "${base}" ] || [ -z "${new}" ]; then
        log_error "usage: sovereign-osctl profiles fork <base-id> <new-id>"
        return 2
      fi
      # Validate base + new
      local base_file="${__REPO_ROOT}/profiles/${base}.yaml"
      local new_file="${__REPO_ROOT}/profiles/${new}.yaml"
      if [ ! -f "${base_file}" ]; then
        log_error "no such base profile: ${base}"
        return 1
      fi
      if [ -f "${new_file}" ]; then
        log_error "target profile already exists: ${new_file}"
        log_error "  refusing to overwrite; pick a different <new-id> or rm the file first"
        return 1
      fi
      if ! [[ "${new}" =~ ^[a-z][a-z0-9-]*$ ]]; then
        log_error "invalid new profile id: ${new}"
        log_error "  must match: ^[a-z][a-z0-9-]*$ (lowercase, digits, hyphens; starts with letter)"
        return 2
      fi
      # Read base, mutate identity.{id, parent}, write new
      BASE_FILE="${base_file}" NEW_FILE="${new_file}" BASE_ID="${base}" NEW_ID="${new}" \
      python3 - <<'PY'
import os, yaml
with open(os.environ["BASE_FILE"]) as f:
    data = yaml.safe_load(f) or {}
ident = data.setdefault("identity", {})
ident["id"] = os.environ["NEW_ID"]
ident["parent"] = os.environ["BASE_ID"]
ident["status"] = "draft"
ident["description"] = (
    f"Forked from {os.environ['BASE_ID']} via 'sovereign-osctl profiles fork'.\n"
    f"Operator-customize below; the parent reference preserves inheritance.\n\n"
    + (ident.get("description") or "")
)
with open(os.environ["NEW_FILE"], "w") as f:
    # Preserve the schema header comment
    f.write(f"# yaml-language-server: $schema=../schemas/profile.schema.yaml\n")
    f.write(f"#\n")
    f.write(f"# {os.environ['NEW_ID']} profile (forked from {os.environ['BASE_ID']} at fork time).\n")
    f.write(f"# Edit freely; mixin composition is preserved.\n#\n")
    yaml.safe_dump(data, f, sort_keys=False, default_flow_style=False)
PY
      log_info "forked: ${new_file}"
      # Validate immediately
      if [ -x "${__REPO_ROOT}/scripts/validate-profiles.sh" ]; then
        if SOVEREIGN_OS_PROFILE_FILE="${new_file}" "${__REPO_ROOT}/scripts/validate-profiles.sh" 2>/dev/null \
           | grep -q "${new}"; then
          log_info "  ✓ schema-validates"
        else
          log_warn "  schema validation skipped or inconclusive (run validate-profiles.sh manually)"
        fi
      fi
      # Register in INDEX if present
      local index_file="${__REPO_ROOT}/profiles/INDEX.md"
      if [ -f "${index_file}" ] && ! grep -q "\`${new}\`" "${index_file}"; then
        echo "| [\`${new}\`](${new}.yaml) | Forked from ${base} | draft | (operator-customize) | $(whoami) | (preserved from ${base}) |" >> "${index_file}"
        log_info "  registered in profiles/INDEX.md"
      fi
      echo
      log_info "NEXT:"
      log_info "  1. edit ${new_file} (CPU/GPU/storage/hooks/mixins as your hardware differs)"
      log_info "  2. validate:  sovereign-osctl profiles validate"
      log_info "  3. compare:   sovereign-osctl profiles compare ${base} ${new}"
      log_info "  4. activate:  sovereign-osctl profiles switch ${new}"
      ;;
    compare)
      # R139 (F-12 MED closure): unified diff of two profiles' EFFECTIVE
      # (post-mixin-merge) state. Operator wonders "what's actually
      # different between sain-01 and headless?" — this answers it
      # without opening two YAMLs side by side.
      local a="${1:-}" b="${2:-}"
      if [ -z "${a}" ] || [ -z "${b}" ]; then
        log_error "usage: sovereign-osctl profiles compare <a> <b>"
        return 2
      fi
      for p in "${a}" "${b}"; do
        if [ ! -f "${__REPO_ROOT}/profiles/${p}.yaml" ]; then
          log_error "no such profile: ${p}"
          return 1
        fi
      done
      local tmp_a tmp_b
      tmp_a="$(mktemp)"; tmp_b="$(mktemp)"
      (cd "${__REPO_ROOT}" && python3 -m tools.profile_merger "${a}") > "${tmp_a}" 2>/dev/null
      (cd "${__REPO_ROOT}" && python3 -m tools.profile_merger "${b}") > "${tmp_b}" 2>/dev/null
      echo "--- ${a} (effective)"
      echo "+++ ${b} (effective)"
      diff -u "${tmp_a}" "${tmp_b}" | tail -n +3 || true
      rm -f "${tmp_a}" "${tmp_b}"
      ;;
    validate)
      "${__REPO_ROOT}/scripts/validate-profiles.sh"
      ;;
    active)
      echo "${SOVEREIGN_OS_PROFILE}"
      ;;
    switch)
      local id="${1:?usage: profiles switch <id>}"
      local f="${__REPO_ROOT}/profiles/${id}.yaml"
      require_file "$f"
      mkdir -p /etc/sovereign-os
      echo "${id}" > /etc/sovereign-os/active-profile
      log_info "active profile set to: ${id}"
      log_warn "NOTE: kernel changes require rebuild; package changes via apt; "
      log_warn "      hardware changes may require post-install hook re-run."
      ;;
    *)
      log_error "unknown profiles subcommand: ${sub}"
      cmd_help
      exit 2
      ;;
  esac
}

# ------------------------------ whitelabel -----------------------------------

cmd_whitelabel() {
  local sub="${1:-show}"
  shift || true
  case "${sub}" in
    show)
      local active="default"
      if [ -r /etc/sovereign-os/active-whitelabel ]; then
        active="$(cat /etc/sovereign-os/active-whitelabel)"
      fi
      local f="${__REPO_ROOT}/whitelabel/${active}.yaml"
      if [ -r "$f" ]; then
        echo "active whitelabel: ${active}"
        echo
        cat "$f"
      else
        echo "active whitelabel: ${active} (file not found at ${f})"
      fi
      ;;
    list)
      echo "Declared whitelabels:"
      find "${__REPO_ROOT}/whitelabel" -maxdepth 1 -name '*.yaml' -type f 2>/dev/null | sort | while read -r w; do
        local id name
        id="$(basename "$w" .yaml)"
        name="$(python3 -c "import yaml;d=yaml.safe_load(open('$w'));print(d.get('identity',{}).get('name',''))" 2>/dev/null)"
        printf "  %-20s %s\n" "${id}" "${name}"
      done
      ;;
    apply)
      local id="${1:?usage: whitelabel apply <id>}"
      local wl_file="${__REPO_ROOT}/whitelabel/${id}.yaml"
      require_file "${wl_file}"
      local profile_file="${__REPO_ROOT}/profiles/${SOVEREIGN_OS_PROFILE}.yaml"
      require_file "${profile_file}"

      log_info "applying whitelabel '${id}' to running system"
      log_warn "  Note: build-time-flag strategies (kernel KBUILD_BUILD_USER etc.)"
      log_warn "        require kernel rebuild. Only template-substitution +"
      log_warn "        file-overlay + first-boot-script swap cleanly on running system."

      if ! confirm "Apply whitelabel '${id}' to running system?" default-yes; then
        log_info "aborted"
        return 0
      fi

      # Use render engine in "live-apply" mode (Stage-2+ path; for now,
      # just re-render and let the orchestrator pick up).
      python3 "${__REPO_ROOT}/scripts/whitelabel/render.py" \
        --profile "${profile_file}" \
        --whitelabel "${wl_file}" \
        --out "/tmp/sovereign-os-whitelabel-${id}" \
        --substrate mkosi

      mkdir -p /etc/sovereign-os
      echo "${id}" > /etc/sovereign-os/active-whitelabel

      # Stage-2+ wires apply-to-running-system; for now, log next steps
      log_info "render complete to /tmp/sovereign-os-whitelabel-${id}"
      log_info "  to apply non-rebuild surfaces (os-release, issue, motd):"
      log_info "    sudo cp /tmp/sovereign-os-whitelabel-${id}/mkosi.skeleton/etc/* /etc/"
      log_info "  some surfaces (kernel /proc/version) require rebuild."
      ;;
    diff)
      local target="${1:-}"
      if [ -z "${target}" ]; then
        log_error "usage: whitelabel diff <id>"
        log_error "  shows what would change if <id> were applied vs current active"
        return 2
      fi
      local active="default"
      [ -r /etc/sovereign-os/active-whitelabel ] && \
        active="$(cat /etc/sovereign-os/active-whitelabel)"
      local active_file="${__REPO_ROOT}/whitelabel/${active}.yaml"
      local target_file="${__REPO_ROOT}/whitelabel/${target}.yaml"
      require_file "${active_file}"
      require_file "${target_file}"
      if [ "${active}" = "${target}" ]; then
        log_info "active whitelabel is already '${target}' — no diff"
        return 0
      fi
      log_info "diff: ${active}.yaml → ${target}.yaml"
      echo
      if command -v diff >/dev/null 2>&1; then
        diff -u "${active_file}" "${target_file}" || true
      else
        echo "(diff unavailable; showing both files)"
        echo "=== ${active}.yaml ==="
        cat "${active_file}"
        echo "=== ${target}.yaml ==="
        cat "${target_file}"
      fi
      ;;
    *)
      log_error "unknown whitelabel subcommand: ${sub}"
      cmd_help
      exit 2
      ;;
  esac
}

# ------------------------------ perimeter ------------------------------------

cmd_perimeter() {
  local sub="${1:-status}"
  shift || true
  case "${sub}" in
    status)
      if command -v tetragon >/dev/null 2>&1; then
        if systemctl is-active --quiet tetragon; then
          echo "tetragon: ACTIVE"
        else
          echo "tetragon: INACTIVE"
        fi
        echo
        echo "Loaded policies:"
        find /etc/tetragon/tracing-policies -name '*.yaml' -type f 2>/dev/null | while read -r p; do
          echo "  $(basename "$p")"
        done
      else
        echo "tetragon: NOT INSTALLED"
      fi
      ;;
    verify)
      "${__REPO_ROOT}/scripts/hooks/recurrent/tetragon-policy-verify.sh"
      ;;
    reload)
      require_root
      log_info "restarting tetragon to reload policies"
      systemctl restart tetragon
      systemctl is-active --quiet tetragon && log_info "tetragon active" || log_error "tetragon failed to start"
      ;;
    *)
      log_error "unknown perimeter subcommand: ${sub}"
      cmd_help
      exit 2
      ;;
  esac
}

# ------------------------------ models ---------------------------------------

cmd_models() {
  local sub="${1:-list}"
  shift || true
  : "${SOVEREIGN_OS_MODELS_DIR:=/mnt/vault/models}"
  case "${sub}" in
    list)
      if [ ! -d "${SOVEREIGN_OS_MODELS_DIR}" ]; then
        echo "models dir not present: ${SOVEREIGN_OS_MODELS_DIR}"
        return 0
      fi
      echo "Resident models in ${SOVEREIGN_OS_MODELS_DIR}:"
      find "${SOVEREIGN_OS_MODELS_DIR}" -maxdepth 2 -type d -mindepth 1 | sort | while read -r d; do
        local size
        size="$(du -sh "$d" 2>/dev/null | cut -f1)"
        printf "  %-50s %s\n" "${d##*/}" "${size}"
      done
      ;;
    pull)
      local hf_id="${1:?usage: models pull <hf-id> e.g. microsoft/bitnet-b1.58-2B-4T}"
      log_info "pulling ${hf_id} → ${SOVEREIGN_OS_MODELS_DIR}/$(basename "${hf_id}")"
      if ! command -v huggingface-cli >/dev/null 2>&1; then
        log_error "huggingface-cli not installed; pip install huggingface_hub"
        return 1
      fi
      mkdir -p "${SOVEREIGN_OS_MODELS_DIR}"
      huggingface-cli download "${hf_id}" --local-dir "${SOVEREIGN_OS_MODELS_DIR}/$(basename "${hf_id}")"
      log_info "model pulled"
      ;;
    verify)
      "${__REPO_ROOT}/scripts/hooks/recurrent/model-catalog-sync.sh"
      ;;
    size)
      if [ ! -d "${SOVEREIGN_OS_MODELS_DIR}" ]; then
        echo "models dir not present: ${SOVEREIGN_OS_MODELS_DIR}"
        return 0
      fi
      echo "Disk usage at ${SOVEREIGN_OS_MODELS_DIR}:"
      du -sh "${SOVEREIGN_OS_MODELS_DIR}" 2>/dev/null
      echo
      echo "Per-model breakdown:"
      find "${SOVEREIGN_OS_MODELS_DIR}" -maxdepth 2 -type d -mindepth 1 2>/dev/null \
        | xargs -I{} du -sh {} 2>/dev/null \
        | sort -h
      ;;
    remove)
      local target="${1:-}"
      if [ -z "${target}" ]; then
        log_error "usage: models remove <model-name>  (subdir name under SOVEREIGN_OS_MODELS_DIR)"
        return 2
      fi
      local target_path="${SOVEREIGN_OS_MODELS_DIR}/${target}"
      if [ ! -d "${target_path}" ]; then
        log_error "model not resident: ${target_path}"
        return 1
      fi
      local sz; sz="$(du -sh "${target_path}" 2>/dev/null | cut -f1)"
      log_warn "about to DELETE: ${target_path} (${sz})"
      if [ "${SOVEREIGN_OS_ASSUME_YES:-}" != "1" ]; then
        if ! confirm "Confirm permanent delete of ${target} (${sz})?" default-no; then
          log_info "remove cancelled"
          return 0
        fi
      fi
      rm -rf "${target_path}"
      log_info "removed: ${target}"
      ;;
    *)
      log_error "unknown models subcommand: ${sub}"
      cmd_help
      exit 2
      ;;
  esac
}

# ------------------------------ audit ----------------------------------------

cmd_audit() {
  local sub="${1:-friction}"
  shift || true
  case "${sub}" in
    friction)
      "${__REPO_ROOT}/scripts/hooks/post-install/friction-audit-runtime.sh"
      ;;
    perimeter)
      "${__REPO_ROOT}/scripts/hooks/recurrent/tetragon-policy-verify.sh"
      ;;
    storage)
      if command -v zpool >/dev/null 2>&1; then
        zpool status -v
        zpool list
        zfs list
      else
        echo "zfs not installed"
      fi
      ;;
    provenance)
      # SDD-019: verify build-provenance.json against sha256sums.txt.
      # Accepts a manifest path or auto-discovers from common locations.
      # --deep: also recompute SHA256 of files on disk and compare vs manifest
      #         (closes the in-toto verifier loop — manifest ↔ sums ↔ disk).
      local deep_mode=0
      while [ $# -gt 0 ]; do
        case "$1" in
          --deep) deep_mode=1; shift ;;
          --) shift; break ;;
          -*) log_error "unknown flag: $1"; return 2 ;;
          *) break ;;
        esac
      done
      local manifest="${1:-}"
      if [ -z "${manifest}" ]; then
        for candidate in \
          "/var/lib/sovereign-os/build-provenance.json" \
          "${SOVEREIGN_OS_IMAGE_DIR:-/no-such-path}/build-provenance.json" \
          "${HOME}/.sovereign-os/build-state/build-provenance.json"; do
          if [ -f "${candidate}" ]; then
            manifest="${candidate}"
            break
          fi
        done
      fi
      if [ -z "${manifest}" ] || [ ! -f "${manifest}" ]; then
        log_error "no build-provenance.json found"
        log_error "  pass path: sovereign-osctl audit provenance [--deep] <path>"
        log_error "  or set SOVEREIGN_OS_IMAGE_DIR to the directory containing it"
        return 1
      fi
      local sums="$(dirname "${manifest}")/sha256sums.txt"
      log_info "manifest: ${manifest}"
      [ -f "${sums}" ] && log_info "sha256sums: ${sums}" || log_warn "sha256sums.txt absent — content-verify skipped"
      [ "${deep_mode}" -eq 1 ] && log_info "deep mode: will recompute SHA256 of files on disk"
      python3 - "${manifest}" "${sums:-/dev/null}" "${deep_mode}" <<'PY'
import json, sys, hashlib, pathlib
manifest_path = pathlib.Path(sys.argv[1])
sums_path = pathlib.Path(sys.argv[2]) if sys.argv[2] != '/dev/null' else None
deep_mode = (sys.argv[3] == '1') if len(sys.argv) > 3 else False
data = json.loads(manifest_path.read_text())
artifact_dir = manifest_path.parent

# Header
print(f"  _type:         {data.get('_type', '?')}")
print(f"  predicateType: {data.get('predicateType', '?')}")
subjects = data.get('subject') or []
print(f"  subjects:      {len(subjects)} artifact(s)")

# Pretty-print externalParameters
ext = (data.get('predicate', {})
            .get('buildDefinition', {})
            .get('externalParameters', {}))
if ext:
    print("  build inputs:")
    for k, v in sorted(ext.items()):
        v_disp = v if v else '<unset>'
        print(f"    {k:24s} {v_disp}")

# Cross-check against sha256sums.txt if present
if sums_path and sums_path.exists():
    declared = {s['name']: s['digest']['sha256'] for s in subjects}
    sums = {}
    for line in sums_path.read_text().splitlines():
        line = line.strip()
        if not line:
            continue
        digest, _, name = line.partition('  ')
        if name.startswith('./'):
            name = name[2:]
        sums[name] = digest
    mismatches = []
    missing_in_sums = []
    for name, sha in declared.items():
        if name not in sums:
            missing_in_sums.append(name)
        elif sums[name] != sha:
            mismatches.append((name, sums[name], sha))
    if mismatches:
        print(f"  ✗ {len(mismatches)} digest mismatch(es):")
        for name, expected, actual in mismatches[:5]:
            print(f"    {name}: sha256sums={expected[:12]}…  manifest={actual[:12]}…")
        sys.exit(2)
    elif missing_in_sums:
        print(f"  ! {len(missing_in_sums)} subject(s) not in sha256sums.txt (subset audit ok)")
    else:
        print(f"  ✓ all {len(declared)} subject digests match sha256sums.txt")

# Deep mode: recompute SHA256 of each subject's file on disk
if deep_mode:
    print()
    print("  deep verification — recomputing SHA256 of files on disk:")
    declared = {s['name']: s['digest']['sha256'] for s in subjects}
    deep_mismatches = []
    deep_missing = []
    deep_verified = 0
    for name, expected_sha in declared.items():
        path = artifact_dir / name
        if not path.is_file():
            deep_missing.append(name)
            continue
        h = hashlib.sha256()
        with path.open('rb') as fh:
            for chunk in iter(lambda: fh.read(1024 * 1024), b''):
                h.update(chunk)
        actual = h.hexdigest()
        if actual != expected_sha:
            deep_mismatches.append((name, expected_sha, actual))
        else:
            deep_verified += 1
    if deep_missing:
        print(f"  ! {len(deep_missing)} file(s) listed in manifest but missing on disk:")
        for name in deep_missing[:5]:
            print(f"      {name}")
    if deep_mismatches:
        print(f"  ✗ {len(deep_mismatches)} file(s) on disk differ from manifest digest:")
        for name, expected, actual in deep_mismatches[:5]:
            print(f"      {name}")
            print(f"        manifest: {expected[:16]}…")
            print(f"        on disk:  {actual[:16]}…")
        sys.exit(3)
    if deep_verified == len(declared):
        print(f"  ✓ all {deep_verified} files on disk match manifest digest")
    elif deep_verified > 0:
        print(f"  ✓ {deep_verified}/{len(declared)} files on disk match manifest digest")
PY
      ;;
    drift)
      # Round 111: compare deployed hardening drop-ins vs source-of-truth
      # in config/server/ and config/workstation/. Operators get drift
      # detection WITHOUT re-running the apply hook (which would overwrite).
      local json_mode=0
      [ "${1:-}" = "--json" ] && { json_mode=1; shift; }

      : "${SOVEREIGN_OS_HARDENING_DEST_PREFIX:=}"

      # Each entry: source-relative-path:absolute-destination
      # SDD-024 inventory of drop-ins for both role-server and role-workstation
      local -a drop_ins=(
        "server/auditd.rules:${SOVEREIGN_OS_HARDENING_DEST_PREFIX}/etc/audit/rules.d/sovereign-os.rules"
        "server/fail2ban-jail.local:${SOVEREIGN_OS_HARDENING_DEST_PREFIX}/etc/fail2ban/jail.d/sovereign-os.local"
        "server/unattended-upgrades.conf:${SOVEREIGN_OS_HARDENING_DEST_PREFIX}/etc/apt/apt.conf.d/52sovereign-os-unattended.conf"
        "server/sshd.conf:${SOVEREIGN_OS_HARDENING_DEST_PREFIX}/etc/ssh/sshd_config.d/50sovereign-os.conf"
        "server/pwquality.conf:${SOVEREIGN_OS_HARDENING_DEST_PREFIX}/etc/security/pwquality.conf.d/50sovereign-os.conf"
        "workstation/sshd.conf:${SOVEREIGN_OS_HARDENING_DEST_PREFIX}/etc/ssh/sshd_config.d/50sovereign-os.conf"
      )

      # JSON accumulator (one entry per drop-in)
      local -a json_entries=()
      local drift_count=0 unchanged=0 missing=0 not_applicable=0

      for entry in "${drop_ins[@]}"; do
        local rel="${entry%:*}"
        local dst="${entry#*:}"
        local src="${__REPO_ROOT}/config/${rel}"
        local kind="${rel%%/*}"  # server or workstation
        local fname="${rel#*/}"

        # Note: server/sshd.conf and workstation/sshd.conf share the same
        # destination. Resolution: which one applies depends on the
        # profile. If both exist on disk, the LAST-applied wins (apply
        # hooks run in profile-determined order). We report which source
        # the deployed file matches (if any).

        if [ ! -r "${src}" ]; then
          # Source absent (shouldn't happen in a release)
          if [ "${json_mode}" -eq 1 ]; then
            json_entries+=("{\"kind\":\"${kind}\",\"file\":\"${fname}\",\"destination\":\"${dst}\",\"state\":\"source-missing\"}")
          else
            log_warn "  source MISSING: ${src}"
          fi
          continue
        fi

        if [ ! -e "${dst}" ]; then
          # Deployed file absent
          if [ "${json_mode}" -eq 1 ]; then
            json_entries+=("{\"kind\":\"${kind}\",\"file\":\"${fname}\",\"destination\":\"${dst}\",\"state\":\"not-deployed\"}")
          else
            log_info "  not-deployed:  [${kind}] ${fname} → ${dst}"
          fi
          not_applicable=$((not_applicable + 1))
          continue
        fi

        if cmp -s "${src}" "${dst}"; then
          if [ "${json_mode}" -eq 1 ]; then
            json_entries+=("{\"kind\":\"${kind}\",\"file\":\"${fname}\",\"destination\":\"${dst}\",\"state\":\"unchanged\"}")
          else
            log_info "  unchanged:     [${kind}] ${fname}"
          fi
          unchanged=$((unchanged + 1))
        else
          if [ "${json_mode}" -eq 1 ]; then
            json_entries+=("{\"kind\":\"${kind}\",\"file\":\"${fname}\",\"destination\":\"${dst}\",\"state\":\"drifted\"}")
          else
            log_warn "  DRIFTED:       [${kind}] ${fname} → ${dst}"
          fi
          drift_count=$((drift_count + 1))
        fi
      done

      if [ "${json_mode}" -eq 1 ]; then
        # Emit a single JSON object with summary + entries array
        local entries_csv
        entries_csv="$(IFS=,; echo "${json_entries[*]}")"
        printf '{"summary":{"drifted":%d,"unchanged":%d,"not_deployed":%d},"entries":[%s]}\n' \
          "${drift_count}" "${unchanged}" "${not_applicable}" "${entries_csv}"
      else
        echo
        log_info "drift summary: drifted=${drift_count} unchanged=${unchanged} not-deployed=${not_applicable}"
        if [ "${drift_count}" -gt 0 ]; then
          log_warn "  some drop-ins have drifted from source — re-apply with:"
          log_warn "    sudo sovereign-osctl maintenance security-check  # or"
          log_warn "    sudo /opt/sovereign-os/scripts/hooks/post-install/apply-server-hardening.sh"
          log_warn "    sudo /opt/sovereign-os/scripts/hooks/post-install/apply-workstation-hardening.sh"
        fi
      fi

      # exit (not return) to bypass ERR trap on intentional non-zero
      [ "${drift_count}" -eq 0 ] && exit 0 || exit 1
      ;;
    customization)
      # R142 (F-07 MED closure): "did my customization actually land?"
      # Cross-cuts profile + whitelabel + hostname + active-profile state
      # vs declared values. Operator who customized a profile then
      # deployed wants ONE check to verify the runtime state matches.
      local json_mode=0
      [ "${1:-}" = "--json" ] && { json_mode=1; shift; }

      local profile="${SOVEREIGN_OS_PROFILE:-sain-01}"
      local profile_file="${__REPO_ROOT}/profiles/${profile}.yaml"
      local checks_pass=0 checks_warn=0 checks_fail=0
      local -a results=()

      add_check() {  # add_check status name expected actual
        local status="$1" name="$2" expected="$3" actual="$4"
        case "${status}" in
          pass) checks_pass=$((checks_pass + 1)) ;;
          warn) checks_warn=$((checks_warn + 1)) ;;
          fail) checks_fail=$((checks_fail + 1)) ;;
        esac
        results+=("{\"status\":\"${status}\",\"name\":\"${name}\",\"expected\":\"${expected}\",\"actual\":\"${actual}\"}")
      }

      if [ ! -f "${profile_file}" ]; then
        if [ "${json_mode}" -eq 1 ]; then
          echo "{\"summary\":{\"pass\":0,\"warn\":0,\"fail\":1},\"checks\":[{\"status\":\"fail\",\"name\":\"profile-file\",\"expected\":\"${profile_file}\",\"actual\":\"missing\"}]}"
        else
          log_error "active profile YAML missing: ${profile_file}"
        fi
        exit 1
      fi

      # Check 1: /etc/sovereign-os/active-profile matches SOVEREIGN_OS_PROFILE
      local active_file_value="<unset>"
      [ -r /etc/sovereign-os/active-profile ] && active_file_value="$(cat /etc/sovereign-os/active-profile)"
      if [ "${active_file_value}" = "${profile}" ]; then
        add_check pass "active-profile" "${profile}" "${profile}"
      elif [ "${active_file_value}" = "<unset>" ]; then
        add_check warn "active-profile" "${profile}" "(file absent)"
      else
        add_check fail "active-profile" "${profile}" "${active_file_value}"
      fi

      # Check 2: /etc/os-release ID matches whitelabel.branding.os_id (if rendered)
      local declared_os_id; declared_os_id="$(PROFILE_FILE="${profile_file}" REPO_ROOT="${__REPO_ROOT}" python3 -c "
import os, yaml, pathlib
with open(os.environ['PROFILE_FILE']) as f:
    pdata = yaml.safe_load(f) or {}
wl_name = (pdata.get('whitelabel') or {}).get('profile', 'default')
wl_file = pathlib.Path(os.environ['REPO_ROOT']) / 'whitelabel' / f'{wl_name}.yaml'
if not wl_file.exists():
    print('?')
else:
    with open(wl_file) as f:
        wdata = yaml.safe_load(f) or {}
    print((wdata.get('branding') or {}).get('os_id', '?'))
")"
      local actual_os_id="<unset>"
      [ -r /etc/os-release ] && actual_os_id="$(grep '^ID=' /etc/os-release | head -1 | cut -d= -f2 | tr -d '\"')"
      if [ "${declared_os_id}" = "${actual_os_id}" ]; then
        add_check pass "os-release-id" "${declared_os_id}" "${actual_os_id}"
      elif [ "${actual_os_id}" = "<unset>" ]; then
        add_check warn "os-release-id" "${declared_os_id}" "(file absent)"
      else
        add_check fail "os-release-id" "${declared_os_id}" "${actual_os_id}"
      fi

      # Check 3: hardening drift cross-reference
      # If apply-server-hardening or apply-workstation-hardening is registered
      # in the profile, check the dest files match the source. Reuses R111's
      # logic at a high level: just check if the file is present + size > 0.
      local has_hardening
      has_hardening="$(PROFILE_FILE="${profile_file}" python3 -c "
import os, yaml
with open(os.environ['PROFILE_FILE']) as f:
    data = yaml.safe_load(f) or {}
hooks = ((data.get('hooks') or {}).get('post_install_first_boot') or [])
ids = {h.get('id') for h in hooks}
if 'apply-server-hardening' in ids: print('server')
elif 'apply-workstation-hardening' in ids: print('workstation')
else: print('none')
")"
      case "${has_hardening}" in
        server|workstation)
          # Check if sshd hardening landed (canonical surrogate)
          if [ -r /etc/ssh/sshd_config.d/50sovereign-os.conf ]; then
            add_check pass "hardening-${has_hardening}" "deployed" "deployed"
          else
            add_check warn "hardening-${has_hardening}" "deployed" "(no /etc/ssh/sshd_config.d/50sovereign-os.conf)"
          fi
          ;;
        none)
          add_check pass "hardening" "n/a" "n/a (profile has no hardening hook)"
          ;;
      esac

      # Check 4: number of installed packages vs profile.packages.base + role
      # (informational — package set is mutable in service of operator workflow)
      local declared_pkgs
      declared_pkgs="$(PROFILE_FILE="${profile_file}" python3 -c "
import os, yaml
with open(os.environ['PROFILE_FILE']) as f:
    data = yaml.safe_load(f) or {}
pkgs = data.get('packages', {})
all_pkgs = set(pkgs.get('base') or [])
for role_pkgs in (pkgs.get('role') or {}).values():
    all_pkgs.update(role_pkgs or [])
print(len(all_pkgs))
")"
      if command -v dpkg >/dev/null 2>&1; then
        local installed_count
        installed_count="$(dpkg -l 2>/dev/null | grep -c '^ii' || echo 0)"
        if [ "${installed_count}" -ge "${declared_pkgs}" ]; then
          add_check pass "package-count" "≥${declared_pkgs} (declared)" "${installed_count} (installed)"
        else
          add_check warn "package-count" "≥${declared_pkgs} (declared)" "${installed_count} (installed; some declared not yet installed)"
        fi
      else
        add_check warn "package-count" "${declared_pkgs}" "(dpkg unavailable; build host?)"
      fi

      # Check 5: hostname surface
      local current_host; current_host="$(hostname 2>/dev/null || echo unknown)"
      add_check pass "hostname" "(operator-set)" "${current_host}"

      # Emit results
      if [ "${json_mode}" -eq 1 ]; then
        local checks_csv; checks_csv="$(IFS=,; echo "${results[*]}")"
        printf '{"summary":{"pass":%d,"warn":%d,"fail":%d},"profile":"%s","checks":[%s]}\n' \
          "${checks_pass}" "${checks_warn}" "${checks_fail}" "${profile}" "${checks_csv}"
      else
        echo
        echo "  customization audit (profile=${profile})"
        echo "  ----------------------------------------"
        for r in "${results[@]}"; do
          local s n exp act
          s="$(python3 -c "import json,sys; d=json.loads(sys.argv[1]); print(d['status'])" "${r}")"
          n="$(python3 -c "import json,sys; d=json.loads(sys.argv[1]); print(d['name'])" "${r}")"
          exp="$(python3 -c "import json,sys; d=json.loads(sys.argv[1]); print(d['expected'])" "${r}")"
          act="$(python3 -c "import json,sys; d=json.loads(sys.argv[1]); print(d['actual'])" "${r}")"
          local marker
          case "${s}" in pass) marker="✓" ;; warn) marker="!" ;; fail) marker="✗" ;; *) marker="?" ;; esac
          printf "  %s %-22s expected=%-30s actual=%s\n" "${marker}" "${n}" "${exp}" "${act}"
        done
        echo
        echo "  summary: ${checks_pass} pass · ${checks_warn} warn · ${checks_fail} fail"
      fi
      [ "${checks_fail}" -eq 0 ] && exit 0 || exit 1
      ;;
    *)
      log_error "unknown audit subcommand: ${sub}"
      cmd_help
      exit 2
      ;;
  esac
}

# ------------------------------ maintenance ----------------------------------

cmd_maintenance() {
  local sub="${1:-list}"
  shift || true
  case "${sub}" in
    list)
      cat <<EOF
Maintenance subverbs (each runs the matching recurrent hook on demand):

  list                   This list.
  scrub                  Trigger ZFS scrub of the tank pool now.
  arc-status             Show ZFS ARC stats (size + c + c_min + c_max).
  log-rotate             Manually rotate ~/.sovereign-os/log/*.jsonl now.
  snapshot               Manually take a tank/context ZFS snapshot now.
  security-check         Manually scan for pending security updates now.
  models-sync            Manually verify the resident model catalog now.
  perimeter-check        Manually verify Tetragon perimeter policy now.
  alerts-check           Derive alerts + emit meta-counters now (hourly timer).

All of these run via the matching systemd timer (daily/weekly cadence);
this surface gives operators on-demand control when they need it.

Most subverbs require root; honor SOVEREIGN_OS_DRY_RUN=1.
EOF
      ;;
    scrub)
      "${__REPO_ROOT}/scripts/hooks/recurrent/zfs-scrub.sh"
      ;;
    arc-status)
      if [ -r /proc/spl/kstat/zfs/arcstats ]; then
        grep -E "^(size|c$|c_min|c_max)" /proc/spl/kstat/zfs/arcstats
      else
        echo "ARC stats not available (ZFS not loaded)"
      fi
      ;;
    log-rotate)
      "${__REPO_ROOT}/scripts/hooks/recurrent/log-rotate.sh"
      ;;
    snapshot)
      "${__REPO_ROOT}/scripts/hooks/recurrent/backup-snapshot.sh"
      ;;
    security-check)
      "${__REPO_ROOT}/scripts/hooks/recurrent/security-update-check.sh"
      ;;
    models-sync)
      "${__REPO_ROOT}/scripts/hooks/recurrent/model-catalog-sync.sh"
      ;;
    perimeter-check)
      "${__REPO_ROOT}/scripts/hooks/recurrent/tetragon-policy-verify.sh"
      ;;
    alerts-check)
      "${__REPO_ROOT}/scripts/hooks/recurrent/alerts-check.sh"
      ;;
    *)
      log_error "unknown maintenance subcommand: ${sub}"
      log_error "  available: list / scrub / arc-status / log-rotate / snapshot / security-check / models-sync / perimeter-check / alerts-check"
      exit 2
      ;;
  esac
}

# ------------------------------ metrics --------------------------------------
#
# Surfaces the SDD-016 Layer B Prometheus textfile collector output to
# operators who don't run Grafana. The .prom files at
# /var/lib/node_exporter/textfile_collector/sovereign-os-*.prom are
# authoritative; Grafana dashboards are convenience. This verb makes
# the authoritative surface readable from the shell.

cmd_metrics() {
  local sub="${1:-list}"
  shift || true

  : "${SOVEREIGN_OS_METRICS_DIR:=/var/lib/node_exporter/textfile_collector}"

  case "${sub}" in
    list)
      if [ ! -d "${SOVEREIGN_OS_METRICS_DIR}" ]; then
        echo "metrics dir absent: ${SOVEREIGN_OS_METRICS_DIR}"
        echo "  (node_exporter textfile collector may not be installed,"
        echo "   or no hook has emitted a metric yet)"
        return 0
      fi
      local files
      mapfile -t files < <(find "${SOVEREIGN_OS_METRICS_DIR}" -maxdepth 1 -name 'sovereign-os-*.prom' -type f 2>/dev/null | sort)
      if [ "${#files[@]}" -eq 0 ]; then
        echo "no sovereign-os-*.prom files in ${SOVEREIGN_OS_METRICS_DIR}"
        return 0
      fi
      printf "%-50s  %-20s  %s\n" "FILE" "LAST UPDATE" "METRICS"
      for f in "${files[@]}"; do
        local bn mtime n
        bn="$(basename "${f}")"
        mtime="$(date -r "${f}" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo unknown)"
        n="$(grep -vc '^#\|^$' "${f}" 2>/dev/null || echo 0)"
        printf "%-50s  %-20s  %s\n" "${bn}" "${mtime}" "${n}"
      done
      ;;
    show)
      local name="${1:-}"
      if [ -z "${name}" ]; then
        log_error "usage: sovereign-osctl metrics show <basename>"
        log_error "  example: sovereign-osctl metrics show log-rotation"
        log_error "  (.prom suffix optional; sovereign-os- prefix optional)"
        return 2
      fi
      # Resolve: try exact, then with sovereign-os- prefix, then with .prom suffix
      local file=""
      for candidate in \
        "${SOVEREIGN_OS_METRICS_DIR}/${name}" \
        "${SOVEREIGN_OS_METRICS_DIR}/${name}.prom" \
        "${SOVEREIGN_OS_METRICS_DIR}/sovereign-os-${name}" \
        "${SOVEREIGN_OS_METRICS_DIR}/sovereign-os-${name}.prom"; do
        if [ -f "${candidate}" ]; then
          file="${candidate}"
          break
        fi
      done
      if [ -z "${file}" ]; then
        log_error "no .prom file matches '${name}' in ${SOVEREIGN_OS_METRICS_DIR}"
        log_error "  run 'sovereign-osctl metrics list' to see what's available"
        return 1
      fi
      echo "# file:  ${file}"
      echo "# mtime: $(date -r "${file}" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo unknown)"
      echo
      cat "${file}"
      ;;
    tail)
      local n="${1:-5}"
      if ! [[ "${n}" =~ ^[0-9]+$ ]]; then
        log_error "tail count must be a non-negative integer (got: ${n})"
        return 2
      fi
      if [ ! -d "${SOVEREIGN_OS_METRICS_DIR}" ]; then
        echo "metrics dir absent: ${SOVEREIGN_OS_METRICS_DIR}"
        return 0
      fi
      # Newest-first ordering by mtime; cap at N
      mapfile -t recent < <(find "${SOVEREIGN_OS_METRICS_DIR}" -maxdepth 1 -name 'sovereign-os-*.prom' -type f -printf '%T@ %p\n' 2>/dev/null | sort -nr | head -n "${n}" | awk '{print $2}')
      if [ "${#recent[@]}" -eq 0 ]; then
        echo "no sovereign-os-*.prom files in ${SOVEREIGN_OS_METRICS_DIR}"
        return 0
      fi
      for f in "${recent[@]}"; do
        echo "===== $(basename "${f}")  ($(date -r "${f}" '+%Y-%m-%d %H:%M:%S')) ====="
        grep -v '^#' "${f}" | grep -v '^$' || true
        echo
      done
      ;;
    health)
      local issues=0
      if [ ! -d "${SOVEREIGN_OS_METRICS_DIR}" ]; then
        log_warn "metrics dir absent: ${SOVEREIGN_OS_METRICS_DIR}"
        log_warn "  install node_exporter and create the dir, or set"
        log_warn "  SOVEREIGN_OS_METRICS_DIR to an alternate path"
        return 1
      fi
      log_info "metrics dir: ${SOVEREIGN_OS_METRICS_DIR}"
      mapfile -t files < <(find "${SOVEREIGN_OS_METRICS_DIR}" -maxdepth 1 -name 'sovereign-os-*.prom' -type f 2>/dev/null | sort)
      if [ "${#files[@]}" -eq 0 ]; then
        log_warn "  no sovereign-os-*.prom files present (no hook has emitted yet)"
        return 0
      fi
      log_info "  ${#files[@]} sovereign-os-*.prom files"
      local now stale_threshold
      now="$(date +%s)"
      stale_threshold="${SOVEREIGN_OS_METRICS_STALE_DAYS:-7}"
      for f in "${files[@]}"; do
        local mtime age_days
        mtime="$(stat -c '%Y' "${f}" 2>/dev/null || echo "${now}")"
        age_days=$(( (now - mtime) / 86400 ))
        if [ "${age_days}" -gt "${stale_threshold}" ]; then
          log_warn "  STALE — $(basename "${f}") (${age_days}d old, threshold ${stale_threshold}d)"
          issues=$((issues + 1))
        fi
        # format sanity: each non-comment, non-empty line should be 'name value' or 'name{labels} value'
        local bad_lines
        bad_lines="$(grep -v '^#' "${f}" | grep -v '^$' | grep -cvE '^[a-zA-Z_:][a-zA-Z0-9_:]*(\{[^}]*\})?\s+[-0-9.eE+]+(\s+[0-9]+)?\s*$' || true)"
        if [ "${bad_lines:-0}" -gt 0 ]; then
          log_error "  MALFORMED — $(basename "${f}") has ${bad_lines} non-conforming line(s)"
          issues=$((issues + 1))
        fi
      done
      if [ "${issues}" -eq 0 ]; then
        log_info "  all files fresh + well-formed"
        return 0
      else
        log_error "  ${issues} issue(s) found"
        return 1
      fi
      ;;
    *)
      log_error "unknown metrics subcommand: ${sub}"
      log_error "  available: list / show <name> / tail [N] / health"
      return 2
      ;;
  esac
}

# ------------------------------ journal --------------------------------------
#
# Surfaces SDD-016 Layer A — the structured JSONL logs that every
# scripts/build/* and scripts/hooks/* emits via the common log_info /
# log_warn / log_error helpers. Operators can grep/jq these directly,
# but a first-class verb makes the surface usable without third-party
# tooling. Symmetrical with `metrics` (Layer B) + `alerts` (rules over
# Layer B).
#
# Log dir resolution:
#   1. SOVEREIGN_OS_LOG_DIR env override
#   2. /var/log/sovereign-os/ (installed system)
#   3. ~/.sovereign-os/log/   (per-operator build host)
#   4. fall back to the first that exists

cmd_journal() {
  local sub="${1:-list}"
  shift || true

  local log_dir=""
  if [ -n "${SOVEREIGN_OS_LOG_DIR:-}" ] && [ -d "${SOVEREIGN_OS_LOG_DIR}" ]; then
    log_dir="${SOVEREIGN_OS_LOG_DIR}"
  elif [ -d /var/log/sovereign-os ]; then
    log_dir="/var/log/sovereign-os"
  elif [ -d "${HOME}/.sovereign-os/log" ]; then
    log_dir="${HOME}/.sovereign-os/log"
  fi

  if [ -z "${log_dir}" ]; then
    echo "no Layer A log dir found; checked:"
    echo "  \$SOVEREIGN_OS_LOG_DIR (unset)"
    echo "  /var/log/sovereign-os/"
    echo "  ${HOME}/.sovereign-os/log/"
    return 0
  fi

  case "${sub}" in
    list)
      mapfile -t files < <(find "${log_dir}" -maxdepth 1 -name '*.jsonl' -type f 2>/dev/null | sort)
      if [ "${#files[@]}" -eq 0 ]; then
        echo "no .jsonl files in ${log_dir}"
        return 0
      fi
      echo "log dir: ${log_dir}"
      echo
      printf "%-44s  %-8s  %s\n" "FILE" "EVENTS" "FIRST → LAST"
      for f in "${files[@]}"; do
        local bn n first_ts last_ts
        bn="$(basename "${f}")"
        n="$(wc -l < "${f}" | tr -d ' ')"
        if [ "${n}" -gt 0 ]; then
          first_ts="$(python3 -c "import json,sys; print(json.loads(sys.stdin.readline()).get('ts','?'))" < "${f}" 2>/dev/null || echo '?')"
          last_ts="$(tail -1 "${f}" | python3 -c "import json,sys; print(json.loads(sys.stdin.read()).get('ts','?'))" 2>/dev/null || echo '?')"
        else
          first_ts="(empty)"; last_ts=""
        fi
        printf "%-44s  %-8s  %s → %s\n" "${bn}" "${n}" "${first_ts}" "${last_ts}"
      done
      ;;
    show)
      local name="${1:-}"
      if [ -z "${name}" ]; then
        log_error "usage: sovereign-osctl journal show <file>"
        return 2
      fi
      local file=""
      for cand in "${log_dir}/${name}" "${log_dir}/${name}.jsonl" "${name}"; do
        if [ -f "${cand}" ]; then file="${cand}"; break; fi
      done
      if [ -z "${file}" ]; then
        log_error "no log file matches '${name}' (in ${log_dir} or as absolute path)"
        return 1
      fi
      echo "# file: ${file}"
      echo
      python3 - "${file}" <<'PY'
import sys, json
fn = sys.argv[1]
print(f"{'TS':<26} {'LEVEL':<6} {'STEP':<22} MSG")
with open(fn) as fh:
    for line in fh:
        line = line.strip()
        if not line: continue
        try:
            e = json.loads(line)
        except json.JSONDecodeError:
            print(f"{'?':<26} {'?':<6} {'?':<22} (malformed: {line[:120]})")
            continue
        ts = e.get("ts", "")
        level = (e.get("level") or "?").upper()
        step = e.get("step", "?")
        msg = e.get("msg", "")
        print(f"{ts:<26} {level:<6} {step:<22} {msg}")
PY
      ;;
    tail)
      local n="${1:-3}"
      if ! [[ "${n}" =~ ^[0-9]+$ ]]; then
        log_error "tail count must be a non-negative integer (got: ${n})"
        return 2
      fi
      mapfile -t recent < <(find "${log_dir}" -maxdepth 1 -name '*.jsonl' -type f -printf '%T@ %p\n' 2>/dev/null | sort -nr | head -n "${n}" | awk '{print $2}')
      if [ "${#recent[@]}" -eq 0 ]; then
        echo "no .jsonl files in ${log_dir}"
        return 0
      fi
      for f in "${recent[@]}"; do
        echo "===== $(basename "${f}") ====="
        python3 - "${f}" <<'PY'
import sys, json
fn = sys.argv[1]
with open(fn) as fh:
    for line in fh:
        line = line.strip()
        if not line: continue
        try:
            e = json.loads(line)
        except json.JSONDecodeError:
            print(f"(malformed: {line[:120]})")
            continue
        ts = e.get("ts", "")
        level = (e.get("level") or "?").upper()
        step = e.get("step", "?")
        msg = e.get("msg", "")
        print(f"{ts}  {level:<5}  [{step}]  {msg}")
PY
        echo
      done
      ;;
    errors)
      mapfile -t files < <(find "${log_dir}" -maxdepth 1 -name '*.jsonl' -type f 2>/dev/null | sort)
      if [ "${#files[@]}" -eq 0 ]; then
        echo "no .jsonl files in ${log_dir}"
        return 0
      fi
      local found=0
      for f in "${files[@]}"; do
        local block
        block="$(python3 - "${f}" <<'PY'
import sys, json
fn = sys.argv[1]
out = []
with open(fn) as fh:
    for line in fh:
        line = line.strip()
        if not line: continue
        try:
            e = json.loads(line)
        except json.JSONDecodeError:
            continue
        level = (e.get("level") or "").lower()
        if level not in ("warn", "error"):
            continue
        ts = e.get("ts", "")
        step = e.get("step", "?")
        msg = e.get("msg", "")
        out.append(f"  {ts}  {level.upper():<5}  [{step}]  {msg}")
print("\n".join(out))
PY
)"
        if [ -n "${block}" ]; then
          echo "===== $(basename "${f}") ====="
          echo "${block}"
          echo
          found=1
        fi
      done
      if [ "${found}" -eq 0 ]; then
        echo "no warn/error entries in any .jsonl file in ${log_dir}"
      fi
      ;;
    *)
      log_error "unknown journal subcommand: ${sub}"
      log_error "  available: list / show <file> / tail [N] / errors"
      return 2
      ;;
  esac
}

# ------------------------------ history --------------------------------------
#
# Per-run summary view derived from the Layer A JSONL files. Each
# build-<ts>.jsonl is one run; this verb groups events into a
# tabular history surface that complements 'journal' (per-file events)
# and 'metrics' (point-in-time aggregates).
#
# Run-id format: timestamp suffix of the JSONL filename
#   build-20260516T010000Z.jsonl → 20260516T010000Z
#
# Derived per run:
#   - profile  (from "loaded profile: <name>" event)
#   - steps    (count of "STEP_ID: PASS" + "STEP_ID: FAIL" markers)
#   - result   (success if no errors; fail if any error events)
#   - duration (last ts - first ts, ISO 8601)

cmd_history() {
  local sub="${1:-list}"
  shift || true

  local log_dir=""
  if [ -n "${SOVEREIGN_OS_LOG_DIR:-}" ] && [ -d "${SOVEREIGN_OS_LOG_DIR}" ]; then
    log_dir="${SOVEREIGN_OS_LOG_DIR}"
  elif [ -d /var/log/sovereign-os ]; then
    log_dir="/var/log/sovereign-os"
  elif [ -d "${HOME}/.sovereign-os/log" ]; then
    log_dir="${HOME}/.sovereign-os/log"
  fi

  if [ -z "${log_dir}" ]; then
    echo "no Layer A log dir found"
    return 0
  fi

  case "${sub}" in
    list)
      python3 - "${log_dir}" <<'PY'
import sys, json, pathlib, re
from datetime import datetime

log_dir = pathlib.Path(sys.argv[1])
files = sorted(log_dir.glob("*.jsonl"))
if not files:
    print(f"no .jsonl files in {log_dir}")
    sys.exit(0)

# Wider headers; right-align numeric columns
print(f"{'RUN ID':<24} {'PROFILE':<16} {'STEPS':>5} {'ERR':>4} {'RESULT':<8} {'DURATION':<10} {'STARTED'}")

PROFILE_RE = re.compile(r"loaded profile:\s+(\S+)")
STEP_DONE_RE = re.compile(r"(\S+):\s+(PASS|FAIL)\s*$")

for path in files:
    # run-id = filename stem without 'build-' prefix
    stem = path.stem
    run_id = stem.removeprefix("build-")
    profile = "?"
    step_count = 0
    err_count = 0
    info_count = 0
    first_ts = None
    last_ts = None
    try:
        with path.open() as fh:
            for line in fh:
                line = line.strip()
                if not line: continue
                try:
                    e = json.loads(line)
                except json.JSONDecodeError:
                    continue
                ts = e.get("ts", "")
                msg = e.get("msg", "")
                lvl = (e.get("level") or "").lower()
                if first_ts is None:
                    first_ts = ts
                last_ts = ts
                m = PROFILE_RE.search(msg)
                if m and profile == "?":
                    # Strip trailing path/parens
                    profile = m.group(1).strip()
                if STEP_DONE_RE.search(msg):
                    step_count += 1
                if lvl == "error":
                    err_count += 1
                elif lvl == "info":
                    info_count += 1
    except OSError:
        continue

    # Result: success if no errors AND at least 1 step OR info > 0
    if err_count > 0:
        result = "FAIL"
    elif step_count > 0 or info_count > 0:
        result = "ok"
    else:
        result = "empty"

    # Duration: last - first as seconds, prettified
    duration = "?"
    try:
        if first_ts and last_ts:
            t0 = datetime.fromisoformat(first_ts.replace("Z", "+00:00"))
            t1 = datetime.fromisoformat(last_ts.replace("Z", "+00:00"))
            secs = int((t1 - t0).total_seconds())
            if secs >= 3600:
                duration = f"{secs//3600}h{(secs%3600)//60}m"
            elif secs >= 60:
                duration = f"{secs//60}m{secs%60}s"
            else:
                duration = f"{secs}s"
    except (ValueError, TypeError):
        pass

    started = first_ts or "?"
    print(f"{run_id:<24} {profile:<16} {step_count:>5} {err_count:>4} {result:<8} {duration:<10} {started}")
PY
      ;;

    show)
      local run_id="${1:-}"
      if [ -z "${run_id}" ]; then
        log_error "usage: sovereign-osctl history show <run-id>"
        log_error "  run 'sovereign-osctl history list' to see available run-ids"
        return 2
      fi
      # Resolve: try exact filename, then prepend 'build-' + append '.jsonl'
      local file=""
      for cand in \
        "${log_dir}/${run_id}" \
        "${log_dir}/${run_id}.jsonl" \
        "${log_dir}/build-${run_id}" \
        "${log_dir}/build-${run_id}.jsonl"; do
        if [ -f "${cand}" ]; then file="${cand}"; break; fi
      done
      if [ -z "${file}" ]; then
        log_error "no log file matches run-id '${run_id}' in ${log_dir}"
        return 1
      fi
      python3 - "${file}" <<'PY'
import sys, json, pathlib, re
path = pathlib.Path(sys.argv[1])
PROFILE_RE = re.compile(r"loaded profile:\s+(\S+)")
STEP_HEADER_RE = re.compile(r"━{3,}\s+STEP\s+(\S+)")
STEP_DONE_RE = re.compile(r"(\S+):\s+(PASS|FAIL)\s*$")

events = []
for line in path.read_text().splitlines():
    line = line.strip()
    if not line: continue
    try:
        events.append(json.loads(line))
    except json.JSONDecodeError:
        continue

if not events:
    print(f"  (run is empty)")
    sys.exit(0)

# Header
profile = "?"
for e in events:
    m = PROFILE_RE.search(e.get("msg",""))
    if m:
        profile = m.group(1).strip()
        break

first_ts = events[0].get("ts", "")
last_ts = events[-1].get("ts", "")
errors = [e for e in events if (e.get("level") or "").lower() == "error"]
warns = [e for e in events if (e.get("level") or "").lower() == "warn"]

print(f"  run-id:   {path.stem.removeprefix('build-')}")
print(f"  file:     {path}")
print(f"  profile:  {profile}")
print(f"  started:  {first_ts}")
print(f"  ended:    {last_ts}")
print(f"  events:   {len(events)}  (errors: {len(errors)}, warns: {len(warns)})")
print()

# Step-by-step results
print(f"  STEPS:")
shown_steps = []
for e in events:
    msg = e.get("msg", "")
    m = STEP_HEADER_RE.search(msg)
    if m:
        shown_steps.append({"id": m.group(1), "events": [], "result": None, "start_ts": e.get("ts")})
        continue
    m = STEP_DONE_RE.search(msg)
    if m and shown_steps:
        # Match to most recent step header by id or fall back to last
        sid = m.group(1)
        for s in reversed(shown_steps):
            if s["id"].startswith(sid) or sid.startswith(s["id"]):
                s["result"] = m.group(2)
                s["end_ts"] = e.get("ts")
                break
        else:
            shown_steps[-1]["result"] = m.group(2)
            shown_steps[-1]["end_ts"] = e.get("ts")
    if shown_steps and (e.get("level") or "").lower() == "error":
        shown_steps[-1]["events"].append(e.get("msg", "")[:80])

if not shown_steps:
    # No explicit step headers; fall back to listing pass/fail markers
    for e in events:
        m = STEP_DONE_RE.search(e.get("msg",""))
        if m:
            print(f"    {m.group(2):<5}  {m.group(1)}")
else:
    for s in shown_steps:
        result = s["result"] or "running"
        marker = "✓" if result == "PASS" else ("✗" if result == "FAIL" else "·")
        print(f"    {marker} {s['id']:<32} {result}")
        for err_msg in s["events"][:3]:
            print(f"        {err_msg}")

# Top-level errors not associated with a step
if not shown_steps and errors:
    print()
    print(f"  ERRORS:")
    for e in errors[:5]:
        print(f"    [{e.get('ts','?')}] {e.get('msg','')[:100]}")
PY
      ;;

    *)
      log_error "unknown history subcommand: ${sub}"
      log_error "  available: list / show <run-id>"
      return 2
      ;;
  esac
}

# ------------------------------ alerts ---------------------------------------
#
# Derives operator-actionable alerts from the SDD-016 Layer B textfile
# collector output WITHOUT requiring Alertmanager or any external
# rules engine. Sovereignty principle: the operator must be able to
# observe + act on their fleet using only what sovereign-os ships.
#
# Rules (each emits ALERT or WARN with the metric line + remediation hint):
#
#   ALERT  any *_total{...,result="fail"} > 0
#   ALERT  sovereign_os_friction_audit_failures > 0
#   ALERT  sovereign_os_perimeter_status != 1   (Tetragon inactive)
#   ALERT  sovereign_os_zfs_pool_health < 1     (degraded pool)
#   WARN   sovereign_os_security_updates_available > 0
#   WARN   any *_last_run_timestamp older than SOVEREIGN_OS_ALERTS_STALE_DAYS (default 7)
#
# --json mode emits an array of {level, metric, value, remediation}.

cmd_alerts() {
  local json_mode=0
  if [ "${1:-}" = "--json" ]; then
    json_mode=1
    shift || true
  fi

  : "${SOVEREIGN_OS_METRICS_DIR:=/var/lib/node_exporter/textfile_collector}"
  : "${SOVEREIGN_OS_ALERTS_STALE_DAYS:=7}"

  if [ ! -d "${SOVEREIGN_OS_METRICS_DIR}" ]; then
    if [ "${json_mode}" -eq 1 ]; then
      echo "[]"
    else
      echo "metrics dir absent: ${SOVEREIGN_OS_METRICS_DIR}"
      echo "  no alerts can be derived"
    fi
    return 0
  fi

  # Concatenate all sovereign-os .prom files for rule evaluation
  local now stale_cutoff
  now="$(date +%s)"
  stale_cutoff=$(( now - SOVEREIGN_OS_ALERTS_STALE_DAYS * 86400 ))

  # Python rule engine: parse Prometheus-text-format, apply rules, emit JSONL on stdout
  local alerts_jsonl
  alerts_jsonl="$(SOVEREIGN_OS_METRICS_DIR="${SOVEREIGN_OS_METRICS_DIR}" \
                  STALE_CUTOFF="${stale_cutoff}" \
                  python3 - <<'PY'
import os, re, json, glob

mdir = os.environ["SOVEREIGN_OS_METRICS_DIR"]
stale_cutoff = int(os.environ["STALE_CUTOFF"])

# name{labels} value [timestamp]
METRIC = re.compile(r"^(?P<name>[a-zA-Z_:][a-zA-Z0-9_:]*)(?:\{(?P<labels>[^}]*)\})?\s+(?P<value>-?[0-9.eE+]+)(?:\s+\d+)?\s*$")

def parse_labels(s):
    out = {}
    if not s: return out
    for pair in re.findall(r'(\w+)="((?:[^"\\]|\\.)*)"', s):
        out[pair[0]] = pair[1]
    return out

alerts = []
for path in sorted(glob.glob(os.path.join(mdir, "sovereign-os-*.prom"))):
    try:
        text = open(path).read()
    except OSError:
        continue
    for raw in text.splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        m = METRIC.match(line)
        if not m:
            continue
        name = m.group("name")
        labels = parse_labels(m.group("labels"))
        try:
            value = float(m.group("value"))
        except ValueError:
            continue

        # SDD-023 meta-exclusion: sovereign_os_meta_* metrics MUST NOT
        # trigger rules. They are the OUTPUT of the alerts engine
        # (alerts-check.sh recurrent hook emits meta_alert_count +
        # meta_alerts_check_last_run_timestamp); reacting to them would
        # create a self-reinforcing alert loop on every hourly tick.
        if name.startswith("sovereign_os_meta_"):
            continue

        # Rule 1: any *_total with result="fail" and value > 0
        if name.endswith("_total") and labels.get("result") == "fail" and value > 0:
            alerts.append({
                "level": "ALERT",
                "metric": name,
                "labels": labels,
                "value": value,
                "remediation": f"investigate the most recent {name.replace('sovereign_os_','').replace('_total','')} run; check journalctl and JSONL logs"
            })

        # Rule 2: friction-audit failures
        if name == "sovereign_os_friction_audit_failures" and value > 0:
            alerts.append({
                "level": "ALERT",
                "metric": name,
                "labels": labels,
                "value": value,
                "remediation": "run 'sovereign-osctl audit friction' to see the failing hardware checks"
            })

        # Rule 3: perimeter inactive
        if name == "sovereign_os_perimeter_status" and value != 1:
            alerts.append({
                "level": "ALERT",
                "metric": name,
                "labels": labels,
                "value": value,
                "remediation": "Tetragon not active; run 'sovereign-osctl perimeter status' and 'systemctl status tetragon'"
            })

        # Rule 4: zfs pool degraded
        if name == "sovereign_os_zfs_pool_health" and value < 1:
            alerts.append({
                "level": "ALERT",
                "metric": name,
                "labels": labels,
                "value": value,
                "remediation": f"zpool '{labels.get('pool','tank')}' not ONLINE; run 'zpool status {labels.get('pool','tank')}'"
            })

        # Rule 5: pending security updates (WARN)
        if name == "sovereign_os_security_updates_available" and value > 0:
            alerts.append({
                "level": "WARN",
                "metric": name,
                "labels": labels,
                "value": value,
                "remediation": f"{int(value)} security update(s) pending; run 'unattended-upgrade -d' or 'sovereign-osctl maintenance security-check'"
            })

        # Rule 6: stale last-run timestamps
        if name.endswith("_last_run_timestamp") and value > 0 and value < stale_cutoff:
            age_days = int((stale_cutoff + int(os.environ.get('NOW', 0)) - int(value)) / 86400) if False else None
            from datetime import datetime, timezone
            ts = datetime.fromtimestamp(value, tz=timezone.utc).strftime("%Y-%m-%d %H:%M:%SZ")
            alerts.append({
                "level": "WARN",
                "metric": name,
                "labels": labels,
                "value": value,
                "remediation": f"last successful run was {ts}; recurrent timer may not be firing — check systemd timer status"
            })

# Stable sort: ALERT before WARN, then by metric name
alerts.sort(key=lambda a: (0 if a["level"] == "ALERT" else 1, a["metric"]))
for a in alerts:
    print(json.dumps(a))
PY
)"

  if [ "${json_mode}" -eq 1 ]; then
    # Convert JSONL to JSON array
    if [ -z "${alerts_jsonl}" ]; then
      echo "[]"
    else
      python3 -c "
import sys, json
lines = [l for l in sys.stdin.read().splitlines() if l.strip()]
print(json.dumps([json.loads(l) for l in lines], indent=2))
" <<< "${alerts_jsonl}"
    fi
    return 0
  fi

  # Pretty-print
  local alert_count warn_count
  alert_count="$(grep -c '"level": "ALERT"' <<< "${alerts_jsonl}" || true)"
  warn_count="$(grep -c '"level": "WARN"' <<< "${alerts_jsonl}" || true)"
  alert_count="${alert_count:-0}"
  warn_count="${warn_count:-0}"

  if [ "${alert_count}" -eq 0 ] && [ "${warn_count}" -eq 0 ]; then
    log_info "no alerts derived from ${SOVEREIGN_OS_METRICS_DIR}"
    log_info "  (scanned $(find "${SOVEREIGN_OS_METRICS_DIR}" -maxdepth 1 -name 'sovereign-os-*.prom' -type f 2>/dev/null | wc -l) .prom file(s))"
    return 0
  fi

  echo "sovereign-osctl alerts"
  echo "======================"
  echo
  echo "  ALERT count: ${alert_count}"
  echo "  WARN  count: ${warn_count}"
  echo
  python3 -c "
import sys, json
for line in sys.stdin.read().splitlines():
    if not line.strip(): continue
    a = json.loads(line)
    label_str = ' '.join(f'{k}={v}' for k, v in (a.get('labels') or {}).items())
    print(f\"  [{a['level']:>5}] {a['metric']}{(' {' + label_str + '}') if label_str else ''}\")
    print(f\"          value: {a['value']}\")
    print(f\"          fix:   {a['remediation']}\")
    print()
" <<< "${alerts_jsonl}"

  # Non-zero exit on any ALERT — operator scripts can chain on this.
  # `exit` instead of `return` to bypass the ERR trap (which would
  # otherwise log "command failed: return 1" — confusing noise when
  # the non-zero is deliberate signalling).
  [ "${alert_count}" -eq 0 ] && exit 0 || exit 1
}

# ------------------------------ env ------------------------------------------
#
# Round 137 (F-03 HIGH closure): operator-facing env-var discovery.
# 84+ SOVEREIGN_OS_* env vars scattered across the codebase. Operators
# hunting for "what env var changes X" used to grep the codebase
# manually. This verb does that scan + presents the result.

cmd_env() {
  local sub="${1:-list}"
  shift || true

  case "${sub}" in
    list)
      local filter=""
      while [ $# -gt 0 ]; do
        case "$1" in
          --filter) filter="${2:-}"; shift 2 ;;
          -*) log_error "unknown env list flag: $1"; return 2 ;;
          *) shift ;;
        esac
      done

      # Scan + dedupe + present
      ENV_FILTER="${filter}" REPO_ROOT="${__REPO_ROOT}" python3 - <<'PY'
import os, re, pathlib, collections

repo = pathlib.Path(os.environ["REPO_ROOT"])
flt  = os.environ.get("ENV_FILTER", "")
flt_re = re.compile(flt) if flt else None

# Two patterns:
#   defaults  — `: "${VAR:=value}"` or `: ${VAR:=value}`
#   reads     — bare `${VAR}` or `$VAR` references
DEFAULT_RE = re.compile(r':\s*"?\$\{(SOVEREIGN_OS_[A-Z0-9_]+):=([^}]*)\}"?')
READ_RE    = re.compile(r'\bSOVEREIGN_OS_[A-Z0-9_]+\b')

defaults = {}     # var → (default-value, file)
consumers = collections.defaultdict(set)   # var → set(file)

for path in repo.glob("scripts/**/*"):
    if not path.is_file(): continue
    try:
        text = path.read_text(errors="ignore")
    except OSError:
        continue
    rel = str(path.relative_to(repo))
    for m in DEFAULT_RE.finditer(text):
        var, default = m.group(1), m.group(2)
        if var not in defaults:
            defaults[var] = (default, rel)
    for var in READ_RE.findall(text):
        consumers[var].add(rel)

all_vars = sorted(set(defaults) | set(consumers))
if flt_re:
    all_vars = [v for v in all_vars if flt_re.search(v)]

# Header
print(f"{'NAME':<46} {'DEFAULT':<32} CONSUMERS")
for var in all_vars:
    default, _ = defaults.get(var, ("(no default; set by operator)", ""))
    default_short = default[:30] + ".." if len(default) > 32 else default
    consumer_count = len(consumers.get(var, ()))
    print(f"{var:<46} {default_short:<32} {consumer_count}")

print()
print(f"  total: {len(all_vars)} env var(s)")
if flt_re:
    print(f"  filter: /{flt}/")
print(f"  for details: sovereign-osctl env show <NAME>")
PY
      ;;

    show)
      local name="${1:-}"
      if [ -z "${name}" ]; then
        log_error "usage: sovereign-osctl env show <NAME>"
        return 2
      fi
      ENV_NAME="${name}" REPO_ROOT="${__REPO_ROOT}" CURRENT="${!name:-(unset)}" python3 - <<'PY'
import os, re, pathlib, sys

repo = pathlib.Path(os.environ["REPO_ROOT"])
name = os.environ["ENV_NAME"]
current = os.environ["CURRENT"]

if not name.startswith("SOVEREIGN_OS_"):
    print(f"warn: '{name}' does not start with SOVEREIGN_OS_ — env-var discovery limited", file=sys.stderr)

DEFAULT_RE = re.compile(rf':\s*"?\$\{{{re.escape(name)}:=([^}}]*)\}}"?')
READ_RE = re.compile(rf'\b{re.escape(name)}\b')

default_value = None
default_file = None
consumers = []
for path in repo.glob("scripts/**/*"):
    if not path.is_file(): continue
    try:
        text = path.read_text(errors="ignore")
    except OSError:
        continue
    rel = str(path.relative_to(repo))
    m = DEFAULT_RE.search(text)
    if m and default_value is None:
        default_value = m.group(1)
        default_file = rel
    if READ_RE.search(text):
        consumers.append(rel)

print(f"  name:           {name}")
print(f"  default:        {default_value if default_value else '(no default; set by operator)'}")
if default_file:
    print(f"  default-from:   {default_file}")
print(f"  currently set:  {current}")
print(f"  consumed by:    {len(consumers)} file(s)")
for c in sorted(set(consumers))[:20]:
    print(f"                  - {c}")
if len(set(consumers)) > 20:
    print(f"                  ... and {len(set(consumers)) - 20} more")
if not default_value and not consumers:
    print(f"  WARNING: env var '{name}' not found anywhere in scripts/")
    sys.exit(1)
PY
      ;;

    *)
      log_error "unknown env subcommand: ${sub}"
      log_error "  available: list [--filter <regex>] | show <NAME>"
      return 2
      ;;
  esac
}

# ------------------------------ init -----------------------------------------
#
# Round 136 (F-02 HIGH closure): operator-facing setup wizard.
# Walks the operator through the 5 mandatory decisions (profile,
# substrate, secure-boot posture, disk encryption, whitelabel) ONCE,
# at fresh-machine onboarding time, instead of forcing them to read
# 26 SDDs to compose a build invocation.
#
# Writes the chosen values to .sovereign-os/init-state.yaml + prints
# the EXACT next command. Idempotent — re-running re-prompts and
# overwrites (operator may want to change decisions).
#
# --non-interactive mode: accepts defaults for every decision; writes
# the state file; prints the next command. Suitable for CI / scripted
# fleet bootstrap.

cmd_init() {
  local non_interactive=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --non-interactive|--ni) non_interactive=1; shift ;;
      -*) log_error "unknown init flag: $1"; return 2 ;;
      *)  shift ;;
    esac
  done
  [ -n "${SOVEREIGN_OS_NONINTERACTIVE:-}" ] && non_interactive=1

  local repo_root
  repo_root="$(cd "${__REPO_ROOT}" && pwd)"
  local state_dir="${repo_root}/.sovereign-os"
  local state_file="${state_dir}/init-state.yaml"
  mkdir -p "${state_dir}"

  echo
  echo "  sovereign-osctl init — operator setup wizard"
  echo "  ============================================="
  echo
  echo "  Walks you through 5 decisions. Defaults shown in [brackets]."
  echo "  Press Enter at any prompt to accept the default."
  echo

  # ---- Decision 1: profile ----
  echo "  [1/5] PROFILE — which hardware archetype?"
  echo "    sain-01         AI workstation (Zen 5 · 128GB · 2x NVMe-PCIe-5 · 3090 + 5090 VFIO + Tetragon)"
  echo "    old-workstation constrained dev box (single 3090, ext4)"
  echo "    minimal         VM baseline (generic x86-64-v3, virtio-blk)"
  echo "    developer       polyglot dev workstation (full toolchain)"
  echo "    headless        bare-metal server (8c/16t · 32GB ECC · auditd + fail2ban)"
  echo "    recommendation: sain-01 if SAIN-01 hardware; else minimal for VM testing"
  local profile_id="sain-01"
  if [ "${non_interactive}" -eq 0 ]; then
    read -rp "  profile [${profile_id}]: " ans
    [ -n "${ans}" ] && profile_id="${ans}"
  fi
  # Validate
  if [ ! -f "${repo_root}/profiles/${profile_id}.yaml" ]; then
    log_error "  no such profile: ${profile_id} (looked in profiles/)"
    return 1
  fi
  echo "    → ${profile_id}"
  echo

  # ---- Decision 2: substrate ----
  echo "  [2/5] SUBSTRATE — image-build backend"
  echo "    mkosi           SDD-003 primary; Debian 13 trixie"
  echo "    live-build      ALT-A; substrate-agnostic content"
  echo "    recommendation: mkosi (primary path; faster builds; reproducibility-tested)"
  local substrate="mkosi"
  if [ "${non_interactive}" -eq 0 ]; then
    read -rp "  substrate [${substrate}]: " ans
    [ -n "${ans}" ] && substrate="${ans}"
  fi
  case "${substrate}" in
    mkosi|live-build) ;;
    *) log_error "  unknown substrate: ${substrate} (valid: mkosi, live-build)"; return 1 ;;
  esac
  echo "    → ${substrate}"
  echo

  # ---- Decision 3: secure-boot posture ----
  # Pull profile default if set
  local secure_boot_default
  secure_boot_default="$(python3 -c "
import yaml, sys
try:
    with open('${repo_root}/profiles/${profile_id}.yaml') as f:
        data = yaml.safe_load(f) or {}
    print((data.get('kernel') or {}).get('cmdline', {}).get('secure_boot', 'none'))
except: print('none')
" 2>/dev/null)"
  echo "  [3/5] SECURE-BOOT — UEFI signing posture (SDD-015)"
  echo "    none            no signing chain (dev / VM)"
  echo "    shim            Microsoft-CA shim + operator MOK (most operators)"
  echo "    signed          operator-owned PK chain (advanced; pre-enrolled hardware)"
  echo "    profile default: ${secure_boot_default}"
  local secure_boot="${secure_boot_default}"
  if [ "${non_interactive}" -eq 0 ]; then
    read -rp "  secure_boot [${secure_boot}]: " ans
    [ -n "${ans}" ] && secure_boot="${ans}"
  fi
  case "${secure_boot}" in
    none|shim|signed) ;;
    *) log_error "  invalid secure_boot: ${secure_boot}"; return 1 ;;
  esac
  echo "    → ${secure_boot}"
  echo

  # ---- Decision 4: disk encryption opt-in ----
  echo "  [4/5] DISK ENCRYPTION — opt-in toggle (SDD-022)"
  echo "    yes             ZFS-native (zfs-tiered profiles) or LUKS2 (ext4)"
  echo "    no              clear-text rootfs (dev/VM only)"
  echo "    recommendation: yes for sain-01 + headless; profile-specific for others"
  local encrypt_default="yes"
  case "${profile_id}" in
    minimal) encrypt_default="no" ;;
    developer|old-workstation) encrypt_default="yes" ;;
  esac
  local encrypt="${encrypt_default}"
  if [ "${non_interactive}" -eq 0 ]; then
    read -rp "  encrypt [${encrypt}]: " ans
    [ -n "${ans}" ] && encrypt="${ans}"
  fi
  case "${encrypt}" in yes|no) ;; *) log_error "  invalid (yes|no): ${encrypt}"; return 1 ;; esac
  echo "    → ${encrypt}"
  echo

  # ---- Decision 5: whitelabel ----
  echo "  [5/5] WHITELABEL — operator branding identity"
  echo "    default         sovereign-os default whitelabel (motd · plymouth · grub)"
  echo "    fork            operator-owned fork (you author whitelabel/<id>.yaml later)"
  echo "    recommendation: default (operator can fork later via 'profiles fork')"
  local whitelabel="default"
  if [ "${non_interactive}" -eq 0 ]; then
    read -rp "  whitelabel [${whitelabel}]: " ans
    [ -n "${ans}" ] && whitelabel="${ans}"
  fi
  echo "    → ${whitelabel}"
  echo

  # ---- Write state file ----
  local now; now="$(date -u --iso-8601=seconds)"
  cat > "${state_file}" <<EOF
# auto-generated by sovereign-osctl init
# rewrite by re-running 'sovereign-osctl init'
schema_version: "1.0.0"
init_completed_at: "${now}"
decisions:
  profile: "${profile_id}"
  substrate: "${substrate}"
  secure_boot: "${secure_boot}"
  encrypt: "${encrypt}"
  whitelabel: "${whitelabel}"
EOF
  log_info "init state written: ${state_file}"
  echo
  echo "  NEXT STEPS:"
  echo "    # 1. Run preflight against your chosen profile"
  echo "    SOVEREIGN_OS_PROFILE=${profile_id} scripts/build/orchestrate.sh preflight"
  echo
  echo "    # 2. Build the image (dry-run first; remove --dry-run when ready)"
  echo "    SOVEREIGN_OS_PROFILE=${profile_id} SOVEREIGN_OS_SUBSTRATE=${substrate} \\"
  echo "      scripts/build/orchestrate.sh run --dry-run"
  echo
  echo "    # 3. After build succeeds, dump to target device (gated):"
  echo "    sovereign-osctl install image --plan build/${profile_id}/output/${profile_id} --to /dev/<target>"
  echo
}

# ------------------------------ secure-boot ----------------------------------
#
# R143 (F-05 MED closure): SDD-015 'signed' posture requires operator-
# owned PK/KEK/db keys (NEVER in-repo per SDD-015 § Operator-supplied
# keys). Without this verb operators had to manually openssl + sbsign
# + KeyTool the whole chain. Most skipped the 'signed' posture
# because of that friction.
#
# This verb generates the key triple with sane defaults, writes them
# OUTSIDE the repo root (hard refusal otherwise), and prints the
# enrollment commands. Operator backs them up; sovereign-os never
# sees them again.

cmd_secure_boot() {
  local sub="${1:-status}"
  shift || true

  case "${sub}" in
    gen-keys)
      local out_dir="" cn=""
      while [ $# -gt 0 ]; do
        case "$1" in
          --out) out_dir="${2:-}"; shift 2 ;;
          --cn)  cn="${2:-}"; shift 2 ;;
          -*)    log_error "unknown gen-keys flag: $1"; return 2 ;;
          *)     shift ;;
        esac
      done
      if [ -z "${out_dir}" ]; then
        log_error "usage: sovereign-osctl secure-boot gen-keys --out <dir> [--cn <common-name>]"
        log_error "  --out is REQUIRED. operator-owned keys MUST land outside the repo."
        return 2
      fi
      # Reject if --out is under repo root
      local out_abs repo_abs
      out_abs="$(readlink -f "${out_dir}" 2>/dev/null || echo "${out_dir}")"
      repo_abs="$(readlink -f "${__REPO_ROOT}" 2>/dev/null || echo "${__REPO_ROOT}")"
      case "${out_abs}" in
        "${repo_abs}"*)
          log_error "HARD REFUSAL — --out ${out_abs} is under the sovereign-os repo root (${repo_abs})"
          log_error "  operator-supplied keys MUST NEVER live in-repo per SDD-015."
          log_error "  pick a location outside the repo (e.g. ~/.sovereign-os/secure-boot-keys/)"
          return 1
          ;;
      esac
      # Require openssl
      if ! command -v openssl >/dev/null 2>&1; then
        log_error "openssl is required to generate keys (apt install openssl)"
        return 1
      fi
      mkdir -p "${out_dir}"
      [ -z "${cn}" ] && cn="sovereign-os-$(hostname -s 2>/dev/null || echo host)"
      log_warn "GENERATING OPERATOR-OWNED secure-boot keys (4096-bit RSA, 10-year validity)"
      log_warn "  CN: ${cn}"
      log_warn "  out: ${out_dir}"
      log_warn ""

      # Generate three key/cert pairs: PK, KEK, db
      local key_type
      for key_type in PK KEK db; do
        local subj="/CN=${cn} ${key_type}/"
        log_info "  generating ${key_type}..."
        openssl req -new -x509 -newkey rsa:4096 -nodes -days 3650 \
          -subj "${subj}" \
          -keyout "${out_dir}/${key_type}.key" \
          -out    "${out_dir}/${key_type}.crt" >/dev/null 2>&1
        chmod 0600 "${out_dir}/${key_type}.key"
        # Convert .crt → .cer (DER) for UEFI enrollment
        openssl x509 -in "${out_dir}/${key_type}.crt" \
          -outform DER -out "${out_dir}/${key_type}.cer" 2>/dev/null
      done

      # Generate ESL + auth payloads for `efi-updatevar` if sbsigntools present
      if command -v cert-to-efi-sig-list >/dev/null 2>&1 && command -v sign-efi-sig-list >/dev/null 2>&1; then
        for key_type in PK KEK; do
          cert-to-efi-sig-list -g "$(uuidgen 2>/dev/null || echo "00000000-0000-0000-0000-000000000000")" \
            "${out_dir}/${key_type}.crt" "${out_dir}/${key_type}.esl" 2>/dev/null
          sign-efi-sig-list -k "${out_dir}/${key_type}.key" -c "${out_dir}/${key_type}.crt" \
            "${key_type}" "${out_dir}/${key_type}.esl" "${out_dir}/${key_type}.auth" 2>/dev/null
        done
        log_info "  .esl + .auth payloads generated for efi-updatevar enrollment"
      else
        log_warn "  cert-to-efi-sig-list / sign-efi-sig-list not present —"
        log_warn "  install: apt install efitools  — then re-run for .esl/.auth payloads"
      fi

      # Write a README inside the out dir to remind operator of the contract
      cat > "${out_dir}/README.md" <<EOF
# sovereign-os operator-owned secure-boot keys

Generated by \`sovereign-osctl secure-boot gen-keys\` on $(date -u --iso-8601=seconds).

**SDD-015 / Operator-supplied keys posture**: these keys are YOURS.
Sovereign-os ships no central CA, no key escrow, no recovery path.
If you lose them you cannot sign updates to this system.

**WHAT TO DO NOW**:

1. Back these files up (encrypted offline storage — YubiKey HSM,
   air-gapped USB, etc.) BEFORE rebooting.
2. To enroll on a system in setup-mode UEFI:

   \`\`\`sh
   # in setup-mode (PK absent)
   sudo efi-updatevar -e -f db.auth db
   sudo efi-updatevar -e -f KEK.auth KEK
   sudo efi-updatevar -f PK.auth PK     # locks the chain; do PK LAST
   \`\`\`

   On hardware where setup-mode requires firmware-menu interaction,
   use \`KeyTool.efi\` from sbsigntools.

3. Then sign your kernel + initramfs:

   \`\`\`sh
   sudo sbsign --key ${out_dir}/db.key --cert ${out_dir}/db.crt \\
     --output /boot/vmlinuz-signed /boot/vmlinuz-\$(uname -r)
   \`\`\`

4. Set the sovereign-os profile to \`kernel.cmdline.secure_boot: signed\`
   in your profile YAML; tell the orchestrator about your db key via
   \`SOVEREIGN_OS_DB_KEY\` and \`SOVEREIGN_OS_DB_CERT\`.

**KEY HYGIENE**:
  - Never commit these files to any repo (including sovereign-os).
  - Rotate annually; chain-rotation uses the prior PK to sign the new PK.
  - If a key is lost, the only recovery is firmware factory-reset
    (operator workflow; outside sovereign-os scope).
EOF
      echo
      log_info "key triple generated. files in ${out_dir}/:"
      log_info "  PK.{key,crt,cer,esl,auth}  KEK.{key,crt,cer,esl,auth}  db.{key,crt,cer}"
      log_info "  README.md — enrollment + backup contract"
      log_warn ""
      log_warn "BACK THESE UP NOW. sovereign-os never sees them again."
      log_warn "see ${out_dir}/README.md for enrollment commands."
      ;;

    status)
      echo "  secure-boot status:"
      if [ -d /sys/firmware/efi ]; then
        echo "    UEFI:       yes (/sys/firmware/efi present)"
      else
        echo "    UEFI:       no (BIOS or container)"
      fi
      if [ -r /sys/firmware/efi/efivars/SecureBoot-* ] 2>/dev/null; then
        # last byte = 0 disabled, 1 enabled
        local sb_byte
        sb_byte="$(od -An -t u1 /sys/firmware/efi/efivars/SecureBoot-* 2>/dev/null | tail -1 | awk '{print $NF}')"
        if [ "${sb_byte}" = "1" ]; then
          echo "    SecureBoot: ENABLED"
        else
          echo "    SecureBoot: disabled"
        fi
      else
        echo "    SecureBoot: status unreadable (no efivars or insufficient privilege)"
      fi
      if command -v mokutil >/dev/null 2>&1; then
        echo "    MOK:        $(mokutil --sb-state 2>/dev/null || echo unknown)"
        local mok_count; mok_count="$(mokutil --list-enrolled 2>/dev/null | grep -c '^---' || echo 0)"
        echo "    MOK keys enrolled: ${mok_count}"
      else
        echo "    MOK:        mokutil not installed"
      fi
      ;;

    *)
      log_error "unknown secure-boot subcommand: ${sub}"
      log_error "  available: gen-keys --out <dir> [--cn <name>] | status"
      return 2
      ;;
  esac
}

# ------------------------------ install --------------------------------------
#
# Round 134 (F-01 CRIT closure): safety-gated wrapper around `dd` for
# dumping a built sovereign-os image onto a target device. Replaces
# the install-runbook's raw `sudo dd if=... of=...` instruction.
#
# Gates (ALL must pass before any byte is written):
#   1. Image file exists + is non-empty + is a regular file
#   2. Target device exists + is a block device
#   3. Target is NOT a partition (must be the whole disk)
#   4. Target is NOT the currently-mounted root or its parent
#   5. SOVEREIGN_OS_CONFIRM_DESTROY=YES
#   6. Interactive confirm (unless SOVEREIGN_OS_NONINTERACTIVE=1)
#
# --plan mode: show what WOULD happen + device fingerprint, exit 0,
# never write a byte. Operator runs this first to inspect.

cmd_install() {
  local sub="${1:-help}"
  shift || true

  case "${sub}" in
    image)
      local plan_only=0
      local image=""
      local device=""
      while [ $# -gt 0 ]; do
        case "$1" in
          --plan) plan_only=1; shift ;;
          --to)   device="${2:-}"; shift 2 ;;
          --)     shift; break ;;
          -*)     log_error "unknown install image flag: $1"; return 2 ;;
          *)      if [ -z "${image}" ]; then image="$1"; fi; shift ;;
        esac
      done

      # Gate 1 — image file
      if [ -z "${image}" ]; then
        log_error "usage: sovereign-osctl install image [--plan] <image-path> --to <device>"
        return 2
      fi
      if [ ! -f "${image}" ]; then
        log_error "image not found or not a regular file: ${image}"
        return 1
      fi
      local image_size
      image_size="$(stat -c '%s' "${image}" 2>/dev/null || echo 0)"
      if [ "${image_size}" -lt 1048576 ]; then
        log_error "image is suspiciously small (${image_size} bytes); refusing"
        return 1
      fi

      # Gate 2 — target device
      if [ -z "${device}" ]; then
        log_error "missing --to <device>"
        return 2
      fi
      if [ ! -b "${device}" ]; then
        log_error "target is not a block device: ${device}"
        return 1
      fi

      # Gate 3 — must be a whole disk (not a partition)
      # Heuristic: device name ends in a digit AND parent block device exists
      local dev_basename; dev_basename="$(basename "${device}")"
      if [[ "${dev_basename}" =~ [0-9]$ ]] && [ -e "/sys/class/block/${dev_basename}/partition" ]; then
        log_error "target ${device} is a PARTITION, not a whole disk; refusing"
        log_error "  pass the parent disk (e.g. /dev/nvme0n1, not /dev/nvme0n1p1)"
        return 1
      fi

      # Gate 4 — target must NOT be the running root or its parent
      local root_src; root_src="$(findmnt -n -o SOURCE / 2>/dev/null || echo unknown)"
      local root_parent; root_parent="$(lsblk -no PKNAME "${root_src}" 2>/dev/null | head -1 || echo unknown)"
      if [ "${device}" = "${root_src}" ] || [ "${dev_basename}" = "${root_parent}" ]; then
        log_error "target ${device} IS THE RUNNING ROOT or its parent; HARD REFUSAL"
        log_error "  running root: ${root_src}  parent: ${root_parent}"
        return 1
      fi

      # Device fingerprint
      local model serial size_human is_mounted
      model="$(lsblk -dn -o MODEL "${device}" 2>/dev/null | xargs || echo unknown)"
      serial="$(lsblk -dn -o SERIAL "${device}" 2>/dev/null | xargs || echo unknown)"
      size_human="$(lsblk -dn -o SIZE "${device}" 2>/dev/null | xargs || echo unknown)"
      is_mounted="$(lsblk -n -o MOUNTPOINTS "${device}" 2>/dev/null | xargs || echo)"

      echo
      echo "  target device fingerprint:"
      echo "    path:     ${device}"
      echo "    model:    ${model}"
      echo "    serial:   ${serial}"
      echo "    size:     ${size_human}"
      echo "    mounted:  ${is_mounted:-(none)}"
      echo
      echo "  image:"
      echo "    path:     ${image}"
      echo "    size:     $(numfmt --to=iec --suffix=B "${image_size}" 2>/dev/null || echo "${image_size}B")"
      echo

      if [ "${plan_only}" -eq 1 ]; then
        echo "  --plan mode: would run:"
        echo "    sudo dd if='${image}' of='${device}' bs=4M status=progress conv=fsync"
        echo "  no byte was written. drop --plan to execute (gates: SOVEREIGN_OS_CONFIRM_DESTROY=YES + interactive)."
        return 0
      fi

      # Gate 5 — env confirmation
      if [ "${SOVEREIGN_OS_CONFIRM_DESTROY:-}" != "YES" ]; then
        log_error "DESTRUCTIVE operation. SOVEREIGN_OS_CONFIRM_DESTROY=YES not set."
        log_error "  re-run with: SOVEREIGN_OS_CONFIRM_DESTROY=YES sovereign-osctl install image '${image}' --to '${device}'"
        log_error "  or preview without writing: sovereign-osctl install image --plan '${image}' --to '${device}'"
        return 1
      fi

      # Gate 6 — interactive confirm (unless NONINTERACTIVE)
      if [ -z "${SOVEREIGN_OS_NONINTERACTIVE:-}" ]; then
        echo "  This will WIPE ${device} (${model} ${serial}, ${size_human})"
        echo "  and write ${image} ($(numfmt --to=iec --suffix=B "${image_size}" 2>/dev/null || echo "${image_size}B"))."
        echo
        read -rp "  Type the device path (${device}) to confirm: " typed
        if [ "${typed}" != "${device}" ]; then
          log_error "device confirmation mismatch; aborting"
          return 1
        fi
      fi

      # All gates passed — execute
      log_info "writing ${image} → ${device} (this will take several minutes)"
      if command -v dd >/dev/null 2>&1; then
        sudo dd if="${image}" of="${device}" bs=4M status=progress conv=fsync
        log_info "image dump complete"
        log_info "sync'ing disk..."
        sudo sync
        log_info "done. consider 'sovereign-osctl install verify --to ${device}' (future) before unplugging."
      else
        log_error "dd not available; cannot proceed"
        return 1
      fi
      ;;

    help|--help|-h|"")
      cat <<EOF
sovereign-osctl install — operator-side image deployment

USAGE:
  sovereign-osctl install image [--plan] <image-path> --to <device>

GATES (every byte-writing path must pass ALL):
  • image exists + non-empty + regular file
  • target is a block device + WHOLE DISK (not a partition)
  • target is NOT the running root or its parent (HARD REFUSAL)
  • SOVEREIGN_OS_CONFIRM_DESTROY=YES
  • interactive device-path confirm (unless SOVEREIGN_OS_NONINTERACTIVE=1)

--plan mode: shows the device fingerprint + the command that WOULD
run, writes nothing. Recommended first step.

EXAMPLES:
  # 1. Preview
  sovereign-osctl install image --plan build/sain-01/output/sain-01 --to /dev/nvme1n1

  # 2. Execute (after preview review)
  SOVEREIGN_OS_CONFIRM_DESTROY=YES \\
    sudo sovereign-osctl install image build/sain-01/output/sain-01 --to /dev/nvme1n1
EOF
      ;;

    *)
      log_error "unknown install subcommand: ${sub}"
      log_error "  available: image [--plan] <img> --to <dev> | help"
      return 2
      ;;
  esac
}

# ------------------------------ decommission ---------------------------------

# ------------------------------ hooks ----------------------------------------
#
# R141 (F-09 MED closure): operator-facing profile-hook editor.
# Before this verb operators wanting to add a post-install hook (e.g.,
# 'after install, set up my dotfiles') edited the profile YAML manually
# and could typo the path or forget the schema shape. This verb does
# the YAML mutation safely + validates the path + flags the schema.
#
# Stages (must match profile.schema.yaml § hooks):
#   pre_install · during_install · post_install_first_boot ·
#   post_install_recurrent · decommission

cmd_hooks() {
  local sub="${1:-list}"
  shift || true

  case "${sub}" in
    list)
      local id="${1:-${SOVEREIGN_OS_PROFILE}}"
      local f="${__REPO_ROOT}/profiles/${id}.yaml"
      if [ ! -f "${f}" ]; then
        log_error "no such profile: ${id}"
        return 1
      fi
      PROFILE_FILE="${f}" python3 - <<'PY'
import os, yaml
with open(os.environ["PROFILE_FILE"]) as fh:
    data = yaml.safe_load(fh) or {}
hooks = data.get("hooks") or {}
total = 0
for stage in ("pre_install", "during_install", "post_install_first_boot",
              "post_install_recurrent", "decommission"):
    entries = hooks.get(stage) or []
    if not entries: continue
    print(f"  {stage}:")
    for h in entries:
        total += 1
        mand = " [mandatory]" if h.get("mandatory") else ""
        sch = f" schedule={h.get('schedule')}" if h.get("schedule") else ""
        print(f"    - {h.get('id', '?'):<32} {h.get('script', '?')}{mand}{sch}")
print(f"  total: {total} hook(s) declared")
PY
      ;;

    add)
      local stage="" script="" id="" mandatory=0 profile="${SOVEREIGN_OS_PROFILE}"
      stage="${1:-}"; shift || true
      script="${1:-}"; shift || true
      while [ $# -gt 0 ]; do
        case "$1" in
          --id) id="${2:-}"; shift 2 ;;
          --mandatory) mandatory=1; shift ;;
          --profile) profile="${2:-}"; shift 2 ;;
          *) log_error "unknown hooks add flag: $1"; return 2 ;;
        esac
      done
      if [ -z "${stage}" ] || [ -z "${script}" ]; then
        log_error "usage: sovereign-osctl hooks add <stage> <script-path> [--id <id>] [--mandatory] [--profile <id>]"
        return 2
      fi
      # Validate stage
      case "${stage}" in
        pre_install|during_install|post_install_first_boot|post_install_recurrent|decommission) ;;
        *) log_error "invalid stage: ${stage}"
           log_error "  valid: pre_install · during_install · post_install_first_boot · post_install_recurrent · decommission"
           return 2 ;;
      esac
      # Validate profile
      local f="${__REPO_ROOT}/profiles/${profile}.yaml"
      if [ ! -f "${f}" ]; then
        log_error "no such profile: ${profile}"
        return 1
      fi
      # Validate script path (relative to repo root, must exist + be executable)
      local script_full="${__REPO_ROOT}/${script}"
      if [ ! -f "${script_full}" ]; then
        log_error "script not found: ${script_full}"
        log_error "  path must be relative to repo root (e.g. scripts/hooks/post-install/my-hook.sh)"
        return 1
      fi
      if [ ! -x "${script_full}" ]; then
        log_error "script not executable: ${script_full}"
        log_error "  run: chmod +x ${script_full}"
        return 1
      fi
      # Default id from basename
      if [ -z "${id}" ]; then
        id="$(basename "${script}" .sh)"
      fi
      # Validate id pattern
      if ! [[ "${id}" =~ ^[a-z][a-z0-9-]*$ ]]; then
        log_error "invalid hook id: ${id}"
        log_error "  must match: ^[a-z][a-z0-9-]*$"
        return 2
      fi
      # Mutate the profile YAML
      PROFILE_FILE="${f}" STAGE="${stage}" HOOK_ID="${id}" SCRIPT="${script}" \
      MAND="${mandatory}" python3 - <<'PY'
import os, yaml, sys
pfile = os.environ["PROFILE_FILE"]
stage = os.environ["STAGE"]
hook_id = os.environ["HOOK_ID"]
script = os.environ["SCRIPT"]
mandatory = os.environ["MAND"] == "1"
with open(pfile) as f:
    data = yaml.safe_load(f) or {}
hooks = data.setdefault("hooks", {})
entries = hooks.setdefault(stage, [])
# Refuse on duplicate id within the same stage
for e in entries:
    if e.get("id") == hook_id:
        print(f"hook id '{hook_id}' already exists in {stage}; refusing to duplicate", file=sys.stderr)
        sys.exit(1)
new_entry = {
    "id": hook_id,
    "type": "setup",
    "script": script,
    "mandatory": mandatory,
}
entries.append(new_entry)
with open(pfile, "w") as f:
    # Preserve the schema header (assumed to live in the first 5 lines)
    # by re-reading them
    pass
with open(pfile) as f_orig:
    orig_lines = f_orig.readlines()
header_lines = []
for line in orig_lines:
    if line.startswith("#") or not line.strip():
        header_lines.append(line)
    else:
        break
with open(pfile, "w") as f:
    f.writelines(header_lines)
    yaml.safe_dump(data, f, sort_keys=False, default_flow_style=False)
print(f"hook added: id={hook_id} stage={stage} script={script} mandatory={mandatory}")
PY
      local rc=$?
      if [ "${rc}" -ne 0 ]; then
        return "${rc}"
      fi
      log_info "  edited: ${f}"
      log_info "  NEXT:  sovereign-osctl profiles validate"
      ;;

    remove)
      local id="${1:-}" profile="${SOVEREIGN_OS_PROFILE}"
      shift || true
      while [ $# -gt 0 ]; do
        case "$1" in
          --profile) profile="${2:-}"; shift 2 ;;
          *) log_error "unknown hooks remove flag: $1"; return 2 ;;
        esac
      done
      if [ -z "${id}" ]; then
        log_error "usage: sovereign-osctl hooks remove <id> [--profile <id>]"
        return 2
      fi
      local f="${__REPO_ROOT}/profiles/${profile}.yaml"
      if [ ! -f "${f}" ]; then
        log_error "no such profile: ${profile}"
        return 1
      fi
      PROFILE_FILE="${f}" HOOK_ID="${id}" python3 - <<'PY'
import os, yaml, sys
pfile = os.environ["PROFILE_FILE"]
hook_id = os.environ["HOOK_ID"]
with open(pfile) as f:
    data = yaml.safe_load(f) or {}
hooks = data.get("hooks") or {}
removed = 0
for stage, entries in hooks.items():
    if not entries: continue
    before = len(entries)
    hooks[stage] = [e for e in entries if e.get("id") != hook_id]
    removed += before - len(hooks[stage])
if removed == 0:
    print(f"no hook with id '{hook_id}' found in {pfile}", file=sys.stderr)
    sys.exit(1)
with open(pfile) as f_orig:
    orig_lines = f_orig.readlines()
header_lines = []
for line in orig_lines:
    if line.startswith("#") or not line.strip():
        header_lines.append(line)
    else:
        break
with open(pfile, "w") as f:
    f.writelines(header_lines)
    yaml.safe_dump(data, f, sort_keys=False, default_flow_style=False)
print(f"removed {removed} hook entry(ies) with id={hook_id}")
PY
      local rc=$?
      if [ "${rc}" -ne 0 ]; then
        return "${rc}"
      fi
      log_info "  edited: ${f}"
      ;;

    *)
      log_error "unknown hooks subcommand: ${sub}"
      log_error "  available: list [<profile>] | add <stage> <script> [--id ... --mandatory --profile ...] | remove <id> [--profile <id>]"
      return 2
      ;;
  esac
}

cmd_decommission() {
  local sub="${1:-start}"
  case "${sub}" in
    --plan|plan)
      # R139 (F-11 MED closure): non-destructive preview of every
      # decommission phase. Operator rehearsal path — no env-gate
      # required (no bytes are written).
      echo
      echo "  sovereign-osctl decommission --plan"
      echo "  ==================================="
      echo "  Shows EVERY destructive operation across all 3 phases."
      echo "  Writes nothing. Operator inspects, then runs phases explicitly."
      echo
      echo "  Phase 1 — secure-wipe-context (state-fabric)"
      echo "    hook: scripts/hooks/decommission/secure-wipe-context.sh"
      echo "    target: tank/context (ZFS dataset; operator-key encrypted per SDD-022)"
      echo "    operation: 'shred -uvz' on the unlocked content, then zfs destroy"
      if command -v zfs >/dev/null 2>&1 && zfs list tank/context >/dev/null 2>&1; then
        local ctx_size
        ctx_size="$(zfs list -H -o used tank/context 2>/dev/null || echo unknown)"
        echo "    ✓ tank/context exists; size: ${ctx_size}"
      else
        echo "    (tank/context not present in this environment)"
      fi
      echo "    invoke: sovereign-osctl decommission start"
      echo
      echo "  Phase 2 — zfs-pool-destroy (whole pool)"
      echo "    hook: scripts/hooks/decommission/zfs-pool-destroy.sh"
      echo "    target: zpool '${SOVEREIGN_OS_POOL_NAME:-tank}'"
      echo "    operation: 'zpool destroy -f \${POOL}'"
      if command -v zpool >/dev/null 2>&1 && zpool list "${SOVEREIGN_OS_POOL_NAME:-tank}" >/dev/null 2>&1; then
        local pool_size pool_used
        pool_size="$(zpool list -H -o size "${SOVEREIGN_OS_POOL_NAME:-tank}" 2>/dev/null || echo unknown)"
        pool_used="$(zpool list -H -o allocated "${SOVEREIGN_OS_POOL_NAME:-tank}" 2>/dev/null || echo unknown)"
        echo "    ✓ pool '${SOVEREIGN_OS_POOL_NAME:-tank}' exists; size=${pool_size} used=${pool_used}"
      else
        echo "    (pool '${SOVEREIGN_OS_POOL_NAME:-tank}' not present in this environment)"
      fi
      echo "    invoke: SOVEREIGN_OS_CONFIRM_DESTROY=YES sovereign-osctl decommission pool"
      echo
      echo "  Phase 3 — secure-wipe (block devices)"
      echo "    hook: scripts/hooks/decommission/secure-wipe.sh"
      echo "    targets: SOVEREIGN_OS_WIPE_DEVICES (e.g. '/dev/nvme0n1 /dev/nvme1n1')"
      local wipe_devs="${SOVEREIGN_OS_WIPE_DEVICES:-(unset)}"
      echo "    currently: ${wipe_devs}"
      if [ "${wipe_devs}" != "(unset)" ]; then
        for dev in ${wipe_devs}; do
          if [ -b "${dev}" ]; then
            local d_size d_model d_serial
            d_size="$(lsblk -dn -o SIZE "${dev}" 2>/dev/null | xargs || echo ?)"
            d_model="$(lsblk -dn -o MODEL "${dev}" 2>/dev/null | xargs || echo ?)"
            d_serial="$(lsblk -dn -o SERIAL "${dev}" 2>/dev/null | xargs || echo ?)"
            echo "      ✓ ${dev}  ${d_model}  serial=${d_serial}  size=${d_size}"
          else
            echo "      ! ${dev}  NOT A BLOCK DEVICE (refused at execute time)"
          fi
        done
      else
        echo "    operator must export SOVEREIGN_OS_WIPE_DEVICES before phase 3"
      fi
      echo "    operation: 'blkdiscard' if SSD, else 'shred -vfz'"
      echo "    invoke: SOVEREIGN_OS_CONFIRM_DESTROY=YES SOVEREIGN_OS_WIPE_DEVICES='/dev/...' \\"
      echo "              sovereign-osctl decommission wipe"
      echo
      echo "  NOTHING WAS WRITTEN. Each phase requires SOVEREIGN_OS_CONFIRM_DESTROY=YES + interactive confirm."
      return 0
      ;;
    start)
      log_warn "decommission begins; this is DESTRUCTIVE."
      log_warn "  three phases:"
      log_warn "    1. wipe state-fabric (tank/context shred)"
      log_warn "    2. destroy ZFS pool"
      log_warn "    3. secure-wipe block devices"
      if ! confirm "Continue with decommission?" default-no; then
        log_info "aborted"
        return 0
      fi
      "${__REPO_ROOT}/scripts/hooks/decommission/secure-wipe-context.sh"
      log_info ""
      log_info "Phase 1 complete. To continue:"
      log_info "  SOVEREIGN_OS_CONFIRM_DESTROY=YES sudo sovereign-osctl decommission pool"
      ;;
    pool)
      SOVEREIGN_OS_CONFIRM_DESTROY="${SOVEREIGN_OS_CONFIRM_DESTROY:-}" \
        "${__REPO_ROOT}/scripts/hooks/decommission/zfs-pool-destroy.sh"
      log_info ""
      log_info "Phase 2 complete. To wipe block devices:"
      log_info "  SOVEREIGN_OS_CONFIRM_DESTROY=YES SOVEREIGN_OS_WIPE_DEVICES='/dev/...' \\"
      log_info "    sudo sovereign-osctl decommission wipe"
      ;;
    wipe)
      "${__REPO_ROOT}/scripts/hooks/decommission/secure-wipe.sh"
      log_info "decommission complete"
      ;;
    *)
      log_error "unknown decommission subcommand: ${sub}"
      cmd_help
      exit 2
      ;;
  esac
}

# ------------------------------ inference ------------------------------------

cmd_inference() {
  local sub="${1:-status}"
  shift || true

  # Map tier short-names → systemd unit names
  declare -A tier_units=(
    [pulse]="sovereign-pulse.service"
    [logic]="sovereign-logic-engine.service"
    [logic-engine]="sovereign-logic-engine.service"
    [oracle]="sovereign-oracle-core.service"
    [oracle-core]="sovereign-oracle-core.service"
    [router]="sovereign-router.service"
  )

  case "${sub}" in
    status)
      printf "%-25s %-12s %-20s %s\n" "TIER" "STATE" "ENDPOINT" "BACKEND"
      printf "%-25s %-12s %-20s %s\n" "----" "-----" "--------" "-------"
      for tier in pulse logic oracle router; do
        local unit="${tier_units[$tier]}"
        local state="not-installed"
        if systemctl list-unit-files "${unit}" >/dev/null 2>&1; then
          state="$(systemctl is-active "${unit}" 2>/dev/null || echo unknown)"
        fi
        local port endpoint backend
        case "${tier}" in
          pulse)  port=8081; backend="bitnet.cpp (CCD 0)" ;;
          logic)  port=8082; backend="vLLM (3090 VFIO) or llama.cpp" ;;
          oracle) port=8083; backend="vLLM + DFlash (Blackwell)" ;;
          router) port=8080; backend="OpenAI-compatible front" ;;
        esac
        endpoint="http://127.0.0.1:${port}"
        printf "%-25s %-12s %-20s %s\n" "${tier}" "${state}" "${endpoint}" "${backend}"
      done
      ;;

    start|stop|restart)
      local target="${1:-all}"
      shift || true
      require_root
      if [ "${target}" = "all" ]; then
        for tier in pulse logic oracle router; do
          local unit="${tier_units[$tier]}"
          if systemctl list-unit-files "${unit}" >/dev/null 2>&1; then
            log_info "${sub} ${unit}"
            systemctl "${sub}" "${unit}" || log_warn "  ${sub} failed for ${unit}"
          else
            log_warn "${unit} not installed; skipping"
          fi
        done
      else
        local unit="${tier_units[${target}]:-}"
        if [ -z "${unit}" ]; then
          log_error "unknown tier: ${target} (use pulse|logic|oracle|router|all)"
          return 2
        fi
        systemctl "${sub}" "${unit}"
      fi
      ;;

    route)
      local prompt="${*:-hello}"
      python3 - <<PY
import sys
sys.path.insert(0, "${__REPO_ROOT}/scripts/inference")
from router import classify
body = {"model": "auto", "messages": [{"role": "user", "content": """${prompt}"""}]}
print(f"would route to: {classify(body)}")
PY
      ;;

    health)
      # HTTP-probe every tier's /healthz endpoint + the router's /healthz.
      # Used by ops dashboards + operator quick-check. Falls back to TCP-
      # liveness if HTTP returns non-2xx (some backends don't expose
      # /healthz but their port being open is signal enough).
      local any_fail=0
      printf "%-15s %-25s %-10s %s\n" "TIER" "ENDPOINT" "STATUS" "DETAIL"
      printf "%-15s %-25s %-10s %s\n" "----" "--------" "------" "------"
      for tier in pulse logic oracle router; do
        local port endpoint
        case "${tier}" in
          pulse)  port=8081 ;;
          logic)  port=8082 ;;
          oracle) port=8083 ;;
          router) port=8080 ;;
        esac
        endpoint="http://127.0.0.1:${port}"

        # Try /healthz first
        local status detail
        local rc=1
        if command -v curl >/dev/null 2>&1; then
          local code; code="$(curl -s -o /dev/null -w '%{http_code}' --max-time 3 "${endpoint}/healthz" 2>/dev/null || echo 000)"
          if [ "${code}" = "200" ]; then
            status="✓ ok"; detail="200 /healthz"; rc=0
          elif [ "${code}" = "000" ]; then
            # Try TCP fallback
            if (echo >/dev/tcp/127.0.0.1/"${port}") 2>/dev/null; then
              status="~ tcp"; detail="port open, /healthz unreachable"; rc=0
            else
              status="✗ down"; detail="no listener"; rc=1
            fi
          else
            status="? code"; detail="${code} /healthz"; rc=1
          fi
        else
          # curl absent — pure-bash TCP probe via /dev/tcp
          if (echo >/dev/tcp/127.0.0.1/"${port}") 2>/dev/null; then
            status="~ tcp"; detail="port open (no curl for /healthz)"; rc=0
          else
            status="✗ down"; detail="no listener (no curl for /healthz)"; rc=1
          fi
        fi
        [ "${rc}" -ne 0 ] && any_fail=1
        printf "%-15s %-25s %-10s %s\n" "${tier}" "${endpoint}" "${status}" "${detail}"
      done
      [ "${any_fail}" -eq 0 ] && return 0 || return 1
      ;;

    logs)
      local target="${1:?usage: inference logs <pulse|logic|oracle|router>}"
      local unit="${tier_units[${target}]:-}"
      if [ -z "${unit}" ]; then
        log_error "unknown tier: ${target}"
        return 2
      fi
      journalctl -u "${unit}" -f --no-pager
      ;;

    *)
      log_error "unknown inference subcommand: ${sub}"
      cmd_help
      exit 2
      ;;
  esac
}

# ------------------------------ version --------------------------------------

cmd_version() {
  local sovereign_version="0.3.0"
  local phase="Stage-2 operator-observability + hardening complete"
  local active_profile="${SOVEREIGN_OS_PROFILE:-unknown}"
  local active_whitelabel="default"
  [ -r /etc/sovereign-os/active-whitelabel ] && \
    active_whitelabel="$(cat /etc/sovereign-os/active-whitelabel)"
  local kernel_release; kernel_release="$(uname -r)"
  local os_pretty="unknown"
  if [ -r /etc/os-release ]; then
    os_pretty="$(grep PRETTY_NAME /etc/os-release | cut -d= -f2- | tr -d '"')"
  fi

  if [ "${1:-}" = "--json" ]; then
    # Machine-readable for fleet tooling. Stable field set.
    cat <<EOF
{
  "sovereign_osctl_version": "${sovereign_version}",
  "phase": "${phase}",
  "active_profile": "${active_profile}",
  "active_whitelabel": "${active_whitelabel}",
  "kernel_release": "${kernel_release}",
  "os_pretty_name": "${os_pretty}",
  "repo": "https://github.com/cyberpunk042/sovereign-os"
}
EOF
  else
    echo "sovereign-osctl ${sovereign_version} (${phase})"
    echo "active profile:    ${active_profile}"
    echo "active whitelabel: ${active_whitelabel}"
    echo "kernel release:    ${kernel_release}"
    echo "OS:                ${os_pretty}"
  fi
}

# ------------------------------ dispatch -------------------------------------

cmd="${1:-help}"
shift || true

case "${cmd}" in
  status)        cmd_status "$@" ;;
  doctor)        cmd_doctor "$@" ;;
  assistant)     cmd_assistant "$@" ;;
  profiles)      cmd_profiles "$@" ;;
  whitelabel)    cmd_whitelabel "$@" ;;
  perimeter)     cmd_perimeter "$@" ;;
  models)        cmd_models "$@" ;;
  audit)         cmd_audit "$@" ;;
  hooks)         cmd_hooks "$@" ;;
  maintenance)   cmd_maintenance "$@" ;;
  decommission)  cmd_decommission "$@" ;;
  install)       cmd_install "$@" ;;
  secure-boot)   cmd_secure_boot "$@" ;;
  init)          cmd_init "$@" ;;
  env)           cmd_env "$@" ;;
  inference)     cmd_inference "$@" ;;
  metrics)       cmd_metrics "$@" ;;
  alerts)        cmd_alerts "$@" ;;
  journal)       cmd_journal "$@" ;;
  history)       cmd_history "$@" ;;
  version|--version|-V) cmd_version "$@" ;;
  help|--help|-h|"") cmd_help ;;
  *)
    log_error "unknown command: ${cmd}"
    cmd_help
    exit 2
    ;;
esac
