import json, os, sys
path = sys.argv[1]
try:
  n = int(sys.argv[2])
except (ValueError, IndexError):
  n = 20
if n < 1: n = 20
out = {
  "module": "auditor",
  "verb": "history",
  "spec_ref": "master spec § 10 (Native Guardian Loop)",
  "log_path": path,
  "present": os.path.isfile(path),
  "requested_n": n,
  "sovereignty_boundary": "operator §17 — read-only; neutralization is CCD-triggered + CLI-gated",
  "count": 0,
  "lines": [],
}
if out["present"]:
  try:
    with open(path, "r", encoding="utf-8", errors="replace") as fh:
      lines = fh.readlines()
    tail = lines[-n:] if n <= len(lines) else lines
    out["lines"] = [ln.rstrip("\n") for ln in tail]
    out["count"] = len(out["lines"])
    out["total_lines"] = len(lines)
  except OSError as e:
    out["error"] = f"{type(e).__name__}: {e}"
print(json.dumps(out, indent=2))
PY
        else
          if [ -f "${_AUDITOR_LOG}" ]; then
            tail -"${_AUDITOR_N}" "${_AUDITOR_LOG}" 2>/dev/null || {
