import json, os, sys
path = sys.argv[1]
out = {
  "module": "auditor",
  "verb": "last-violation",
  "spec_ref": "master spec § 10 (Native Guardian Loop)",
  "log_path": path,
  "present": os.path.isfile(path),
  "sovereignty_boundary": "operator §17 — read-only; neutralization is CCD-triggered + CLI-gated",
  "line": None,
}
if out["present"]:
  try:
    with open(path, "r", encoding="utf-8", errors="replace") as fh:
      lines = fh.readlines()
    out["line"] = lines[-1].rstrip("\n") if lines else None
    out["total_lines"] = len(lines)
  except OSError as e:
    out["error"] = f"{type(e).__name__}: {e}"
print(json.dumps(out, indent=2))
PY
        else
