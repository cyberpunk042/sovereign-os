# Pulse — Vector Core (CCD0; AVX-512; bitnet.cpp; Wasm AOT)
_trinity_pulse_brief() {
  echo "  [Pulse] — Vector Core (master spec § 17 Module 1; CCD0 cores 0-5)"
  local avx512="absent"
  if grep -q "avx512_vnni" /proc/cpuinfo 2>/dev/null; then
    avx512="present (vnni)"
    grep -q "avx512_bf16" /proc/cpuinfo 2>/dev/null && avx512="${avx512} + bf16"
  fi
  echo "    AVX-512 ISA:        ${avx512}"
  local bitnet_running="not running"
  if systemctl is-active --quiet sovereign-pulse 2>/dev/null; then
    bitnet_running="active (sovereign-pulse.service)"
  fi
  echo "    pulse service:      ${bitnet_running}"
  echo "    backend file:       scripts/inference/backends/bitnet.py"
  echo "    start script:       scripts/inference/start-pulse.sh"
}

_trinity_pulse_full() {
  echo "  [Pulse] — Vector Core (master spec § 17 Module 1, § 20 Wasm-to-AVX-512 AOT)"
  echo
  echo "  PHYSICAL PINNING (master spec § 19.2):"
  echo "    CCD0 cores 0-5; thread mask 0xfff (threads 0-11)"
  echo "    isolation from CCD1 to avoid Infinity Fabric latency"
  echo
  echo "  CPUINFO:"
  grep -E "model name|cpu cores|cache size" /proc/cpuinfo 2>/dev/null | head -3 | sed 's/^/    /'
  echo
  echo "  AVX-512 instruction set markers:"
  for flag in avx512f avx512dq avx512bw avx512vl avx512bf16 avx512fp16 avx512_vnni; do
    if grep -qw "${flag}" /proc/cpuinfo 2>/dev/null; then
      echo "    ✓ ${flag}"
    else
      echo "    ✗ ${flag} (master spec demands this; pulse will be degraded)"
    fi
  done
  echo
  echo "  RUNTIME (when built — R152+):"
  echo "    bitnet.cpp                 → 1-bit/ternary BitNet-b1.58 native execution"
  echo "    Wasm AOT (Cranelift/LLVM)  → znver5 target; pulse_core.wasm"
  echo
  echo "  SERVICE STATE:"
  if command -v systemctl >/dev/null 2>&1; then
    systemctl status sovereign-pulse 2>/dev/null | head -5 | sed 's/^/    /' || \
      echo "    sovereign-pulse.service not installed (R152 wires this)"
  fi
  echo
  echo "  LAYER B METRICS (where to look):"
  echo "    sovereign_os_inference_route_total{tier=\"pulse\"}"
  echo "    sovereign_os_inference_backend_start_total{tier=\"pulse\",backend=\"bitnet\"}"
  echo "    sovereign_os_inference_backend_pid{tier=\"pulse\"}"
}

# Weaver — Sandboxed Fabric (CCD1 cores 6-9; Podman + VFIO + atomic state)
_trinity_weaver_brief() {
  echo "  [Weaver] — Sandboxed Fabric (master spec § 17 Module 2; CCD1 cores 6-9)"
  local podman_state="not installed"
  command -v podman >/dev/null 2>&1 && podman_state="$(podman --version 2>/dev/null | head -1)"
  echo "    podman:             ${podman_state}"
  local vfio_state="unknown"
  if [ -d /sys/bus/pci/drivers/vfio-pci ]; then
    local vfio_count
    vfio_count="$(ls /sys/bus/pci/drivers/vfio-pci/[0-9]* 2>/dev/null | wc -l)"
    vfio_state="vfio-pci loaded; ${vfio_count} device(s) bound"
  fi
  echo "    vfio:               ${vfio_state}"
  local ctx_state="absent"
  command -v zfs >/dev/null 2>&1 && zfs list tank/context >/dev/null 2>&1 && {
    local sync_setting; sync_setting="$(zfs get -H -o value sync tank/context 2>/dev/null)"
    ctx_state="present; sync=${sync_setting}"
  }
  echo "    tank/context:       ${ctx_state}"
}

_trinity_weaver_full() {
  echo "  [Weaver] — Sandboxed Fabric (master spec § 17 Module 2, § 21 Atomic State Protocol)"
  echo
  echo "  PHYSICAL PINNING (master spec § 19.2):"
  echo "    CCD1 cores 6-9; thread mask 0xff000 (threads 12-19)"
  echo "    handles state engine + Tetragon gRPC + network I/O"
  echo
  echo "  PODMAN:"
  if command -v podman >/dev/null 2>&1; then
    podman --version 2>/dev/null | sed 's/^/    /'
    podman info --format "    rootless: {{.Host.Security.Rootless}}, runtime: {{.Host.OCIRuntime.Name}}" 2>/dev/null
  else
    echo "    not installed (apt install podman)"
  fi
  echo
  echo "  VFIO (RTX 3090 sandbox per master spec § 4.3):"
  if [ -d /sys/bus/pci/drivers/vfio-pci ]; then
    echo "    vfio-pci loaded"
    for dev in /sys/bus/pci/drivers/vfio-pci/[0-9]*; do
      [ -e "${dev}" ] || continue
      local addr; addr="$(basename "${dev}")"
      local devid; devid="$(cat "${dev}/device" 2>/dev/null)"
      local vendid; vendid="$(cat "${dev}/vendor" 2>/dev/null)"
      echo "    ✓ ${addr}  vendor=${vendid:-?} device=${devid:-?}"
    done
  else
    echo "    vfio-pci not loaded (modprobe vfio-pci or check kernel cmdline)"
  fi
  echo
  echo "  STATE FABRIC (master spec § 7 — tank/context dataset):"
  if command -v zfs >/dev/null 2>&1 && zfs list tank/context >/dev/null 2>&1; then
    echo "    ✓ tank/context dataset"
    for prop in sync primarycache logbias compression copies; do
      local v; v="$(zfs get -H -o value "${prop}" tank/context 2>/dev/null)"
      echo "      ${prop}: ${v}"
    done
  else
    echo "    tank/context dataset: absent (zfs-tiered profile not yet installed?)"
  fi
  echo
  echo "  VIBE STATE FILES (master spec § 7 — operator-readable):"
  for fname in IDENTITY.md SOUL.md AGENTS.md CLAUDE.md; do
    if [ -f "/mnt/vault/context/${fname}" ]; then
      echo "    ✓ /mnt/vault/context/${fname}"
    else
      echo "    ✗ /mnt/vault/context/${fname} (absent; lands when zfs-tiered installed)"
    fi
  done
  echo
  echo "  ATOMIC STATE PROTOCOL (R154):"
  echo "    Not yet built — scripts/weaver/atomic-state.py per master spec § 21.1"
}

# Auditor — Immutable Gatekeeper (always-on; Tetragon eBPF + Guardian)
_trinity_auditor_brief() {
  echo "  [Auditor] — Immutable Gatekeeper (master spec § 17 Module 3)"
  local tetra_state="not installed"
  if command -v tetragon >/dev/null 2>&1; then
    if systemctl is-active --quiet tetragon 2>/dev/null; then
      tetra_state="active"
    else
      tetra_state="installed but inactive"
    fi
  fi
  echo "    tetragon:           ${tetra_state}"
  local guardian_state="not built (R155)"
  [ -x /usr/local/bin/guardian-core ] && {
    if systemctl is-active --quiet guardian-core 2>/dev/null; then
      guardian_state="installed + active"
    else
      guardian_state="installed but inactive"
    fi
  }
  echo "    guardian-core:      ${guardian_state}"
  local policy="absent"
  [ -f /etc/tetragon/sovereign-perimeter.yaml ] && policy="loaded (sovereign-kernel-fence)"
  echo "    tetragon policy:    ${policy}"
}

_trinity_auditor_full() {
  echo "  [Auditor] — Immutable Gatekeeper (master spec § 17 Module 3, § 10 Native Guardian Loop)"
  echo
  echo "  TETRAGON (kernel-level eBPF):"
  if command -v tetragon >/dev/null 2>&1; then
    echo "    tetragon binary present"
    systemctl is-active tetragon 2>/dev/null | sed 's/^/    state: /'
    systemctl is-enabled tetragon 2>/dev/null | sed 's/^/    boot:  /'
  else
    echo "    NOT installed — see scripts/hooks/post-install/tetragon-policy-load.sh"
  fi
  echo
  echo "  POLICY (master spec § 6 — sovereign-kernel-fence):"
  if [ -f /etc/tetragon/sovereign-perimeter.yaml ]; then
    echo "    ✓ /etc/tetragon/sovereign-perimeter.yaml present"
  else
    echo "    ✗ policy file absent"
    echo "      apply via: scripts/hooks/post-install/tetragon-policy-load.sh"
  fi
  echo
  echo "  GUARDIAN DAEMON (master spec § 10 — R155, not yet built):"
  if [ -x /usr/local/bin/guardian-core ]; then
    echo "    ✓ /usr/local/bin/guardian-core present"
    systemctl is-active guardian-core 2>/dev/null | sed 's/^/    state: /'
  else
    echo "    NOT yet implemented — tracked in R155"
    echo "    when built: reads /var/run/tetragon/tetragon.events;"
    echo "    SIGKILL on policy violation via 'podman kill';"
    echo "    atomic append to /mnt/vault/context/security_audit.log"
  fi
  echo
  echo "  RECENT VIOLATIONS:"
  if [ -f /mnt/vault/context/security_audit.log ]; then
    tail -5 /mnt/vault/context/security_audit.log 2>/dev/null | sed 's/^/    /' || \
      echo "    (audit log empty)"
  else
    echo "    audit log not present (security_audit.log)"
  fi
  echo
  echo "  LAYER B METRICS:"
  echo "    sovereign_os_perimeter_status (1=active, 0=inactive)"
  echo "    sovereign_os_perimeter_verify_last_run_timestamp"
}

# Trinity runtime-profile picker (master spec § 18: Ultra-Sovereign /
# High-Concurrency / Deep Context). YAMLs at `profiles/runtime/*.yaml`;
# active profile recorded at /etc/sovereign-os/active-runtime-profile
# (or per-operator fallback at ~/.sovereign-os/active-runtime-profile).

_trinity_profile() {
  local sub="${1:-list}"
  shift || true
  local runtime_dir="${__REPO_ROOT}/profiles/runtime"
  local active_file="/etc/sovereign-os/active-runtime-profile"
  [ -w /etc 2>/dev/null ] || active_file="${HOME}/.sovereign-os/active-runtime-profile"

  case "${sub}" in
    list)
      if [ ! -d "${runtime_dir}" ]; then
        log_error "runtime profiles dir missing: ${runtime_dir}"
        return 1
      fi
      echo "  Runtime profiles (master spec § 18):"
      echo
      local active=""
      [ -f "${active_file}" ] && active="$(cat "${active_file}")"
      for f in "${runtime_dir}"/*.yaml; do
        [ -f "${f}" ] || continue
        local id name desc
        id="$(basename "$f" .yaml)"
        name="$(grep '^\s*name:' "${f}" | head -1 | sed 's/.*name:\s*//' | tr -d '"')"
        local marker="  "
        [ "${id}" = "${active}" ] && marker="* "
        printf "  %s%-30s %s\n" "${marker}" "${id}" "${name}"
      done
      echo
      echo "  * = currently active"
      echo "  detail: sovereign-osctl trinity profile show <id>"
      ;;
    show)
      local id="${1:-}"
      if [ -z "${id}" ]; then
        log_error "usage: sovereign-osctl trinity profile show <id>"
        return 2
      fi
      local f="${runtime_dir}/${id}.yaml"
      if [ ! -f "${f}" ]; then
        log_error "no such runtime profile: ${id}"
        log_error "  available: $(ls ${runtime_dir}/*.yaml 2>/dev/null | xargs -n1 basename | sed 's/\.yaml//' | tr '\n' ' ')"
        return 1
      fi
      RUNTIME_FILE="${f}" python3 - <<'PY'
import os, yaml
with open(os.environ["RUNTIME_FILE"]) as fh:
    data = yaml.safe_load(fh) or {}
rp = data.get("runtime_profile", {})
print(f"  id:            {rp.get('id', '?')}")
print(f"  name:          {rp.get('name', '?')}")
print(f"  description:")
for line in (rp.get('description') or '').splitlines():
    print(f"    {line}")
print(f"  hardware compat:  {', '.join(rp.get('hardware_profile_compat', []))}")
print()
print(f"  ALLOCATIONS ({len(rp.get('allocations') or [])}):")
for a in rp.get('allocations') or []:
    print(f"    {a.get('agent_id', '?')}")
    print(f"      target_hardware:   {a.get('target_hardware', '?')}")
    if a.get('core_mask'):
        print(f"      core_mask:         {a['core_mask']}")
    if a.get('vram_limit_bytes'):
        gb = a['vram_limit_bytes'] / 1024**3
        print(f"      vram_limit:        {gb:.1f} GB")
    if a.get('tensor_parallel_size'):
        print(f"      tensor_parallel:   {a['tensor_parallel_size']}")
    if a.get('kv_cache_dtype'):
        print(f"      kv_cache_dtype:    {a['kv_cache_dtype']}")
    print(f"      engine:            {a.get('engine', '?')}")
    print(f"      model:             {a.get('model', '?')}")
print()
gpu_state = rp.get('gpu_state') or {}
if gpu_state:
    print(f"  GPU STATE:")
    for slot in ('primary', 'secondary'):
        g = gpu_state.get(slot, {})
        if g:
            print(f"    {slot}: {g.get('mode', '?')}  ({g.get('command', '')})")
power = rp.get('expected_power_draw_watts') or {}
if power:
    print()
    print(f"  EXPECTED POWER:")
    for k, v in power.items():
        print(f"    {k:<20} {v} W")
obs = rp.get('observability') or {}
if obs:
    print()
    print(f"  OBSERVABILITY:")
    for k, v in obs.items():
        print(f"    {k}: {v}")
PY
      ;;
    active)
      if [ -f "${active_file}" ]; then
        cat "${active_file}"
      else
        echo "(none)"
        echo "  no active runtime profile set; pick one with: sovereign-osctl trinity profile switch <id>"
      fi
      ;;
    switch)
      local id="${1:-}"
      if [ -z "${id}" ]; then
        log_error "usage: sovereign-osctl trinity profile switch <id>"
        return 2
      fi
      local f="${runtime_dir}/${id}.yaml"
      if [ ! -f "${f}" ]; then
        log_error "no such runtime profile: ${id}"
        return 1
      fi
      mkdir -p "$(dirname "${active_file}")" 2>/dev/null || true
      echo "${id}" > "${active_file}"
      log_info "active runtime profile set to: ${id}"
      log_info "  (R151 wires start scripts to honor this; until then the YAML is the contract)"
      ;;
    *)
      log_error "unknown trinity profile subcommand: ${sub}"
      log_error "  available: list | show <id> | active | switch <id>"
      return 2
      ;;
  esac
}

# ------------------------------ secure-boot ----------------------------------
#
# R143 (F-05 MED closure): SDD-015 'signed' posture requires operator-
# owned PK/KEK/db keys (NEVER in-repo per SDD-015 § Operator-supplied
# keys). Without this verb operators had to manually openssl + sbsign
# + KeyTool the whole chain. Most skipped the 'signed' posture
# because of that friction.
#
# This verb generates the key triple with sane defaults, writes them
# OUTSIDE the repo root (hard refusal otherwise), and prints the
# enrollment commands. Operator backs them up; sovereign-os never
# sees them again.

# ----------------------------------------------------------------------------
# bootstrap — Master Bootstrap Verification Checklist (master spec § 22).
# ----------------------------------------------------------------------------
cmd_wizard() {
  # R169: cross-repo mirror of selfdef SD-R11 wizard.
  # First-time-operator walkthrough — probes hardware, recommends a
  # sovereign-os profile, surfaces the next-step commands. Pure-read.
  local script
  script="$(dirname "${BASH_SOURCE[0]}")/wizard/onboard.py"
  if [ ! -x "${script}" ]; then
    log_error "wizard script missing or not executable: ${script}"
    return 1
  fi
  exec python3 "${script}" "$@"
}

cmd_bootstrap() {
  local sub="${1:-verify}"
  shift || true

  case "${sub}" in
    verify)
      local verify_script
      verify_script="$(dirname "${BASH_SOURCE[0]}")/bootstrap/verify.sh"
      if [ ! -x "${verify_script}" ]; then
        log_error "bootstrap verify script missing or not executable: ${verify_script}"
        return 1
      fi
      exec "${verify_script}" "$@"
      ;;
    phases)
      local phases_script
      phases_script="$(dirname "${BASH_SOURCE[0]}")/bootstrap/phases.sh"
      if [ ! -x "${phases_script}" ]; then
        log_error "bootstrap phases script missing or not executable: ${phases_script}"
        return 1
      fi
      exec "${phases_script}" "$@"
      ;;
    docs-grid)
      # R207: regenerate docs/src/bootstrap-verify-grid.md from verify-grid.yaml.
      # Companion to `bootstrap docs` (phases) — same SDD-028 pattern.
      local grid_render
      grid_render="$(dirname "${BASH_SOURCE[0]}")/bootstrap/lib/render-verify-grid-md.py"
      if [ ! -x "${grid_render}" ]; then
        log_error "verify-grid doc renderer missing: ${grid_render}"
        return 1
      fi
      exec python3 "${grid_render}" "$@"
      ;;
    docs)
      # R203: regenerate docs/src/bootstrap-phases.md from phases.yaml.
      # Operators rebuild the operator-readable phase rundown after
      # editing the canonical YAML — same source feeds inventory + run.
      local render_script
      render_script="$(dirname "${BASH_SOURCE[0]}")/bootstrap/lib/render-phases-md.py"
      if [ ! -x "${render_script}" ]; then
        log_error "phase doc renderer missing or not executable: ${render_script}"
        return 1
      fi
      exec python3 "${render_script}" "$@"
      ;;
    run)
      # R201: master spec § 12 phase executor — DRY-RUN-ONLY first cut.
      # Emits the execution plan + classifies each artifact's runtime
      # surface (build-step / installer-hook / post-install-hook /
      # recurrent-hook / systemd-unit / tooling). Real --apply is a
      # follow-up round gated behind SOVEREIGN_OS_CONFIRM_DESTROY + L5.
      local run_script
      run_script="$(dirname "${BASH_SOURCE[0]}")/bootstrap/run.sh"
      if [ ! -x "${run_script}" ]; then
        log_error "bootstrap run script missing or not executable: ${run_script}"
        return 1
      fi
      exec "${run_script}" "$@"
      ;;
    hardware-match)
      # R166: cross-repo mirror of selfdef SDD-017 Sain01Match.
      # Same logic, same dimensions, same exit codes — operators can
      # ask "is THIS box the SAIN-01 spec?" from either CLI.
      local match_script
      match_script="$(dirname "${BASH_SOURCE[0]}")/hardware/sain01-match.py"
      if [ ! -x "${match_script}" ]; then
        log_error "hardware match script missing or not executable: ${match_script}"
        return 1
      fi
      exec python3 "${match_script}" "$@"
      ;;
    posture)
      # R210: cross-repo bridge to selfdef SD-R67 `selfdefctl
      # hardware posture`. Reads the saved capabilities JSON the
      # selfdef daemon emits at /var/lib/selfdef/hardware-capabilities
      # .json and renders the same operator-readable posture summary.
      # No selfdefctl required — sovereign-os boxes can introspect
      # their hardware-exploit readiness even without the selfdef
      # CLI installed (as long as the daemon dropped the JSON).
      local posture_script
      posture_script="$(dirname "${BASH_SOURCE[0]}")/hardware/posture.py"
      if [ ! -x "${posture_script}" ]; then
        log_error "posture script missing or not executable: ${posture_script}"
        return 1
      fi
      exec python3 "${posture_script}" "$@"
      ;;
    -h|--help|help)
      cat <<EOF
sovereign-osctl bootstrap — Master Bootstrap Verification + Pipeline surface

Subverbs:
  verify [--only IDS] [--json] [--strict]
    Run the master spec § 22 6-check operational grid (LIVE node):
      01 Microcode/ISA   02 Bus Geometry   03 Linux Memory (ZFS ARC)
      04 Driver Fabric   05 Security Core  06 Network Line (Jumbo MTU)
    Exit 1 if any check FAILs → master spec § 22 lock-state.

  phases [--phase N] [--json]
    Inventory the master spec § 12 chronological 5-phase pipeline
    (AUTHORING-time artifact presence in-repo):
      I    Minimal Trixie Base
      II   Zen 5 Kernel Compilation
      III  Storage Layer + DKMS (ZFS)

  docs-grid [--check|--stdout]   (R207, verify-grid doc generator)
    Regenerate docs/src/bootstrap-verify-grid.md from
    config/bootstrap/verify-grid.yaml. Same SDD-028 pattern.

  docs [--check|--stdout]   (R203, doc generator)
    Regenerate docs/src/bootstrap-phases.md from config/bootstrap/
    phases.yaml. The doc renders the master spec § 12 phase rundown
    with preconditions, postconditions, and artifact lists. --check
    fails (rc=1) if the on-disk doc is stale (used by CI to gate
    accidental drift).

  run [--phase N|all] [--json]   (R201, DRY-RUN-ONLY first cut)
    Emit the execution plan for one (or all) master spec § 12 phases:
    enumerate every artifact + classify its runtime surface
    (build-step / installer-hook / post-install-hook / recurrent-hook
    / systemd-unit / tooling). --apply is intentionally NOT wired:
    Phase III-V artifacts are destructive (zfs-pool-create wipes NVMe,
    vfio-bind detaches the 3090, tetragon-policy-load installs kernel
    BPF). Real execution lives at Layer 5 on the SAIN-01 box behind
    SOVEREIGN_OS_CONFIRM_DESTROY=YES + interactive prompt.

  posture [--caps-path PATH] [--json]   (R210, SD-R67 bridge)
    Render the operator-readable hardware-exploit posture summary
    from the selfdef-emitted capabilities JSON. Composes SD-R64
    (ternary_aot_capable + ZMM INT8 lane width) + SD-R66 (kernel
    selection hint) into a one-screen "does this box exploit the
    AVX-512 + ZMM hot path?" answer. No selfdefctl required —
    sovereign-os reads the JSON the daemon dropped at
    /var/lib/selfdef/hardware-capabilities.json.

  hardware-match [--json] [--verdict-only]
    Cross-repo mirror of selfdef SDD-017 Sain01Match (R166):
    probe CPU/memory/GPU/PCIe/motherboard and report the 5-dimensional
    fitness verdict (FullMatch / PartialMatch / NoMatch) against the
    SAIN-01 hardware spec. Same logic as selfdef-side; exit 0 on
    Full/Partial, 2 on NoMatch.
      IV   Container + Network Edge Isolation
      V    Tetragon + Guardian + State Fabric

Env vars:
  BOOTSTRAP_VERIFY_STRICT=1        promote SKIPs to FAILs (real SAIN-01)
  BOOTSTRAP_VERIFY_DATA_IFACE=...  override the data NIC (default: enp5s0)
  BOOTSTRAP_VERIFY_ARC_MAX_BYTES=  override expected ARC max
EOF
      ;;
    *)
      log_error "unknown bootstrap subverb: ${sub}"
      return 2
      ;;
  esac
}

cmd_secure_boot() {
  local sub="${1:-status}"
  shift || true

  case "${sub}" in
    gen-keys)
      local out_dir="" cn=""
      while [ $# -gt 0 ]; do
        case "$1" in
          --out) out_dir="${2:-}"; shift 2 ;;
          --cn)  cn="${2:-}"; shift 2 ;;
          -*)    log_error "unknown gen-keys flag: $1"; return 2 ;;
          *)     shift ;;
        esac
      done
      if [ -z "${out_dir}" ]; then
        log_error "usage: sovereign-osctl secure-boot gen-keys --out <dir> [--cn <common-name>]"
        log_error "  --out is REQUIRED. operator-owned keys MUST land outside the repo."
        return 2
      fi
      # Reject if --out is under repo root
      local out_abs repo_abs
      out_abs="$(readlink -f "${out_dir}" 2>/dev/null || echo "${out_dir}")"
      repo_abs="$(readlink -f "${__REPO_ROOT}" 2>/dev/null || echo "${__REPO_ROOT}")"
      case "${out_abs}" in
        "${repo_abs}"*)
          log_error "HARD REFUSAL — --out ${out_abs} is under the sovereign-os repo root (${repo_abs})"
          log_error "  operator-supplied keys MUST NEVER live in-repo per SDD-015."
          log_error "  pick a location outside the repo (e.g. ~/.sovereign-os/secure-boot-keys/)"
          return 1
          ;;
      esac
      # Require openssl
      if ! command -v openssl >/dev/null 2>&1; then
        log_error "openssl is required to generate keys (apt install openssl)"
        return 1
      fi
      mkdir -p "${out_dir}"
      [ -z "${cn}" ] && cn="sovereign-os-$(hostname -s 2>/dev/null || echo host)"
      log_warn "GENERATING OPERATOR-OWNED secure-boot keys (4096-bit RSA, 10-year validity)"
      log_warn "  CN: ${cn}"
      log_warn "  out: ${out_dir}"
      log_warn ""

      # Generate three key/cert pairs: PK, KEK, db
      local key_type
      for key_type in PK KEK db; do
        local subj="/CN=${cn} ${key_type}/"
        log_info "  generating ${key_type}..."
        openssl req -new -x509 -newkey rsa:4096 -nodes -days 3650 \
          -subj "${subj}" \
          -keyout "${out_dir}/${key_type}.key" \
          -out    "${out_dir}/${key_type}.crt" >/dev/null 2>&1
        chmod 0600 "${out_dir}/${key_type}.key"
        # Convert .crt → .cer (DER) for UEFI enrollment
        openssl x509 -in "${out_dir}/${key_type}.crt" \
          -outform DER -out "${out_dir}/${key_type}.cer" 2>/dev/null
      done

      # Generate ESL + auth payloads for `efi-updatevar` if sbsigntools present
      if command -v cert-to-efi-sig-list >/dev/null 2>&1 && command -v sign-efi-sig-list >/dev/null 2>&1; then
        for key_type in PK KEK; do
          cert-to-efi-sig-list -g "$(uuidgen 2>/dev/null || echo "00000000-0000-0000-0000-000000000000")" \
            "${out_dir}/${key_type}.crt" "${out_dir}/${key_type}.esl" 2>/dev/null
          sign-efi-sig-list -k "${out_dir}/${key_type}.key" -c "${out_dir}/${key_type}.crt" \
            "${key_type}" "${out_dir}/${key_type}.esl" "${out_dir}/${key_type}.auth" 2>/dev/null
        done
        log_info "  .esl + .auth payloads generated for efi-updatevar enrollment"
      else
        log_warn "  cert-to-efi-sig-list / sign-efi-sig-list not present —"
        log_warn "  install: apt install efitools  — then re-run for .esl/.auth payloads"
      fi

      # Write a README inside the out dir to remind operator of the contract
      cat > "${out_dir}/README.md" <<EOF
# sovereign-os operator-owned secure-boot keys

Generated by \`sovereign-osctl secure-boot gen-keys\` on $(date -u --iso-8601=seconds).

**SDD-015 / Operator-supplied keys posture**: these keys are YOURS.
Sovereign-os ships no central CA, no key escrow, no recovery path.
If you lose them you cannot sign updates to this system.

**WHAT TO DO NOW**:

1. Back these files up (encrypted offline storage — YubiKey HSM,
   air-gapped USB, etc.) BEFORE rebooting.
2. To enroll on a system in setup-mode UEFI:

   \`\`\`sh
   # in setup-mode (PK absent)
   sudo efi-updatevar -e -f db.auth db
   sudo efi-updatevar -e -f KEK.auth KEK
   sudo efi-updatevar -f PK.auth PK     # locks the chain; do PK LAST
   \`\`\`

   On hardware where setup-mode requires firmware-menu interaction,
   use \`KeyTool.efi\` from sbsigntools.

3. Then sign your kernel + initramfs:

   \`\`\`sh
   sudo sbsign --key ${out_dir}/db.key --cert ${out_dir}/db.crt \\
     --output /boot/vmlinuz-signed /boot/vmlinuz-\$(uname -r)
   \`\`\`

4. Set the sovereign-os profile to \`kernel.cmdline.secure_boot: signed\`
   in your profile YAML; tell the orchestrator about your db key via
   \`SOVEREIGN_OS_DB_KEY\` and \`SOVEREIGN_OS_DB_CERT\`.

**KEY HYGIENE**:
  - Never commit these files to any repo (including sovereign-os).
  - Rotate annually; chain-rotation uses the prior PK to sign the new PK.
  - If a key is lost, the only recovery is firmware factory-reset
    (operator workflow; outside sovereign-os scope).
EOF
      echo
      log_info "key triple generated. files in ${out_dir}/:"
      log_info "  PK.{key,crt,cer,esl,auth}  KEK.{key,crt,cer,esl,auth}  db.{key,crt,cer}"
      log_info "  README.md — enrollment + backup contract"
      log_warn ""
      log_warn "BACK THESE UP NOW. sovereign-os never sees them again."
      log_warn "see ${out_dir}/README.md for enrollment commands."
      ;;

    status)
      echo "  secure-boot status:"
      if [ -d /sys/firmware/efi ]; then
        echo "    UEFI:       yes (/sys/firmware/efi present)"
      else
        echo "    UEFI:       no (BIOS or container)"
      fi
      if [ -r /sys/firmware/efi/efivars/SecureBoot-* ] 2>/dev/null; then
        # last byte = 0 disabled, 1 enabled
        local sb_byte
        sb_byte="$(od -An -t u1 /sys/firmware/efi/efivars/SecureBoot-* 2>/dev/null | tail -1 | awk '{print $NF}')"
        if [ "${sb_byte}" = "1" ]; then
          echo "    SecureBoot: ENABLED"
        else
          echo "    SecureBoot: disabled"
        fi
      else
        echo "    SecureBoot: status unreadable (no efivars or insufficient privilege)"
      fi
      if command -v mokutil >/dev/null 2>&1; then
        echo "    MOK:        $(mokutil --sb-state 2>/dev/null || echo unknown)"
        local mok_count; mok_count="$(mokutil --list-enrolled 2>/dev/null | grep -c '^---' || echo 0)"
        echo "    MOK keys enrolled: ${mok_count}"
      else
        echo "    MOK:        mokutil not installed"
      fi
      ;;

    *)
      log_error "unknown secure-boot subcommand: ${sub}"
      log_error "  available: gen-keys --out <dir> [--cn <name>] | status"
      return 2
      ;;
  esac
}

# ------------------------------ install --------------------------------------
#
# Round 134 (F-01 CRIT closure): safety-gated wrapper around `dd` for
# dumping a built sovereign-os image onto a target device. Replaces
# the install-runbook's raw `sudo dd if=... of=...` instruction.
#
# Gates (ALL must pass before any byte is written):
#   1. Image file exists + is non-empty + is a regular file
#   2. Target device exists + is a block device
#   3. Target is NOT a partition (must be the whole disk)
#   4. Target is NOT the currently-mounted root or its parent
#   5. SOVEREIGN_OS_CONFIRM_DESTROY=YES
#   6. Interactive confirm (unless SOVEREIGN_OS_NONINTERACTIVE=1)
#
# --plan mode: show what WOULD happen + device fingerprint, exit 0,
# never write a byte. Operator runs this first to inspect.

cmd_install() {
  local sub="${1:-help}"
  shift || true

  case "${sub}" in
    image)
      local plan_only=0
      local image=""
      local device=""
      while [ $# -gt 0 ]; do
        case "$1" in
          --plan) plan_only=1; shift ;;
          --to)   device="${2:-}"; shift 2 ;;
          --)     shift; break ;;
          -*)     log_error "unknown install image flag: $1"; return 2 ;;
          *)      if [ -z "${image}" ]; then image="$1"; fi; shift ;;
        esac
      done

      # Gate 1 — image file
      if [ -z "${image}" ]; then
        log_error "usage: sovereign-osctl install image [--plan] <image-path> --to <device>"
        return 2
      fi
      if [ ! -f "${image}" ]; then
        log_error "image not found or not a regular file: ${image}"
        return 1
      fi
      local image_size
      image_size="$(stat -c '%s' "${image}" 2>/dev/null || echo 0)"
      if [ "${image_size}" -lt 1048576 ]; then
        log_error "image is suspiciously small (${image_size} bytes); refusing"
        return 1
      fi

      # Gate 2 — target device
      if [ -z "${device}" ]; then
        log_error "missing --to <device>"
        return 2
      fi
      if [ ! -b "${device}" ]; then
        log_error "target is not a block device: ${device}"
        return 1
      fi

      # Gate 3 — must be a whole disk (not a partition)
      # Heuristic: device name ends in a digit AND parent block device exists
      local dev_basename; dev_basename="$(basename "${device}")"
      if [[ "${dev_basename}" =~ [0-9]$ ]] && [ -e "/sys/class/block/${dev_basename}/partition" ]; then
        log_error "target ${device} is a PARTITION, not a whole disk; refusing"
        log_error "  pass the parent disk (e.g. /dev/nvme0n1, not /dev/nvme0n1p1)"
        return 1
      fi

      # Gate 4 — target must NOT be the running root or its parent
      local root_src; root_src="$(findmnt -n -o SOURCE / 2>/dev/null || echo unknown)"
      local root_parent; root_parent="$(lsblk -no PKNAME "${root_src}" 2>/dev/null | head -1 || echo unknown)"
      if [ "${device}" = "${root_src}" ] || [ "${dev_basename}" = "${root_parent}" ]; then
        log_error "target ${device} IS THE RUNNING ROOT or its parent; HARD REFUSAL"
        log_error "  running root: ${root_src}  parent: ${root_parent}"
        return 1
      fi

      # Device fingerprint
      local model serial size_human is_mounted
      model="$(lsblk -dn -o MODEL "${device}" 2>/dev/null | xargs || echo unknown)"
      serial="$(lsblk -dn -o SERIAL "${device}" 2>/dev/null | xargs || echo unknown)"
      size_human="$(lsblk -dn -o SIZE "${device}" 2>/dev/null | xargs || echo unknown)"
      is_mounted="$(lsblk -n -o MOUNTPOINTS "${device}" 2>/dev/null | xargs || echo)"

      echo
      echo "  target device fingerprint:"
      echo "    path:     ${device}"
      echo "    model:    ${model}"
      echo "    serial:   ${serial}"
      echo "    size:     ${size_human}"
      echo "    mounted:  ${is_mounted:-(none)}"
      echo
      echo "  image:"
      echo "    path:     ${image}"
      echo "    size:     $(numfmt --to=iec --suffix=B "${image_size}" 2>/dev/null || echo "${image_size}B")"
      echo

      if [ "${plan_only}" -eq 1 ]; then
        echo "  --plan mode: would run:"
        echo "    sudo dd if='${image}' of='${device}' bs=4M status=progress conv=fsync"
        echo "  no byte was written. drop --plan to execute (gates: SOVEREIGN_OS_CONFIRM_DESTROY=YES + interactive)."
        return 0
      fi

      # Gate 5 — env confirmation
      if [ "${SOVEREIGN_OS_CONFIRM_DESTROY:-}" != "YES" ]; then
        log_error "DESTRUCTIVE operation. SOVEREIGN_OS_CONFIRM_DESTROY=YES not set."
        log_error "  re-run with: SOVEREIGN_OS_CONFIRM_DESTROY=YES sovereign-osctl install image '${image}' --to '${device}'"
        log_error "  or preview without writing: sovereign-osctl install image --plan '${image}' --to '${device}'"
        return 1
      fi

      # Gate 6 — interactive confirm (unless NONINTERACTIVE)
      if [ -z "${SOVEREIGN_OS_NONINTERACTIVE:-}" ]; then
        echo "  This will WIPE ${device} (${model} ${serial}, ${size_human})"
        echo "  and write ${image} ($(numfmt --to=iec --suffix=B "${image_size}" 2>/dev/null || echo "${image_size}B"))."
        echo
        read -rp "  Type the device path (${device}) to confirm: " typed
        if [ "${typed}" != "${device}" ]; then
          log_error "device confirmation mismatch; aborting"
          return 1
        fi
      fi

      # All gates passed — execute
      log_info "writing ${image} → ${device} (this will take several minutes)"
      if command -v dd >/dev/null 2>&1; then
        # Guard dd explicitly. Under set -e a failed write (I/O error, device
        # yanked mid-write, write-protect, sudo denied) would abort the CLI with
        # only dd's raw stderr — leaving the operator without the one fact that
        # matters at THE most destructive moment: the target is now PARTIALLY
        # WRITTEN and must NOT be booted. Surface that explicitly, and don't
        # claim "complete" on a failed dump.
        if ! sudo dd if="${image}" of="${device}" bs=4M status=progress conv=fsync; then
          log_error "dd FAILED writing ${image} → ${device}"
          log_error "  ${device} is now PARTIALLY WRITTEN / UNBOOTABLE — do NOT boot from it."
          log_error "  resolve the dd error (I/O, write-protect, device present?) and re-run the install."
          return 1
        fi
        log_info "image dump complete"
        log_info "sync'ing disk..."
        sudo sync
        log_info "done. consider 'sovereign-osctl install verify --to ${device}' (future) before unplugging."
      else
        log_error "dd not available; cannot proceed"
        return 1
      fi
      ;;

    help|--help|-h|"")
      cat <<EOF
sovereign-osctl install — operator-side image deployment

USAGE:
  sovereign-osctl install image [--plan] <image-path> --to <device>

GATES (every byte-writing path must pass ALL):
  • image exists + non-empty + regular file
  • target is a block device + WHOLE DISK (not a partition)
  • target is NOT the running root or its parent (HARD REFUSAL)
  • SOVEREIGN_OS_CONFIRM_DESTROY=YES
  • interactive device-path confirm (unless SOVEREIGN_OS_NONINTERACTIVE=1)

--plan mode: shows the device fingerprint + the command that WOULD
run, writes nothing. Recommended first step.

EXAMPLES:
  # 1. Preview
  sovereign-osctl install image --plan build/sain-01/output/sain-01 --to /dev/nvme1n1

  # 2. Execute (after preview review)
  SOVEREIGN_OS_CONFIRM_DESTROY=YES \\
    sudo sovereign-osctl install image build/sain-01/output/sain-01 --to /dev/nvme1n1
EOF
      ;;

    suggest-modules)
      # R185: recommend which selfdef modules to enable based on the
      # operator's chosen profile + probed hardware. Read-only —
      # doesn't WRITE /etc/selfdef/modules.toml; the operator copy-
      # pastes the suggested block.
      local profile="${SOVEREIGN_OS_PROFILE:-sain-01}"
      while [ $# -gt 0 ]; do
        case "$1" in
          --profile) profile="$2"; shift 2 ;;
          *) log_error "unknown suggest-modules flag: $1"; return 2 ;;
        esac
      done

      echo "# R185: sovereign-osctl install suggest-modules"
      echo "# profile: ${profile}"
      echo "#"
      echo "# Recommendation matrix (profile × probed hardware):"
      echo "#"

      # Probe AVX-512 + GPU presence (best-effort, no failure exit).
      # Use loop + test -e to avoid glob-unmatch exits firing the
      # script-level ERR trap from common.sh.
      local has_avx512=0 gpu_count=0 _i
      if grep -q "avx512f" /proc/cpuinfo 2>/dev/null; then has_avx512=1; fi
      for _i in 0 1 2 3 4 5 6 7; do
        if [ -e "/dev/nvidia${_i}" ]; then
          gpu_count=$((gpu_count + 1))
        fi
      done
      echo "# detected: avx512f=${has_avx512} gpu_count=${gpu_count}"
      echo ""
      echo "# Copy-paste this block into /etc/selfdef/modules.toml:"
      echo ""

      # R188: delegate to the shared matrix helper (single source of
      # truth, closes SDD-019 T-5). The helper prints one module slug
      # per line; we wrap in `[modules.X]` syntax for copy-paste.
      local _avx_flag=""
      [ "${has_avx512}" = "1" ] && _avx_flag="--has-avx512"
      local rec_out rec_rc
      set +e
      rec_out="$(python3 "${__REPO_ROOT}/scripts/hardware/lib/module-recommendations.py" \
        --profile "${profile}" ${_avx_flag} --gpu-count "${gpu_count}" 2>&1)"
      rec_rc=$?
      set -e
      if [ "${rec_rc}" -ne 0 ]; then
        echo "# (unknown profile ${profile}; valid: sain-01 / developer / headless / minimal / old-workstation)"
        return 2
      fi
      if [ -z "${rec_out}" ]; then
        case "${profile}" in
          minimal|old-workstation)
            echo "# (no selfdef modules recommended for ${profile} —"
            echo "#  it's CPU/VM-only or pre-AVX-512; the gate would skip them all.)"
            ;;
          *)
            echo "# (no selfdef modules recommended — host doesn't unlock cycle-2 features)"
            ;;
        esac
      else
        while IFS= read -r mod; do
          [ -n "${mod}" ] && echo "[modules.${mod}]"
        done <<< "${rec_out}"
      fi
      ;;
    *)
      log_error "unknown install subcommand: ${sub}"
      log_error "  available: image [--plan] <img> --to <dev> | suggest-modules [--profile <p>] | help"
      return 2
      ;;
  esac
}

# ------------------------------ decommission ---------------------------------

# ------------------------------ hooks ----------------------------------------
#
# R141 (F-09 MED closure): operator-facing profile-hook editor.
# Before this verb operators wanting to add a post-install hook (e.g.,
# 'after install, set up my dotfiles') edited the profile YAML manually
# and could typo the path or forget the schema shape. This verb does
# the YAML mutation safely + validates the path + flags the schema.
#
# Stages (must match profile.schema.yaml § hooks):
#   pre_install · during_install · post_install_first_boot ·
#   post_install_recurrent · decommission

cmd_hooks() {
  local sub="${1:-list}"
  shift || true

  case "${sub}" in
    list)
      local id="${1:-${SOVEREIGN_OS_PROFILE}}"
      local f="${__REPO_ROOT}/profiles/${id}.yaml"
      if [ ! -f "${f}" ]; then
        log_error "no such profile: ${id}"
        return 1
      fi
      PROFILE_FILE="${f}" python3 - <<'PY'
import os, yaml
with open(os.environ["PROFILE_FILE"]) as fh:
    data = yaml.safe_load(fh) or {}
hooks = data.get("hooks") or {}
total = 0
for stage in ("pre_install", "during_install", "post_install_first_boot",
              "post_install_recurrent", "decommission"):
    entries = hooks.get(stage) or []
    if not entries: continue
    print(f"  {stage}:")
    for h in entries:
        total += 1
        mand = " [mandatory]" if h.get("mandatory") else ""
        sch = f" schedule={h.get('schedule')}" if h.get("schedule") else ""
        print(f"    - {h.get('id', '?'):<32} {h.get('script', '?')}{mand}{sch}")
print(f"  total: {total} hook(s) declared")
PY
      ;;

    add)
      local stage="" script="" id="" mandatory=0 profile="${SOVEREIGN_OS_PROFILE}"
      stage="${1:-}"; shift || true
      script="${1:-}"; shift || true
      while [ $# -gt 0 ]; do
        case "$1" in
          --id) id="${2:-}"; shift 2 ;;
          --mandatory) mandatory=1; shift ;;
          --profile) profile="${2:-}"; shift 2 ;;
          *) log_error "unknown hooks add flag: $1"; return 2 ;;
        esac
      done
      if [ -z "${stage}" ] || [ -z "${script}" ]; then
        log_error "usage: sovereign-osctl hooks add <stage> <script-path> [--id <id>] [--mandatory] [--profile <id>]"
        return 2
      fi
      # Validate stage
      case "${stage}" in
        pre_install|during_install|post_install_first_boot|post_install_recurrent|decommission) ;;
        *) log_error "invalid stage: ${stage}"
           log_error "  valid: pre_install · during_install · post_install_first_boot · post_install_recurrent · decommission"
           return 2 ;;
      esac
      # Validate profile
      local f="${__REPO_ROOT}/profiles/${profile}.yaml"
      if [ ! -f "${f}" ]; then
        log_error "no such profile: ${profile}"
        return 1
      fi
      # Validate script path (relative to repo root, must exist + be executable)
      local script_full="${__REPO_ROOT}/${script}"
      if [ ! -f "${script_full}" ]; then
        log_error "script not found: ${script_full}"
        log_error "  path must be relative to repo root (e.g. scripts/hooks/post-install/my-hook.sh)"
        return 1
      fi
      if [ ! -x "${script_full}" ]; then
        log_error "script not executable: ${script_full}"
        log_error "  run: chmod +x ${script_full}"
        return 1
      fi
      # Default id from basename
      if [ -z "${id}" ]; then
        id="$(basename "${script}" .sh)"
      fi
      # Validate id pattern
      if ! [[ "${id}" =~ ^[a-z][a-z0-9-]*$ ]]; then
        log_error "invalid hook id: ${id}"
        log_error "  must match: ^[a-z][a-z0-9-]*$"
        return 2
      fi
      # Mutate the profile YAML
      PROFILE_FILE="${f}" STAGE="${stage}" HOOK_ID="${id}" SCRIPT="${script}" \
      MAND="${mandatory}" python3 - <<'PY'
import os, yaml, sys
pfile = os.environ["PROFILE_FILE"]
stage = os.environ["STAGE"]
hook_id = os.environ["HOOK_ID"]
script = os.environ["SCRIPT"]
mandatory = os.environ["MAND"] == "1"
with open(pfile) as f:
    data = yaml.safe_load(f) or {}
hooks = data.setdefault("hooks", {})
entries = hooks.setdefault(stage, [])
# Refuse on duplicate id within the same stage
for e in entries:
    if e.get("id") == hook_id:
        print(f"hook id '{hook_id}' already exists in {stage}; refusing to duplicate", file=sys.stderr)
        sys.exit(1)
new_entry = {
    "id": hook_id,
    "type": "setup",
    "script": script,
    "mandatory": mandatory,
}
entries.append(new_entry)
# R144 fix (bug #18): preserve the schema header by reading the
# ORIGINAL file before any write (the prior `open(..., "w")` truncated
# the file BEFORE the header re-read, wiping all comments).
with open(pfile) as f_orig:
    orig_lines = f_orig.readlines()
header_lines = []
for line in orig_lines:
    if line.startswith("#") or not line.strip():
        header_lines.append(line)
    else:
        break
with open(pfile, "w") as f:
    f.writelines(header_lines)
    yaml.safe_dump(data, f, sort_keys=False, default_flow_style=False)
print(f"hook added: id={hook_id} stage={stage} script={script} mandatory={mandatory}")
PY
      local rc=$?
      if [ "${rc}" -ne 0 ]; then
        return "${rc}"
      fi
      log_info "  edited: ${f}"
      log_info "  NEXT:  sovereign-osctl profiles validate"
      ;;

    remove)
      local id="${1:-}" profile="${SOVEREIGN_OS_PROFILE}"
      shift || true
      while [ $# -gt 0 ]; do
        case "$1" in
          --profile) profile="${2:-}"; shift 2 ;;
          *) log_error "unknown hooks remove flag: $1"; return 2 ;;
        esac
      done
      if [ -z "${id}" ]; then
        log_error "usage: sovereign-osctl hooks remove <id> [--profile <id>]"
        return 2
      fi
      local f="${__REPO_ROOT}/profiles/${profile}.yaml"
      if [ ! -f "${f}" ]; then
        log_error "no such profile: ${profile}"
        return 1
      fi
      PROFILE_FILE="${f}" HOOK_ID="${id}" python3 - <<'PY'
import os, yaml, sys
pfile = os.environ["PROFILE_FILE"]
hook_id = os.environ["HOOK_ID"]
with open(pfile) as f:
    data = yaml.safe_load(f) or {}
hooks = data.get("hooks") or {}
removed = 0
for stage, entries in hooks.items():
    if not entries: continue
    before = len(entries)
    hooks[stage] = [e for e in entries if e.get("id") != hook_id]
    removed += before - len(hooks[stage])
if removed == 0:
    print(f"no hook with id '{hook_id}' found in {pfile}", file=sys.stderr)
    sys.exit(1)
with open(pfile) as f_orig:
    orig_lines = f_orig.readlines()
header_lines = []
for line in orig_lines:
    if line.startswith("#") or not line.strip():
        header_lines.append(line)
    else:
        break
with open(pfile, "w") as f:
    f.writelines(header_lines)
    yaml.safe_dump(data, f, sort_keys=False, default_flow_style=False)
print(f"removed {removed} hook entry(ies) with id={hook_id}")
PY
      local rc=$?
      if [ "${rc}" -ne 0 ]; then
        return "${rc}"
      fi
      log_info "  edited: ${f}"
      ;;

    *)
      log_error "unknown hooks subcommand: ${sub}"
      log_error "  available: list [<profile>] | add <stage> <script> [--id ... --mandatory --profile ...] | remove <id> [--profile <id>]"
      return 2
      ;;
  esac
}

cmd_decommission() {
  local sub="${1:-start}"
  case "${sub}" in
    --plan|plan)
      # R139 (F-11 MED closure): non-destructive preview of every
      # decommission phase. Operator rehearsal path — no env-gate
      # required (no bytes are written).
      echo
      echo "  sovereign-osctl decommission --plan"
      echo "  ==================================="
      echo "  Shows EVERY destructive operation across all 3 phases."
      echo "  Writes nothing. Operator inspects, then runs phases explicitly."
      echo
      echo "  Phase 1 — secure-wipe-context (state-fabric)"
      echo "    hook: scripts/hooks/decommission/secure-wipe-context.sh"
      echo "    target: tank/context (ZFS dataset; operator-key encrypted per SDD-022)"
      echo "    operation: 'shred -uvz' on the unlocked content, then zfs destroy"
      if command -v zfs >/dev/null 2>&1 && zfs list tank/context >/dev/null 2>&1; then
        local ctx_size
        ctx_size="$(zfs list -H -o used tank/context 2>/dev/null || echo unknown)"
        echo "    ✓ tank/context exists; size: ${ctx_size}"
      else
        echo "    (tank/context not present in this environment)"
      fi
      echo "    invoke: sovereign-osctl decommission start"
      echo
      echo "  Phase 2 — zfs-pool-destroy (whole pool)"
      echo "    hook: scripts/hooks/decommission/zfs-pool-destroy.sh"
      echo "    target: zpool '${SOVEREIGN_OS_POOL_NAME:-tank}'"
      echo "    operation: 'zpool destroy -f \${POOL}'"
      if command -v zpool >/dev/null 2>&1 && zpool list "${SOVEREIGN_OS_POOL_NAME:-tank}" >/dev/null 2>&1; then
        local pool_size pool_used
        pool_size="$(zpool list -H -o size "${SOVEREIGN_OS_POOL_NAME:-tank}" 2>/dev/null || echo unknown)"
        pool_used="$(zpool list -H -o allocated "${SOVEREIGN_OS_POOL_NAME:-tank}" 2>/dev/null || echo unknown)"
        echo "    ✓ pool '${SOVEREIGN_OS_POOL_NAME:-tank}' exists; size=${pool_size} used=${pool_used}"
      else
        echo "    (pool '${SOVEREIGN_OS_POOL_NAME:-tank}' not present in this environment)"
      fi
      echo "    invoke: SOVEREIGN_OS_CONFIRM_DESTROY=YES sovereign-osctl decommission pool"
      echo
      echo "  Phase 3 — secure-wipe (block devices)"
      echo "    hook: scripts/hooks/decommission/secure-wipe.sh"
      echo "    targets: SOVEREIGN_OS_WIPE_DEVICES (e.g. '/dev/nvme0n1 /dev/nvme1n1')"
      local wipe_devs="${SOVEREIGN_OS_WIPE_DEVICES:-(unset)}"
      echo "    currently: ${wipe_devs}"
      if [ "${wipe_devs}" != "(unset)" ]; then
        for dev in ${wipe_devs}; do
          if [ -b "${dev}" ]; then
            local d_size d_model d_serial
            d_size="$(lsblk -dn -o SIZE "${dev}" 2>/dev/null | xargs || echo ?)"
            d_model="$(lsblk -dn -o MODEL "${dev}" 2>/dev/null | xargs || echo ?)"
            d_serial="$(lsblk -dn -o SERIAL "${dev}" 2>/dev/null | xargs || echo ?)"
            echo "      ✓ ${dev}  ${d_model}  serial=${d_serial}  size=${d_size}"
          else
            echo "      ! ${dev}  NOT A BLOCK DEVICE (refused at execute time)"
          fi
        done
      else
        echo "    operator must export SOVEREIGN_OS_WIPE_DEVICES before phase 3"
      fi
      echo "    operation: 'blkdiscard' if SSD, else 'shred -vfz'"
      echo "    invoke: SOVEREIGN_OS_CONFIRM_DESTROY=YES SOVEREIGN_OS_WIPE_DEVICES='/dev/...' \\"
      echo "              sovereign-osctl decommission wipe"
      echo
      echo "  NOTHING WAS WRITTEN. Each phase requires SOVEREIGN_OS_CONFIRM_DESTROY=YES + interactive confirm."
      return 0
      ;;
    start)
      log_warn "decommission begins; this is DESTRUCTIVE."
      log_warn "  three phases:"
      log_warn "    1. wipe state-fabric (tank/context shred)"
      log_warn "    2. destroy ZFS pool"
      log_warn "    3. secure-wipe block devices"
      if ! confirm "Continue with decommission?" default-no; then
        log_info "aborted"
        return 0
      fi
      "${__REPO_ROOT}/scripts/hooks/decommission/secure-wipe-context.sh"
      log_info ""
      log_info "Phase 1 complete. To continue:"
      log_info "  SOVEREIGN_OS_CONFIRM_DESTROY=YES sudo sovereign-osctl decommission pool"
      ;;
    pool)
      SOVEREIGN_OS_CONFIRM_DESTROY="${SOVEREIGN_OS_CONFIRM_DESTROY:-}" \
        "${__REPO_ROOT}/scripts/hooks/decommission/zfs-pool-destroy.sh"
      log_info ""
      log_info "Phase 2 complete. To wipe block devices:"
      log_info "  SOVEREIGN_OS_CONFIRM_DESTROY=YES SOVEREIGN_OS_WIPE_DEVICES='/dev/...' \\"
      log_info "    sudo sovereign-osctl decommission wipe"
      ;;
    wipe)
      "${__REPO_ROOT}/scripts/hooks/decommission/secure-wipe.sh"
      log_info "decommission complete"
      ;;
    *)
      log_error "unknown decommission subcommand: ${sub}"
      cmd_help
      exit 2
      ;;
  esac
}

# ------------------------------ inference ------------------------------------

cmd_inference() {
  local sub="${1:-status}"
  shift || true

  # Map tier short-names → systemd unit names
  declare -A tier_units=(
    [pulse]="sovereign-pulse.service"
    [logic]="sovereign-logic-engine.service"
    [logic-engine]="sovereign-logic-engine.service"
    [oracle]="sovereign-oracle-core.service"
    [oracle-core]="sovereign-oracle-core.service"
    [router]="sovereign-router.service"
  )

  case "${sub}" in
    status)
      printf "%-25s %-12s %-20s %s\n" "TIER" "STATE" "ENDPOINT" "BACKEND"
      printf "%-25s %-12s %-20s %s\n" "----" "-----" "--------" "-------"
      for tier in pulse logic oracle router; do
        local unit="${tier_units[$tier]}"
        local state="not-installed"
        if systemctl list-unit-files "${unit}" >/dev/null 2>&1; then
          state="$(systemctl is-active "${unit}" 2>/dev/null || echo unknown)"
        fi
        local port endpoint backend
        case "${tier}" in
          pulse)  port=8081; backend="bitnet.cpp (CCD 0)" ;;
          logic)  port=8082; backend="vLLM (3090 VFIO) or llama.cpp" ;;
          oracle) port=8083; backend="vLLM + DFlash (Blackwell)" ;;
          router) port=8080; backend="OpenAI-compatible front" ;;
        esac
        endpoint="http://127.0.0.1:${port}"
        printf "%-25s %-12s %-20s %s\n" "${tier}" "${state}" "${endpoint}" "${backend}"
      done
      ;;

    start|stop|restart)
      local target="${1:-all}"
      shift || true
      require_root
      if [ "${target}" = "all" ]; then
        for tier in pulse logic oracle router; do
          local unit="${tier_units[$tier]}"
          if systemctl list-unit-files "${unit}" >/dev/null 2>&1; then
            log_info "${sub} ${unit}"
            systemctl "${sub}" "${unit}" || log_warn "  ${sub} failed for ${unit}"
          else
            log_warn "${unit} not installed; skipping"
          fi
        done
      else
        local unit="${tier_units[${target}]:-}"
        if [ -z "${unit}" ]; then
          log_error "unknown tier: ${target} (use pulse|logic|oracle|router|all)"
          return 2
        fi
        systemctl "${sub}" "${unit}"
      fi
      ;;

    route)
      local prompt="${*:-hello}"
      python3 - <<PY
import sys
sys.path.insert(0, "${__REPO_ROOT}/scripts/inference")
from router import classify
body = {"model": "auto", "messages": [{"role": "user", "content": """${prompt}"""}]}
print(f"would route to: {classify(body)}")
PY
      ;;

    health)
      # HTTP-probe every tier's /healthz endpoint + the router's /healthz.
      # Used by ops dashboards + operator quick-check. Falls back to TCP-
      # liveness if HTTP returns non-2xx (some backends don't expose
      # /healthz but their port being open is signal enough).
      local any_fail=0
      printf "%-15s %-25s %-10s %s\n" "TIER" "ENDPOINT" "STATUS" "DETAIL"
      printf "%-15s %-25s %-10s %s\n" "----" "--------" "------" "------"
      for tier in pulse logic oracle router; do
        local port endpoint
        case "${tier}" in
          pulse)  port=8081 ;;
          logic)  port=8082 ;;
          oracle) port=8083 ;;
          router) port=8080 ;;
        esac
        endpoint="http://127.0.0.1:${port}"

        # Try /healthz first
        local status detail
        local rc=1
        if command -v curl >/dev/null 2>&1; then
          local code; code="$(curl -s -o /dev/null -w '%{http_code}' --max-time 3 "${endpoint}/healthz" 2>/dev/null || echo 000)"
          if [ "${code}" = "200" ]; then
            status="✓ ok"; detail="200 /healthz"; rc=0
          elif [ "${code}" = "000" ]; then
            # Try TCP fallback
            if (echo >/dev/tcp/127.0.0.1/"${port}") 2>/dev/null; then
              status="~ tcp"; detail="port open, /healthz unreachable"; rc=0
            else
              status="✗ down"; detail="no listener"; rc=1
            fi
          else
            status="? code"; detail="${code} /healthz"; rc=1
          fi
        else
          # curl absent — pure-bash TCP probe via /dev/tcp
          if (echo >/dev/tcp/127.0.0.1/"${port}") 2>/dev/null; then
            status="~ tcp"; detail="port open (no curl for /healthz)"; rc=0
          else
            status="✗ down"; detail="no listener (no curl for /healthz)"; rc=1
          fi
        fi
        [ "${rc}" -ne 0 ] && any_fail=1
        printf "%-15s %-25s %-10s %s\n" "${tier}" "${endpoint}" "${status}" "${detail}"
      done
      [ "${any_fail}" -eq 0 ] && return 0 || return 1
      ;;

    logs)
      local target="${1:?usage: inference logs <pulse|logic|oracle|router>}"
      local unit="${tier_units[${target}]:-}"
      if [ -z "${unit}" ]; then
        log_error "unknown tier: ${target}"
        return 2
      fi
      journalctl -u "${unit}" -f --no-pager
      ;;

    *)
      log_error "unknown inference subcommand: ${sub}"
      cmd_help
      exit 2
      ;;
  esac
}

# ------------------------------ version --------------------------------------

cmd_version() {
  local sovereign_version="0.3.0"
  local phase="Stage-2 operator-observability + hardening complete"
  local active_profile="${SOVEREIGN_OS_PROFILE:-unknown}"
  local active_whitelabel="default"
  [ -r /etc/sovereign-os/active-whitelabel ] && \
    active_whitelabel="$(cat /etc/sovereign-os/active-whitelabel)"
  local kernel_release; kernel_release="$(uname -r)"
  local os_pretty="unknown"
  if [ -r /etc/os-release ]; then
    os_pretty="$(grep PRETTY_NAME /etc/os-release | cut -d= -f2- | tr -d '"')"
  fi

  if [ "${1:-}" = "--json" ]; then
    # Machine-readable for fleet tooling. Stable field set.
    cat <<EOF
{
  "sovereign_osctl_version": "${sovereign_version}",
  "phase": "${phase}",
  "active_profile": "${active_profile}",
  "active_whitelabel": "${active_whitelabel}",
  "kernel_release": "${kernel_release}",
  "os_pretty_name": "${os_pretty}",
  "repo": "https://github.com/cyberpunk042/sovereign-os"
}
EOF
  else
    echo "sovereign-osctl ${sovereign_version} (${phase})"
    echo "active profile:    ${active_profile}"
    echo "active whitelabel: ${active_whitelabel}"
    echo "kernel release:    ${kernel_release}"
    echo "OS:                ${os_pretty}"
  fi
}

