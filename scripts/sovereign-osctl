  if [[ "${SOVEREIGN_OS_DRY_RUN:-}" == "1" ]]; then
    if [[ "${iterations}" -eq 0 ]]; then iterations=1; fi
  fi

  local frame=0
  while :; do
    frame=$((frame + 1))
    printf '\x1b[2J\x1b[H'
    local now
    now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "── surface-map.watch (frame ${frame}, refresh=${refresh}s, ${now}) ──"
    echo
    # R543 (E5++): system-wide §1g 8-surface ceiling-closure rollup
    # banner (R540 milestone over the same surface-map.py importlib
    # data source — operator-§1g UX rule: high-signal information at
    # the top of the refresh loop, surfaced BEFORE the per-module
    # matrix). Same R539 invariants the API + webapp surfaces show.
    "${__REPO_ROOT}/scripts/operator/surface-map.py" milestone 2>/dev/null \
      | sed 's/^/  /' \
      || echo "  (surface-map milestone emit failed)"
    echo
    "${__REPO_ROOT}/scripts/operator/surface-map.py" coverage 2>/dev/null \
      || echo "  (surface-map coverage emit failed — module data missing?)"
    echo
    if [[ "${iterations}" -gt 0 && "${frame}" -ge "${iterations}" ]]; then
      echo "  (reached --iterations=${iterations}; exit)"
    else
      echo "  (Ctrl-C to exit; refresh in ${refresh}s)"
    fi

    if [[ "${iterations}" -gt 0 && "${frame}" -ge "${iterations}" ]]; then
      break
    fi
    if ! sleep "${refresh}" 2>/dev/null; then
      echo
      echo "  ── surface-map.watch interrupted ──"
      break
    fi
  done
  return 0
}

_weaver_watch() {
  # R534 (E5++) — Weaver TUI refresh-loop surface.
  #
  # Per operator §1g 8-surface delivery contract (verbatim):
  #
  #   "everything is not just core, not just cli, not just TUI, not just
  #   API, not just tool and MCP but also Dashboards and Web Apps and
  #   Services"
  #
  # First commit in the weaver tier-3 surface-expansion arc
  # (R534 TUI → R535 MCP → R536 API + webapp + service). Drains the
  # weaver tui:FUTURE waiver — same shape as the surface-map
  # R531-R533 / ux-design-audit R528-R530 / doc-coverage R525-R527
  # arcs. Brief render combines `_trinity_weaver_brief` (operator-
  # known shape) + the master spec § 21 atomic-state file presence
  # listing (4-state-fabric: IDENTITY / SOUL / AGENTS / CLAUDE).
  #
  # Operator-named guarantees (mirror of R531 surface-map.watch):
  #   - Minimum refresh interval = 1s (max(1,...) floor) so the operator
  #     can't accidentally hammer the state-fabric stat() calls.
  #   - SOVEREIGN_OS_DRY_RUN=1 forces single-render exit (CI-safe).
  #   - Bounded by --iterations (0 = unbounded; default = 0 unless DRY).
  #   - Ctrl-C exits cleanly.
  local refresh=5
  local iterations=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --refresh)    refresh="${2:-5}"; shift 2 ;;
      --refresh=*)  refresh="${1#*=}"; shift ;;
      --iterations) iterations="${2:-0}"; shift 2 ;;
      --iterations=*) iterations="${1#*=}"; shift ;;
      -h|--help)
        cat <<'WEAVER_WATCH_HELP'
  weaver watch [--refresh N] [--iterations N]

  Refresh-loop TUI surface for the §17 Weaver (master spec § 17
  Module 2 + § 21 Atomic State Protocol). Continuously re-renders
  the Weaver brief panel (podman / vfio / tank/context) PLUS the
  4-state-fabric file presence listing (IDENTITY / SOUL / AGENTS /
  CLAUDE) per the master spec § 21.1 lockless loopback write
  sequence.

  Operator-§1g verbatim (R453 anchor): "everything is not just
  core, not just cli, not just TUI, not just API, not just tool
  and MCP but also Dashboards and Web Apps and Services".

  Options:
    --refresh N       seconds between renders (default: 5, min: 1)
    --iterations N    cap the number of renders (default: 0 = unbounded;
                      SOVEREIGN_OS_DRY_RUN=1 forces a single render)
WEAVER_WATCH_HELP
        return 0
        ;;
      *)
        log_error "unknown weaver watch flag: $1"
        return 2
        ;;
    esac
  done

  case "${refresh}" in
    ''|*[!0-9]*) refresh=5 ;;
  esac
  case "${iterations}" in
    ''|*[!0-9]*) iterations=0 ;;
  esac
  if [[ "${refresh}" -lt 1 ]]; then refresh=1; fi

  if [[ "${SOVEREIGN_OS_DRY_RUN:-}" == "1" ]]; then
    if [[ "${iterations}" -eq 0 ]]; then iterations=1; fi
  fi

  local frame=0
  while :; do
    frame=$((frame + 1))
    printf '\x1b[2J\x1b[H'
    local now
    now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "── weaver.watch (frame ${frame}, refresh=${refresh}s, ${now}) ──"
    echo
    _trinity_weaver_brief
    echo
    echo "  STATE FABRIC (master spec § 7 — operator-readable):"
    if "${__REPO_ROOT}/scripts/weaver/atomic-state.py" list 2>/dev/null \
        | sed 's/^/    /'; then
      :
    else
      echo "    (atomic-state list emit failed — context dir absent?)"
    fi
    echo
    if [[ "${iterations}" -gt 0 && "${frame}" -ge "${iterations}" ]]; then
      echo "  (reached --iterations=${iterations}; exit)"
    else
      echo "  (Ctrl-C to exit; refresh in ${refresh}s)"
    fi

    if [[ "${iterations}" -gt 0 && "${frame}" -ge "${iterations}" ]]; then
      break
    fi
    if ! sleep "${refresh}" 2>/dev/null; then
      echo
      echo "  ── weaver.watch interrupted ──"
      break
    fi
  done
  return 0
}

# R537 (E5++) — Auditor TUI refresh-loop surface.
#
# Per operator §1g 8-surface delivery contract (verbatim, R453 anchor):
#
#   "everything is not just core, not just cli, not just TUI, not just
#   API, not just tool and MCP but also Dashboards and Web Apps and
#   Services"
#
# First commit in the auditor tier-3 surface-expansion arc
# (R537 TUI → R538 MCP → R539 API + webapp). The auditor `service`
# surface already ships (R155 guardian-core systemd daemon) so this
# arc differs from the weaver R534-R536 / surface-map R531-R533 /
# ux-design-audit R528-R530 arcs in that the service waiver is
# already drained — but the tui / api / mcp / webapp waivers all
# remain to be closed.
#
# Brief render combines `_trinity_auditor_brief` (operator-known
# shape) + master spec § 10 Native Guardian Loop violation tail
# (tail -5 /mnt/vault/context/security_audit.log) + LAYER B metric
# anchor names. Operator §17 sovereignty boundary: neutralization
# stays CCD-triggered + CLI-gated — the TUI surface is read-only.
#
# Operator-named guarantees (mirror of R534 weaver.watch):
#   - Minimum refresh interval = 1s (max(1,...) floor) so the operator
#     can't accidentally hammer systemctl + audit-log stat calls.
#   - SOVEREIGN_OS_DRY_RUN=1 forces single-render exit (CI-safe).
#   - Bounded by --iterations (0 = unbounded; default = 0 unless DRY).
#   - Ctrl-C exits cleanly.
_auditor_watch() {
  local refresh=5
  local iterations=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --refresh)    refresh="${2:-5}"; shift 2 ;;
      --refresh=*)  refresh="${1#*=}"; shift ;;
      --iterations) iterations="${2:-0}"; shift 2 ;;
      --iterations=*) iterations="${1#*=}"; shift ;;
      -h|--help)
        cat <<'AUDITOR_WATCH_HELP'
  auditor watch [--refresh N] [--iterations N]

  Refresh-loop TUI surface for the §17 Auditor (master spec § 17
  Module 3 + § 10 Native Guardian Loop). Continuously re-renders
  the Auditor brief panel (tetragon / guardian-core / policy
  state) PLUS the recent security_audit.log tail (last 5
  violations) — read-only operator visibility.

  Operator §17 sovereignty boundary: neutralization is CCD-
  triggered + CLI-gated; the TUI surface is INSPECTION ONLY.

  Operator-§1g verbatim (R453 anchor): "everything is not just
  core, not just cli, not just TUI, not just API, not just tool
  and MCP but also Dashboards and Web Apps and Services".

  Options:
    --refresh N       seconds between renders (default: 5, min: 1)
    --iterations N    cap the number of renders (default: 0 = unbounded;
                      SOVEREIGN_OS_DRY_RUN=1 forces a single render)
AUDITOR_WATCH_HELP
        return 0
        ;;
      *)
        log_error "unknown auditor watch flag: $1"
        return 2
        ;;
    esac
  done

  case "${refresh}" in
    ''|*[!0-9]*) refresh=5 ;;
  esac
  case "${iterations}" in
    ''|*[!0-9]*) iterations=0 ;;
  esac
  if [[ "${refresh}" -lt 1 ]]; then refresh=1; fi

  if [[ "${SOVEREIGN_OS_DRY_RUN:-}" == "1" ]]; then
    if [[ "${iterations}" -eq 0 ]]; then iterations=1; fi
  fi

  local audit_log="/mnt/vault/context/security_audit.log"

  local frame=0
  while :; do
    frame=$((frame + 1))
    printf '\x1b[2J\x1b[H'
    local now
    now="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "── auditor.watch (frame ${frame}, refresh=${refresh}s, ${now}) ──"
    echo
    _trinity_auditor_brief
    echo
    echo "  RECENT VIOLATIONS (master spec § 10 — security_audit.log tail):"
    if [ -f "${audit_log}" ]; then
      if tail -5 "${audit_log}" 2>/dev/null | sed 's/^/    /'; then
        :
      else
        echo "    (audit log unreadable)"
      fi
    else
      echo "    audit log not present (${audit_log})"
      echo "    (lands when guardian-core daemon writes its first event)"
    fi
    echo
    echo "  LAYER B METRICS (Prometheus):"
    echo "    sovereign_os_auditor_neutralization_total{result}"
    echo "    sovereign_os_auditor_event_parse_total{outcome}"
    echo "    sovereign_os_auditor_last_neutralization_timestamp"
    echo
    if [[ "${iterations}" -gt 0 && "${frame}" -ge "${iterations}" ]]; then
      echo "  (reached --iterations=${iterations}; exit)"
    else
      echo "  (Ctrl-C to exit; refresh in ${refresh}s)"
    fi

    if [[ "${iterations}" -gt 0 && "${frame}" -ge "${iterations}" ]]; then
      break
    fi
    if ! sleep "${refresh}" 2>/dev/null; then
      echo
      echo "  ── auditor.watch interrupted ──"
      break
    fi
  done
  return 0
}

