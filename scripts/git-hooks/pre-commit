#!/usr/bin/env bash
# scripts/git-hooks/pre-commit — sovereign-os operator pre-commit gate.
#
# FAST BY DEFAULT. A plain `git commit` runs only a quick shellcheck of the
# STAGED shell files (~1s) so commits are instant. The full local gate
# (Layer 1 `pytest tests/schema tests/lint` + validate-profiles.sh + a full
# lint of scripts + the L3 nspawn suite, ~90s) is OPT-IN — and CI runs the
# full suite on every push regardless, so nothing ships unchecked.
#
# Install via:
#   ln -sf "$(pwd)/scripts/git-hooks/pre-commit" .git/hooks/pre-commit
#
# Disable for one commit via:
#   git commit --no-verify
# (sovereign-os direct-push workflow means operator commits straight to
# main; CI is the pre-merge enforcement, the local gate is convenience.)
#
# Tunable env:
#   SOVEREIGN_OS_PRECOMMIT_FULL=1      Run the ENTIRE local gate (L1 + profiles
#                                      + shellcheck + full L3) — the heavy path.
#   SOVEREIGN_OS_PRECOMMIT_SKIP_L3=1   In FULL mode, skip the L3 nspawn suite.

set -euo pipefail

__REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "${__REPO_ROOT}"

bold='\033[1m'; red='\033[31m'; green='\033[32m'; yellow='\033[33m'; reset='\033[0m'
failed=0

# ─────────────────────────── FAST PATH (default) ───────────────────────────
if [ -z "${SOVEREIGN_OS_PRECOMMIT_FULL:-}" ]; then
  # Only shellcheck the STAGED *.sh files — quick, catches obvious breakage.
  if command -v shellcheck >/dev/null 2>&1; then
    mapfile -t staged < <(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -E '\.sh$' || true)
    if [ "${#staged[@]}" -gt 0 ]; then
      if shellcheck --severity=error --source-path=scripts/build/lib --external-sources "${staged[@]}" 2>/dev/null; then
        echo -e "${green}✓${reset} pre-commit (fast): ${#staged[@]} staged shell file(s) shellcheck-clean"
      else
        echo -e "${red}✗${reset} staged shell file has a shellcheck ERROR (above)"
        failed=1
      fi
    fi
  fi
  if [ "${failed}" -ne 0 ]; then
    echo -e "${red}✗ pre-commit failed${reset} — fix, or \`git commit --no-verify\`."
    exit 1
  fi
  echo -e "  ${yellow}·${reset} fast mode. Full local gate: ${bold}SOVEREIGN_OS_PRECOMMIT_FULL=1 git commit${reset} (CI runs it regardless)."
  exit 0
fi

# ─────────────────────────── FULL PATH (opt-in) ────────────────────────────
echo -e "${bold}sovereign-os pre-commit gate — FULL${reset}"
echo

echo -e "${bold}[L1] schema + lint pytest${reset}"
if python3 -m pytest tests/schema tests/lint -q 2>&1 | tail -3; then
  echo -e "  ${green}✓${reset} Layer 1 passes"
else
  echo -e "  ${red}✗${reset} Layer 1 FAILED"; failed=1
fi
echo

if [ -x "${__REPO_ROOT}/scripts/validate-profiles.sh" ]; then
  echo -e "${bold}[profiles] schema-validate all${reset}"
  if "${__REPO_ROOT}/scripts/validate-profiles.sh" >/dev/null 2>&1; then
    echo -e "  ${green}✓${reset} all profiles validate"
  else
    echo -e "  ${red}✗${reset} profile validation FAILED"
    "${__REPO_ROOT}/scripts/validate-profiles.sh" 2>&1 | tail -10; failed=1
  fi
  echo
fi

if command -v shellcheck >/dev/null 2>&1; then
  echo -e "${bold}[shellcheck] scripts/${reset}"
  shellcheck_issues="$(find scripts -name '*.sh' -type f -print0 \
    | xargs -0 shellcheck --severity=warning --source-path=scripts/build/lib --external-sources 2>&1 \
    | wc -l || true)"
  if [ "${shellcheck_issues}" -le 1 ]; then
    echo -e "  ${green}✓${reset} no shellcheck warnings"
  else
    echo -e "  ${yellow}!${reset} ${shellcheck_issues} shellcheck warning line(s) (informational; CI is warning-only)"
  fi
  echo
fi

if [ -z "${SOVEREIGN_OS_PRECOMMIT_SKIP_L3:-}" ]; then
  echo -e "${bold}[L3 — full nspawn suite]${reset} (30+ seconds)"
  for t in tests/nspawn/test_*.sh; do
    [ -x "${t}" ] || continue
    name="$(basename "${t}" .sh)"
    if "${t}" >/dev/null 2>&1; then
      echo -e "  ${green}✓${reset} ${name}"
    else
      echo -e "  ${red}✗${reset} ${name} FAILED — run \`${t}\` to see details"; failed=1
    fi
  done
  echo
fi

if [ "${failed}" -ne 0 ]; then
  echo -e "${bold}${red}✗ pre-commit gate FAILED${reset} — fix issues or use \`git commit --no-verify\` (last resort)"
  exit 1
fi
echo -e "${bold}${green}✓ pre-commit gate clean${reset}"
exit 0
