# /etc/sovereign-os/inference-router.env
# OpenAI-compatible router in front of the direct stack
#
# Edit and reload: sudo systemctl restart sovereign-router.service

# Listen address (default local-only; bind to a network address only if
# trusted clients on a known segment need access).
SOVEREIGN_OS_ROUTER_HOST=127.0.0.1
SOVEREIGN_OS_ROUTER_PORT=8080

SOVEREIGN_OS_LOG_LEVEL=info
