# /etc/sovereign-os/inference-logic-engine.env
# Logic Engine — vLLM (default) or llama.cpp on RTX 3090 (VFIO-bound)
#
# Edit and reload: sudo systemctl restart sovereign-logic-engine.service

SOVEREIGN_OS_LOGIC_BACKEND=vllm
LOGIC_MODEL=/mnt/vault/models/qwen3-coder
LOGIC_HOST=127.0.0.1
LOGIC_PORT=8082

# llama.cpp fallback:
# SOVEREIGN_OS_LOGIC_BACKEND=llama_cpp
# LOGIC_MODEL=/mnt/vault/models/qwen3-coder.Q4_K_M.gguf

SOVEREIGN_OS_PROFILE=sain-01
SOVEREIGN_OS_LOG_LEVEL=info
