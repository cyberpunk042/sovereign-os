# /etc/sovereign-os/inference-pulse.env
# Pulse — bitnet.cpp on CCD 0
#
# Edit and reload: sudo systemctl restart sovereign-pulse.service

PULSE_MODEL=/mnt/vault/models/microsoft__bitnet-b1.58-2B-4T
PULSE_HOST=127.0.0.1
PULSE_PORT=8081
PULSE_AFFINITY=0-5

# Optional kernel choice: TL2 (default x86) | I2_S (lossless; slightly slower)
BITNET_KERNEL=TL2

# Optional: override binary location
# BITNET_BIN=/usr/local/bin/bitnet-cli

SOVEREIGN_OS_PROFILE=sain-01
SOVEREIGN_OS_LOG_LEVEL=info
