# /etc/sovereign-os/inference-oracle-core.env
# Oracle Core — vLLM + DFlash on RTX PRO 6000 Blackwell (host-resident)
#
# Pick ONE of the operator-named candidates per cmp-ling-26-flash-vs-nemotron-3-nano-omni:
#   - Nemotron-3-Nano-Omni: BF16 native fit; multimodal; up to 1M context
#   - Ling-2.6-flash: 107B MoE; MIT license; needs Q4 or MoE-active-only

ORACLE_MODEL=/mnt/vault/models/nvidia__Nemotron-3-Nano-Omni-30B-A3B-Reasoning-BF16
ORACLE_HOST=127.0.0.1
ORACLE_PORT=8083

# KV-cache dtype: 'auto' on first run; 'fp8' for deep-context profiles
ORACLE_KV_CACHE_DTYPE=fp8

# DFlash speculative-decoding draft (only set when a checkpoint is published
# for the target model on z-lab's HuggingFace org). Boosts code/math 3-6×.
# ORACLE_DFLASH_DRAFT=z-lab/Nemotron-3-Nano-Omni-DFlash

SOVEREIGN_OS_PROFILE=sain-01
SOVEREIGN_OS_LOG_LEVEL=info
