[Unit]
Description=Sovereign Code Console read-only API + webapp host (SDD-112)
Documentation=https://github.com/cyberpunk042/sovereign-os/blob/main/scripts/operator/code-console-api.py
# Read-only observation + composer surface for the claude.ai/code-style Code
# Console panel. Composes two shipped cores: the M057 session registry
# (/run/sovereign-os/sessions.json) for the LEFT rail, and the SDD-062/103
# loopback prompt engine for the composer. There is NO host mutation surface —
# the ONLY POST is /api/code-console/chat, a NON-mutating inference read-compute
# to the loopback router (R10212); every real action is an MS003-signed CLI verb.
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /usr/local/lib/sovereign-os/scripts/operator/code-console-api.py
Restart=on-failure
RestartSec=3
StandardOutput=journal
StandardError=journal

# Loopback-by-default — operator-§1g exposure decision is theirs. To expose
# beyond loopback, drop /etc/systemd/system/sovereign-code-console-api.service.d/bind.conf:
#   [Service]
#   Environment=CODE_CONSOLE_API_BIND=0.0.0.0
Environment=CODE_CONSOLE_API_BIND=127.0.0.1
Environment=CODE_CONSOLE_API_PORT=8140

# R171 defense-in-depth (Layer-1 lint enforced). Read-only HTTP surface;
# reads the session registry + appends the metrics textfile.
ProtectSystem=strict
ProtectClock=true
ProtectHostname=true
RestrictSUIDSGID=true
ReadWritePaths=/var/lib/node_exporter/textfile_collector
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictNamespaces=true
RestrictRealtime=true
LockPersonality=true
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
SystemCallArchitectures=native
SystemCallFilter=@system-service
SystemCallFilter=~@privileged @resources

[Install]
WantedBy=multi-user.target
