[Unit]
Description=Daily sovereign-os log rotation
Documentation=https://github.com/cyberpunk042/sovereign-os/blob/main/scripts/hooks/recurrent/log-rotate.sh

[Timer]
# Daily 03:30 local; randomize +/- 30 minutes to avoid storms
OnCalendar=*-*-* 03:30:00
RandomizedDelaySec=1800
Persistent=true
Unit=sovereign-log-rotate.service

[Install]
WantedBy=timers.target
