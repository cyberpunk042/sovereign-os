[Unit]
Description=Sovereign evals read-only API + D-10 dashboard host (M060 R10106-R10108)
Documentation=https://github.com/cyberpunk042/sovereign-os/blob/main/scripts/operator/evals-api.py
# Read-only observation surface: aggregates the Eval-Value fabric's eval-run
# log into per-task pass/fail + per-model trend + benchmark-suite progress +
# adapter-promotion candidates (cross-referenced with the D-11 adapter
# registry), enforcing the M079 WB/BB disaggregation invariant in the core.
# There is NO mutation surface — eval runs + adapter promotion are MS003-signed
# CLI verbs, never web mutations.
After=network.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /usr/local/lib/sovereign-os/scripts/operator/evals-api.py
Restart=on-failure
RestartSec=3
StandardOutput=journal
StandardError=journal

# Loopback-by-default — operator-§1g exposure decision is theirs. To expose
# beyond loopback, drop /etc/systemd/system/sovereign-evals-api.service.d/bind.conf:
#   [Service]
#   Environment=EVALS_API_BIND=0.0.0.0
Environment=EVALS_API_BIND=127.0.0.1
Environment=EVALS_API_PORT=8108

# R171 defense-in-depth (Layer-1 lint enforced). Read-only HTTP surface;
# reads the eval log + adapter registry + appends the metrics textfile.
ProtectSystem=strict
ProtectClock=true
ProtectHostname=true
RestrictSUIDSGID=true
ReadWritePaths=/var/lib/node_exporter/textfile_collector
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictNamespaces=true
RestrictRealtime=true
LockPersonality=true
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
SystemCallArchitectures=native
SystemCallFilter=@system-service
SystemCallFilter=~@privileged @resources

[Install]
WantedBy=multi-user.target
